{"sections":[],"metadata":{"title":"Migrating from Ensembles 2","roleHeading":"Article","modules":[{"name":"Ensembles"}],"role":"article"},"kind":"article","hierarchy":{"paths":[["doc:\/\/Ensembles\/documentation\/Ensembles"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensembles\/migratingfromensembles2"]}],"abstract":[{"type":"text","text":"Transition an existing Ensembles 2 (Objective-C) app to Ensembles 3."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Ensembles\/documentation\/Ensembles\/MigratingFromEnsembles2"},"seeAlsoSections":[{"identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted"],"title":"Related Documentation","anchor":"Related-Documentation"},{"identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted","doc:\/\/Ensembles\/documentation\/Ensembles\/Architecture","doc:\/\/Ensembles\/documentation\/Ensembles\/ConflictResolution","doc:\/\/Ensembles\/documentation\/Ensembles\/CustomCloudBackends"],"title":"Articles","generated":true,"anchor":"Articles"}],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Ensembles 3 is fully backward compatible with Ensembles 2 cloud data. You can migrate without a data reset — existing cloud files, event stores, and CloudKit records are all readable by E3 out of the box."}],"type":"paragraph"},{"text":"What’s Backward Compatible","anchor":"Whats-Backward-Compatible","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Cloud files"}],"type":"strong"},{"type":"text","text":" — The directory structure and file formats in the cloud are identical. E3 reads all E2 cloud data."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Event store"}]},{"text":" — The Core Data model for the local event database (","type":"text"},{"code":"CDEEventStoreModel","type":"codeVoice"},{"type":"text","text":") is unchanged."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"JSON format","type":"text"}],"type":"strong"},{"type":"text","text":" — Property change values use the same JSON serialization."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"CloudKit records"}],"type":"strong"},{"text":" — Record types (","type":"text"},{"code":"CDEFileSystemNode","type":"codeVoice"},{"type":"text","text":", "},{"code":"CDEItem","type":"codeVoice"},{"type":"text","text":", "},{"code":"CDEDataFile","type":"codeVoice"},{"text":") and field names are preserved.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Encryption","type":"text"}]},{"type":"text","text":" — E3’s "},{"type":"codeVoice","code":".legacy"},{"type":"text","text":" encryption format (RNCryptor v3) matches E2’s "},{"code":"CDEEncryptedCloudFileSystem","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reading E2 data works regardless of compatibility mode — compatibility mode only restricts what E3 "},{"inlineContent":[{"type":"text","text":"exports"}],"type":"emphasis"},{"text":".","type":"text"}]},{"type":"heading","level":3,"text":"Step-by-Step Migration","anchor":"Step-by-Step-Migration"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"1. Swap the dependency"}],"type":"strong"}]},{"type":"paragraph","inlineContent":[{"text":"Replace the Ensembles 2 CocoaPod or framework with the Ensembles 3 Swift package:","type":"text"}]},{"code":["\/\/ Package.swift",".package(url: \"https:\/\/github.com\/mentalfaculty\/Ensembles-3.git\", from: \"3.0.0\")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or add it via Xcode’s "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Add Package Dependencies"}]},{"type":"text","text":" menu."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"2. Set compatibility mode","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If some users may still be running the E2 version of your app, set "},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode\/ensembles2Compatible","type":"reference","isActive":true},{"type":"text","text":" so E3 restricts its exports to formats E2 peers can parse:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ With a container","let config = EnsembleContainerConfiguration(","    compatibilityMode: .ensembles2Compatible",")","let container = CoreDataEnsembleContainer(","    name: \"MainStore\",","    storeURL: storeURL,","    modelURL: modelURL,","    cloudFileSystem: cloudFS,","    configuration: config",")","","\/\/ Or directly on an ensemble","ensemble.compatibilityMode = .ensembles2Compatible"]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"3. Update API names","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"text":"Ensembles 3 uses different class and method names:","type":"text"}],"type":"paragraph"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Ensembles 2 (Objective-C)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Ensembles 3 (Swift)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"CDEPersistentStoreEnsemble"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","isActive":true,"type":"reference"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"CDEPersistentStoreEnsembleDelegate","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate","type":"reference"}]}]],[[{"inlineContent":[{"type":"codeVoice","code":"leechPersistentStore(...)"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CoreDataEnsemble\/attachPersistentStore()"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"deleechPersistentStore(...)"}]}],[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/detachPersistentStore()"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":"mergeWithCompletion:","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/sync(options:)"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"CDECloudFileSystem","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem","type":"reference","isActive":true}]}]],[[{"type":"paragraph","inlineContent":[{"code":"CDEEncryptedCloudFileSystem","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"EncryptedCloudFileSystem"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"CDECloudKitFileSystem","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CloudKitFileSystem"}]}]]],"type":"table"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"4. Test thoroughly"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Verify your app can read existing cloud data from E2 peers."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Confirm that E2 peers can still read data exported by your E3 build (while in "},{"type":"codeVoice","cod