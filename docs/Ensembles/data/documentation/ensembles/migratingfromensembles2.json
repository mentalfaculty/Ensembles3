{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Transition an existing Ensembles 2 (Objective-C) app to Ensembles 3."}],"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted"],"anchor":"Related-Documentation"},{"title":"Articles","identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted","doc:\/\/Ensembles\/documentation\/Ensembles\/Architecture","doc:\/\/Ensembles\/documentation\/Ensembles\/ConflictResolution","doc:\/\/Ensembles\/documentation\/Ensembles\/CustomCloudBackends"],"anchor":"Articles","generated":true}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Ensembles 3 is fully backward compatible with Ensembles 2 cloud data. You can migrate without a data reset — existing cloud files, event stores, and CloudKit records are all readable by E3 out of the box."}],"type":"paragraph"},{"level":3,"type":"heading","text":"What’s Backward Compatible","anchor":"Whats-Backward-Compatible"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Cloud files","type":"text"}],"type":"strong"},{"type":"text","text":" — The directory structure and file formats in the cloud are identical. E3 reads all E2 cloud data."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Event store","type":"text"}],"type":"strong"},{"type":"text","text":" — The Core Data model for the local event database ("},{"type":"codeVoice","code":"CDEEventStoreModel"},{"type":"text","text":") is unchanged."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"JSON format","type":"text"}],"type":"strong"},{"type":"text","text":" — Property change values use the same JSON serialization."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"CloudKit records","type":"text"}],"type":"strong"},{"type":"text","text":" — Record types ("},{"type":"codeVoice","code":"CDEFileSystemNode"},{"type":"text","text":", "},{"type":"codeVoice","code":"CDEItem"},{"type":"text","text":", "},{"type":"codeVoice","code":"CDEDataFile"},{"type":"text","text":") and field names are preserved."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Encryption","type":"text"}],"type":"strong"},{"type":"text","text":" — E3’s "},{"type":"codeVoice","code":".legacy"},{"type":"text","text":" encryption format (RNCryptor v3) matches E2’s "},{"type":"codeVoice","code":"CDEEncryptedCloudFileSystem"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Reading E2 data works regardless of compatibility mode — compatibility mode only restricts what E3 "},{"type":"emphasis","inlineContent":[{"text":"exports","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"},{"level":3,"type":"heading","text":"Step-by-Step Migration","anchor":"Step-by-Step-Migration"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"1. Swap the dependency","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Replace the Ensembles 2 CocoaPod or framework with the Ensembles 3 Swift package:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Package.swift",".package(url: \"https:\/\/github.com\/mentalfaculty\/Ensembles-3.git\", from: \"3.0.0\")"]},{"inlineContent":[{"type":"text","text":"Or add it via Xcode’s "},{"type":"emphasis","inlineContent":[{"text":"Add Package Dependencies","type":"text"}]},{"type":"text","text":" menu."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"2. Set compatibility mode","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If some users may still be running the E2 version of your app, set "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode\/ensembles2Compatible","isActive":true},{"type":"text","text":" so E3 restricts its exports to formats E2 peers can parse:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ With a container","let config = EnsembleContainerConfiguration(","    compatibilityMode: .ensembles2Compatible",")","let container = CoreDataEnsembleContainer(","    name: \"MainStore\",","    storeURL: storeURL,","    modelURL: modelURL,","    cloudFileSystem: cloudFS,","    configuration: config",")","","\/\/ Or directly on an ensemble","ensemble.compatibilityMode = .ensembles2Compatible"]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"3. Update API names","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Ensembles 3 uses different class and method names:"}],"type":"paragraph"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Ensembles 2 (Objective-C)","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Ensembles 3 (Swift)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CDEPersistentStoreEnsemble"}]}],[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","type":"reference"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CDEPersistentStoreEnsembleDelegate"}]}],[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate","type":"reference"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"leechPersistentStore(...)"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CoreDataEnsemble\/attachPersistentStore()"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"deleechPersistentStore(...)"}]}],[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/detachPersistentStore()","type":"reference"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"mergeWithCompletion:"}]}],[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/sync(options:)","type":"reference"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CDECloudFileSystem"}]}],[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem","type":"reference"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CDEEncryptedCloudFileSystem"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"EncryptedCloudFileSystem"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CDECloudKitFileSystem"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CloudKitFileSystem"}]}]]],"header":"row"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"4. Test thoroughly","type":"text"}]}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Verify your app can read existing cloud data from E2 peers."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Confirm that E2 peers can still read data exported by your E3 build (while in "},{"type":"codeVoice","code":".ensembles2Compatible"},{"type":"text","text":" mode)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Test attachment, sync, and detach cycles."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"5. Switch to full E3 mode","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Once all users have upgraded to the E3 version of your app, change the compatibility mode to unlock future E3-only features:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["ensemble.compatibilityMode = .ensembles3  \/\/ the default"]},{"level":3,"type":"heading","text":"What `ensembles2Compatible` Restricts","anchor":"What-ensembles2Compatible-Restricts"},{"inlineContent":[{"type":"text","text":"Currently, "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode\/ensembles2Compatible","isActive":true},{"type":"text","text":" applies one restriction:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Model hashes","type":"text"}],"type":"strong"},{"type":"text","text":": Forces "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/compressModelHashes"},{"type":"text","text":" to "},{"type":"codeVoice","code":"false"},{"type":"text","text":", so model version hashes use the full XML property list format that E2 peers can parse."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"No other export behavior is changed. As E3 evolves, additional restrictions may be added to this mode to maintain E2 compatibility."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/Ensembles\/documentation\/Ensembles"]]},"variants":[{"paths":["\/documentation\/ensembles\/migratingfromensembles2"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Article","modules":[{"name":"Ensembles"}],"role":"article","title":"Migrating from Ensembles 2"},"identifier":{"url":"doc:\/\/Ensembles\/documentation\/Ensembles\/MigratingFromEnsembles2","interfaceLanguage":"swift"},"kind":"article","sections":[],"references":{"doc://Ensembles/documentation/Ensembles/CoreDataEnsemble/sync(options:)":{"abstract":[{"type":"text","text":"Syncs changes with other peers."}],"url":"\/documentation\/ensembles\/coredataensemble\/sync(options:)","ki