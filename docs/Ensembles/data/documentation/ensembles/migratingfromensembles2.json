{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"Transition an existing Ensembles 2 (Objective-C) app to Ensembles 3.","type":"text"}],"sections":[],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Ensembles\/documentation\/Ensembles\/MigratingFromEnsembles2"},"metadata":{"modules":[{"name":"Ensembles"}],"title":"Migrating from Ensembles 2","roleHeading":"Article","role":"article"},"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted"],"title":"Related Documentation"},{"generated":true,"identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted","doc:\/\/Ensembles\/documentation\/Ensembles\/Architecture","doc:\/\/Ensembles\/documentation\/Ensembles\/ConflictResolution","doc:\/\/Ensembles\/documentation\/Ensembles\/CustomCloudBackends"],"title":"Articles","anchor":"Articles"}],"variants":[{"paths":["\/documentation\/ensembles\/migratingfromensembles2"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Ensembles 3 is fully backward compatible with Ensembles 2 cloud data. You can migrate without a data reset — existing cloud files, event stores, and CloudKit records are all readable by E3 out of the box."}],"type":"paragraph"},{"level":3,"anchor":"Whats-Backward-Compatible","text":"What’s Backward Compatible","type":"heading"},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Cloud files"}],"type":"strong"},{"type":"text","text":" — The directory structure and file formats in the cloud are identical. E3 reads all E2 cloud data."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Event store"}],"type":"strong"},{"text":" — The Core Data model for the local event database (","type":"text"},{"code":"CDEEventStoreModel","type":"codeVoice"},{"text":") is unchanged.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"JSON format"}]},{"type":"text","text":" — Property change values use the same JSON serialization."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"CloudKit records"}],"type":"strong"},{"type":"text","text":" — Record types ("},{"code":"CDEFileSystemNode","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CDEItem","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CDEDataFile","type":"codeVoice"},{"text":") and field names are preserved.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Encryption"}]},{"text":" — E3’s ","type":"text"},{"code":".legacy","type":"codeVoice"},{"text":" encryption format (RNCryptor v3) matches E2’s ","type":"text"},{"code":"CDEEncryptedCloudFileSystem","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Reading E2 data works regardless of compatibility mode — compatibility mode only restricts what E3 "},{"inlineContent":[{"text":"exports","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"},{"level":3,"anchor":"Step-by-Step-Migration","text":"Step-by-Step Migration","type":"heading"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"1. Swap the dependency"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Replace the Ensembles 2 CocoaPod or framework with the Ensembles 3 Swift package:"}],"type":"paragraph"},{"code":["\/\/ Package.swift",".package(url: \"https:\/\/github.com\/mentalfaculty\/Ensembles-3.git\", from: \"3.0.0\")"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Or add it via Xcode’s "},{"inlineContent":[{"type":"text","text":"Add Package Dependencies"}],"type":"emphasis"},{"text":" menu.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"2. Set compatibility mode"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"text":"If some users may still be running the E2 version of your app, set ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode\/ensembles2Compatible","type":"reference"},{"text":" so E3 restricts its exports to formats E2 peers can parse:","type":"text"}],"type":"paragraph"},{"code":["\/\/ With a container","let config = EnsembleContainerConfiguration(","    compatibilityMode: .ensembles2Compatible",")","let container = CoreDataEnsembleContainer(","    name: \"MainStore\",","    storeURL: storeURL,","    modelURL: modelURL,","    cloudFileSystem: cloudFS,","    configuration: config",")","","\/\/ Or directly on an ensemble","ensemble.compatibilityMode = .ensembles2Compatible"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"3. Update API names"}],"type":"strong"}]},{"inlineContent":[{"type":"text","text":"Ensembles 3 uses different class and method names:"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Ensembles 2 (Objective-C)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Ensembles 3 (Swift)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"CDEPersistentStoreEnsemble"}],"type":"paragraph"}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"CDEPersistentStoreEnsembleDelegate"}],"type":"paragraph"}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"leechPersistentStore(...)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"CoreDataEnsemble\/attachPersistentStore()"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"deleechPersistentStore(...)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/detachPersistentStore()"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"mergeWithCompletion:"}],"type":"paragraph"}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/sync(options:)"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"CDECloudFileSystem","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"CDEEncryptedCloudFileSystem","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"EncryptedCloudFileSystem","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":"CDECloudKitFileSystem","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"CloudKitFileSystem","type":"codeVoice"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"4. Test thoroughly"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Verify your app can read existing cloud data from E2 peers.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Confirm that E2 peers can still read data exported by your E3 build (while in ","type":"text"},{"code":".ensembles2Compatible","type":"codeVoice"},{"text":" mode).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Test attachment, sync, and detach cycles.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"5. Switch to full E3 mode"}],"type":"strong"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Once all users have upgraded to the E3 version of your app, change the compatibility mode to unlock future E3-only features:"}],"type":"paragraph"},{"syntax":"swift","code":["ensemble.compatibilityMode = .ensembles3  \/\/ the default"],"type":"codeListing"},{"anchor":"What-ensembles2Compatible-Restricts","type":"heading","level":3,"text":"What `ensembles2Compatible` Restricts"},{"inlineContent":[{"type":"text","text":"Currently, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode\/ensembles2Compatible"},{"type":"text","text":" applies one restriction:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Model hashes"}]},{"type":"text","text":": Forces "},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/compressModelHashes","type":"reference","isActive":true},{"type":"text","text":" to "},{"type":"codeVoice","code":"false"},{"type":"text","text":", so model version hashes use the full XML property list format that E2 peers can parse."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"No other export behavior is changed. As E3 evolves, additional restrictions may be added to this mode to maintain E2 compatibility."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/Ensembles\/documentation\/Ensembles"]]},"references":{"doc://Ensembles/documentation/Ensembles/CoreDataEnsembleDelegate":{"kind":"symbol","type":"topic","title":"CoreDataEnsembleDelegate","url":"\/documentation\/ensembles\/coredataensembledelegate","identifier":"doc:\/\/