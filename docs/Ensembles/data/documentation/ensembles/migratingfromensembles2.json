{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensembles\/migratingfromensembles2"]}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Ensembles 3 is fully backward compatible with Ensembles 2 cloud data. You can migrate without a data reset — existing cloud files, event stores, and CloudKit records are all readable by E3 out of the box.","type":"text"}]},{"anchor":"Whats-Backward-Compatible","type":"heading","text":"What’s Backward Compatible","level":3},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Cloud files"}]},{"type":"text","text":" — The directory structure and file formats in the cloud are identical. E3 reads all E2 cloud data."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Event store"}],"type":"strong"},{"text":" — E3 uses a raw SQLite event store for performance, but automatically migrates from E2’s Core Data event store on first launch. The migration is transparent — no action is needed.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"JSON format"}],"type":"strong"},{"text":" — Property change values use the same JSON serialization.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"CloudKit records"}],"type":"strong"},{"text":" — Record types (","type":"text"},{"code":"CDEFileSystemNode","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CDEItem","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CDEDataFile","type":"codeVoice"},{"text":") and field names are preserved.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Encryption"}],"type":"strong"},{"text":" — E3’s ","type":"text"},{"code":".legacy","type":"codeVoice"},{"text":" encryption format (RNCryptor v3) matches E2’s ","type":"text"},{"code":"CDEEncryptedCloudFileSystem","type":"codeVoice"},{"text":".","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Reading E2 data works regardless of compatibility mode — compatibility mode only restricts what E3 ","type":"text"},{"inlineContent":[{"type":"text","text":"exports"}],"type":"emphasis"},{"text":".","type":"text"}]},{"anchor":"Step-by-Step-Migration","type":"heading","text":"Step-by-Step Migration","level":3},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"1. Swap the dependency"}],"type":"strong"}]},{"type":"paragraph","inlineContent":[{"text":"Replace the Ensembles 2 CocoaPod or framework with the Ensembles 3 Swift package:","type":"text"}]},{"code":["\/\/ Package.swift",".package(url: \"https:\/\/github.com\/mentalfaculty\/Ensembles-3.git\", from: \"3.0.0\")"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Or add it via Xcode’s ","type":"text"},{"inlineContent":[{"type":"text","text":"Add Package Dependencies"}],"type":"emphasis"},{"text":" menu.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"2. Set compatibility mode"}],"type":"strong"}]},{"type":"paragraph","inlineContent":[{"text":"If some users may still be running the E2 version of your app, set ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode\/ensembles2Compatible","isActive":true},{"text":" so E3 restricts its exports to formats E2 peers can parse:","type":"text"}]},{"code":["\/\/ With a container","let config = EnsembleContainerConfiguration(","    compatibilityMode: .ensembles2Compatible",")","let container = CoreDataEnsembleContainer(","    name: \"MainStore\",","    storeURL: storeURL,","    modelURL: modelURL,","    cloudFileSystem: cloudFS,","    configuration: config",")","","\/\/ Or directly on an ensemble","ensemble.compatibilityMode = .ensembles2Compatible"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"3. Update API names"}],"type":"strong"}]},{"type":"paragraph","inlineContent":[{"text":"Ensembles 3 uses different class and method names:","type":"text"}]},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Ensembles 2 (Objective-C)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Ensembles 3 (Swift)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"CDEPersistentStoreEnsemble"}],"type":"paragraph"}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"CDEPersistentStoreEnsembleDelegate"}],"type":"paragraph"}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"leechPersistentStore(...)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"CoreDataEnsemble\/attachPersistentStore()"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"deleechPersistentStore(...)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/detachPersistentStore()"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"mergeWithCompletion:"}],"type":"paragraph"}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/sync(options:)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"CDECloudFileSystem"}],"type":"paragraph"}],[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"CDEEncryptedCloudFileSystem"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"EncryptedCloudFileSystem"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"CDECloudKitFileSystem"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"CloudKitFileSystem"}],"type":"paragraph"}]]],"type":"table"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"4. Test thoroughly"}],"type":"strong"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Verify your app can read existing cloud data from E2 peers.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Confirm that E2 peers can still read data exported by your E3 build (while in ","type":"text"},{"code":".ensembles2Compatible","type":"codeVoice"},{"text":" mode).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Test attachment, sync, and detach cycles.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"5. Switch to full E3 mode"}],"type":"strong"}]},{"type":"paragraph","inlineContent":[{"text":"Once all users have upgraded to the E3 version of your app, change the compatibility mode to unlock future E3-only features:","type":"text"}]},{"code":["ensemble.compatibilityMode = .ensembles3  \/\/ the default"],"syntax":"swift","type":"codeListing"},{"anchor":"What-ensembles2Compatible-Restricts","type":"heading","text":"What `ensembles2Compatible` Restricts","level":3},{"type":"paragraph","inlineContent":[{"text":"Currently, ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode\/ensembles2Compatible","isActive":true},{"text":" applies one restriction:","type":"text"}]},{"type":"unorder