,"type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"Once all users have upgraded to the E3 version of your app, change the compatibility mode to unlock future E3-only features:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["ensemble.compatibilityMode = .ensembles3  \/\/ the default"]},{"type":"heading","level":3,"text":"What `ensembles2Compatible` Restricts","anchor":"What-ensembles2Compatible-Restricts"},{"type":"paragraph","inlineContent":[{"text":"Currently, ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CompatibilityMode\/ensembles2Compatible"},{"type":"text","text":" applies one restriction:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Model hashes","type":"text"}],"type":"strong"},{"type":"text","text":": Forces "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/compressModelHashes"},{"type":"text","text":" to "},{"code":"false","type":"codeVoice"},{"type":"text","text":", so model version hashes use the full XML property list format that E2 peers can parse."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"No other export behavior is changed. As E3 evolves, additional restrictions may be added to this mode to maintain E2 compatibility."}]}],"kind":"content"}],"metadata":{"modules":[{"name":"Ensembles"}],"title":"Migrating from Ensembles 2","roleHeading":"Article","role":"article"},"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Transition an existing Ensembles 2 (Objective-C) app to Ensembles 3."}],"sections":[],"references":{"doc://Ensembles/documentation/Ensembles/CoreDataEnsemble/detachPersistentStore()":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"detachPersistentStore"},{"kind":"text","text":"() "},{"k