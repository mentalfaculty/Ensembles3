{"abstract":[{"type":"text","text":"Implement the CloudFileSystem protocol to sync via any storage service."}],"hierarchy":{"paths":[["doc:\/\/Ensembles\/documentation\/Ensembles"]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Ensembles exchanges sync data through a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem","type":"reference"},{"text":" — a protocol that abstracts file storage behind a simple path-based API. Any service that can store and retrieve files at paths can serve as a backend: cloud storage (S3, Google Cloud Storage), file servers (WebDAV, SFTP), databases, or even peer-to-peer connections with a local cache.","type":"text"}]},{"type":"heading","anchor":"The-CloudFileSystem-Protocol","level":2,"text":"The CloudFileSystem Protocol"},{"type":"paragraph","inlineContent":[{"text":"The core protocol has 8 requirements organized into four groups:","type":"text"}]},{"type":"heading","anchor":"Connection","level":3,"text":"Connection"},{"type":"codeListing","code":["public protocol CloudFileSystem: AnyObject, Sendable {","    var isConnected: Bool { get }","    func connect() async throws","    func fetchUserIdentity() async throws","        -> sending (any NSObjectProtocol & NSCoding & NSCopying)?","}"],"syntax":"swift"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem\/isConnected","isActive":true},{"type":"text","text":" — Return whether the backend is ready for operations."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem\/connect()","isActive":true},{"type":"text","text":" — Establish a connection. Called before each attach or merge."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem\/fetchUserIdentity()","isActive":true},{"type":"text","text":" — Return a token identifying the current user, or "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if identity tracking is not supported. Ensembles uses this to detect account changes (e.g., signing out of iCloud)."}]}]}]},{"type":"heading","anchor":"File-Operations","level":3,"text":"File Operations"},{"type":"codeListing","code":["func fileExists(atPath path: String) async throws -> FileExistence","func createDirectory(atPath path: String) async throws","func contentsOfDirectory(atPath path: String) async throws -> [any CloudItem]","func removeItem(atPath path: String) async throws"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Paths are forward-slash separated, rooted at ","type":"text"},{"type":"codeVoice","code":"\/"},{"text":". The ensemble creates a directory structure like ","type":"text"},{"type":"codeVoice","code":"\/MyEnsemble\/events\/"},{"text":", ","type":"text"},{"type":"codeVoice","code":"\/MyEnsemble\/baselines\/"},{"text":", etc.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Directory listings should return ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFile","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudDirectory","type":"reference"},{"text":" items with their ","type":"text"},{"type":"codeVoice","code":"path"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"name"},{"text":" populated. Only list immediate children — do not recurse.","type":"text"}]},{"type":"heading","anchor":"File-Transfer","level":3,"text":"File Transfer"},{"type":"codeListing","code":["func uploadLocalFile(atPath localPath: String, toPath remotePath: String) async throws","func downloadFile(atPath remotePath: String, toLocalFile localPath: String) async throws"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Upload copies a local file to the remote path. Download copies a remote file to the local path. Both paths are absolute on their respective systems (local paths are filesystem paths; remote paths are within the cloud file system’s namespace).","type":"text"}]},{"type":"heading","anchor":"A-Minimal-Example","level":2,"text":"A Minimal Example"},{"type":"paragraph","inlineContent":[{"text":"Here is a skeleton implementation to illustrate the structure:","type":"text"}]},{"type":"codeListing","code":["import Ensembles","","public final class MyCloudFileSystem: CloudFileSystem, @unchecked Sendable {","","    public var isConnected: Bool { true }","","    public func connect() async throws {","        \/\/ Authenticate or establish a session","    }","","    public func fetchUserIdentity() async throws","        -> sending (any NSObjectProtocol & NSCoding & NSCopying)? {","        \/\/ Return a user token, or nil","        return nil","    }","","    public func fileExists(atPath path: String) async throws -> FileExistence {","        \/\/ Check your storage and return the result","    }","","    public func createDirectory(atPath path: String) async throws {","        \/\/ Create a directory marker or equivalent","    }","","    public func contentsOfDirectory(atPath path: String) async throws","        -> [any CloudItem] {","        \/\/ List immediate children as CloudFile\/CloudDirectory items","    }","","    public func removeItem(atPath path: String) async throws {","        \/\/ Delete a file or directory (and its contents)","    }","","    public func uploadLocalFile(","        atPath localPath: String,","        toPath remotePath: String","    ) async throws {","        let data = try Data(contentsOf: URL(fileURLWithPath: localPath))","        \/\/ Store data at remotePath in your backend","    }","","    public func downloadFile(","        atPath remotePath: String,","        toLocalFile localPath: String","    ) async throws {","        \/\/ Retrieve data from remotePath in your backend","        let data: Data = \/\/ ...fetch from backend","        try data.write(to: URL(fileURLWithPath: localPath), options: .atomic)","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"Reference-Implementations","level":2,"text":"Reference Implementations"},{"type":"paragraph","inlineContent":[{"text":"Study the built-in backends as starting points:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"MemoryCloudFileSystem"}]},{"type":"text","text":" (in "},{"type":"codeVoice","code":"EnsemblesMemory"},{"type":"text","text":") — The simplest implementation. An actor that stores files in a dictionary. Good for understanding the protocol’s expectations."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"LocalCloudFileSystem"}]},{"type":"text","text":" (in "},{"type":"codeVoice","code":"EnsemblesLocalFile"},{"type":"text","text":") — Uses "},{"type":"codeVoice","code":"FileManager"},{"type":"text","text":" to store files in a local directory. Shows how to map the protocol onto a real file system."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"CloudKitFileSystem"}]},{"type":"text","text":" (in "},{"type":"codeVoice","code":"EnsemblesCloudKit"},{"type":"text","text":") — A production backend using CloudKit. Shows how to implement batch operations and setup hooks."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"PCloudCloudFileSystem"}]},{"type":"text","text":" (in "},{"type":"codeVoice","code":"EnsemblesPCloud"},{"type":"text","text":") — A URLSession-based REST client with no SDK dependency. A good model for building backends against any REST API."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"BoxCloudFileSystem"}]},{"type":"text","text":" (in "},{"type":"codeVoice","code":"EnsemblesBox"},{"type":"text","text":") — Wraps the Box Swift SDK. Demonstrates how to bridge an ID-based API (where files are identified by numeric IDs, not paths) onto the path-based "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" protocol using folder-walking and caching."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"S3CloudFileSystem"}]},{"type":"text","text":" (in "},{"type":"codeVoice","code":"EnsemblesS3"},{"type":"text","text":") — Wraps the AWS SDK for Swift. Shows how to simulate directory semantics on a flat key-value store using key prefixes and delimiters."}]}]}]},{"type":"heading","anchor":"Optional-Batch-Operations","level":2,"text":"Optional: Batch Operations"},{"type":"paragraph","inlineContent":[{"text":"If your backend can handle multiple files in a single request (reducing round trips), adopt ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemBatchOperations","type":"reference"},{"text":":","type":"text"}]},{"type":"codeListing","code":["extension MyCloudFileSystem: CloudFileSystemBatchOperations {","    public var fileUploadMaximumBatchSize: Int { 20 }","    public var fileDownloadMaximumBatchSize: Int { 20 }","","    public func uploadLocalFiles(","        atPaths localPaths: [String],","        toPaths remotePaths: [String]","    ) async throws {","        \/\/ Upload multiple files in one request","    }","","    public func downloadFiles(","        atPaths remotePaths: [String],","        toLocalFiles localPaths: [String]","    ) async throws {","        \/\/ Download multiple files in one request","    }","","    public func removeItems(atPaths paths: [String]) async throws {","        \/\/ Delete multiple items in one request","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"fileUploadMaximumBatchSize"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"fileDownloadMaximumBatchSize"},{"text":" properties control how many files Ensembles passes per batch call. Default is 10 if you don’t override them.","type":"text"}]},{"type":"heading","anchor":"Optional-Setup-Hooks","level":2,"text":"Optional: Setup Hooks"},{"type":"paragraph","inlineContent":[{"text":"For backends that need initialization, caching, or repair logic, adopt ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemSetup","type":"reference"},{"text":":","type":"text"}]},{"type":"codeListing","code":["extension MyCloudFileSystem: CloudFileSystemSetup {","    public func performInitialPreparation() async throws {","        \/\/ One-time setup (e.g., create root directories)","    }","","    public func primeForActivity() async throws {","        \/\/ Called before each operation (e.g., refresh auth tokens,","        \/\/ cache directory listings)","    }","","    public func directoryExists(atPath path: String) async throws -> Bool {","        \/\/ Check directory existence","    }","","    public func repairEnsembleDirectory(atPath path: String) async throws {","        \/\/ Fix up issues like iCloud duplicates or stale locks","    }","}"],"syntax":"swift"},{"type":"heading","anchor":"Threading-and-Sendable","level":2,"text":"Threading and Sendable"},{"type":"paragraph","inlineContent":[{"text":"Cloud file systems must conform to ","type":"text"},{"type":"codeVoice","code":"Sendable"},{"text":". If your implementation uses mutable state, you have several options:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"actor"},{"type":"text","text":" isolation (as "},{"type":"codeVoice","code":"MemoryCloudFileSystem"},{"type":"text","text":" does)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"@unchecked Sendable"},{"type":"text","text":" with explicit locking (as "},{"type":"codeVoice","code":"LocalCloudFileSystem"},{"type":"text","text":" does)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Make the type stateless, delegating state to a thread-safe service"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"All protocol methods are ","type":"text"},{"type":"codeVoice","code":"async throws"},{"text":", so you can freely call async APIs in your implementation.","type":"text"}]}]}],"kind":"article","identifier":{"url":"doc:\/\/Ensembles\/documentation\/Ensembles\/CustomCloudBackends","interfaceLanguage":"swift"},"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem","doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemBatchOperations","doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemSetup"],"title":"Cloud Backends","anchor":"Cloud-Backends","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensembles\/customcloudbackends"]}],"metadata":{"roleHeading":"Article","title":"Custom Cloud Backends","role":"article","modules":[{"name":"Ensembles"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://Ensembles/documentation/Ensembles/CloudFile":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"CloudFile","kind":"identifier"}],"title":"CloudFile","url":"\/documentation\/ensembles\/cloudfile","type":"topic","navigatorTitle":[{"text":"CloudFile","kind":"identifier"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFile","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"R