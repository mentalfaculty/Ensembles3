{"variants":[{"paths":["\/documentation\/ensembles\/customcloudbackends"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Ensembles exchanges sync data through a ","type":"text"},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem","isActive":true,"type":"reference"},{"text":" — a protocol that abstracts file storage behind a simple path-based API. Any service that can store and retrieve files at paths can serve as a backend: cloud storage (S3, Google Cloud Storage), file servers (WebDAV, SFTP), databases, or even peer-to-peer connections with a local cache.","type":"text"}]},{"text":"The CloudFileSystem Protocol","type":"heading","anchor":"The-CloudFileSystem-Protocol","level":2},{"type":"paragraph","inlineContent":[{"text":"The core protocol has 8 requirements organized into four groups:","type":"text"}]},{"text":"Connection","type":"heading","anchor":"Connection","level":3},{"syntax":"swift","code":["public protocol CloudFileSystem: AnyObject, Sendable {","    var isConnected: Bool { get }","    func connect() async throws","    func fetchUserIdentity() async throws","        -> sending (any NSObjectProtocol & NSCoding & NSCopying)?","}"],"type":"codeListing"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem\/isConnected"},{"text":" — Return whether the backend is ready for operations.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem\/connect()","isActive":true,"type":"reference"},{"type":"text","text":" — Establish a connection. Called before each attach or merge."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem\/fetchUserIdentity()","type":"reference","isActive":true},{"text":" — Return a token identifying the current user, or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if identity tracking is not supported. Ensembles uses this to detect account changes (e.g., signing out of iCloud).","type":"text"}]}]}]},{"anchor":"File-Operations","type":"heading","text":"File Operations","level":3},{"type":"codeListing","code":["func fileExists(atPath path: String) async throws -> FileExistence","func createDirectory(atPath path: String) async throws","func contentsOfDirectory(atPath path: String) async throws -> [any CloudItem]","func removeItem(atPath path: String) async throws"],"syntax":"swift"},{"inlineContent":[{"text":"Paths are forward-slash separated, rooted at ","type":"text"},{"code":"\/","type":"codeVoice"},{"text":". The ensemble creates a directory structure like ","type":"text"},{"code":"\/MyEnsemble\/events\/","type":"codeVoice"},{"text":", ","type":"text"},{"code":"\/MyEnsemble\/baselines\/","type":"codeVoice"},{"text":", etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Directory listings should return ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFile","isActive":true},{"text":" or ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudDirectory","isActive":true},{"text":" items with their ","type":"text"},{"code":"path","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"name","type":"codeVoice"},{"text":" populated. Only list immediate children — do not recurse.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"File-Transfer","text":"File Transfer","type":"heading"},{"syntax":"swift","code":["func uploadLocalFile(atPath localPath: String, toPath remotePath: String) async throws","func downloadFile(atPath remotePath: String, toLocalFile localPath: String) async throws"],"type":"codeListing"},{"inlineContent":[{"text":"Upload copies a local file to the remote path. Download copies a remote file to the local path. Both paths are absolute on their respective systems (local paths are filesystem paths; remote paths are within the cloud file system’s namespace).","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"A-Minimal-Example","text":"A Minimal Example","type":"heading"},{"inlineContent":[{"text":"Here is a skeleton implementation to illustrate the structure:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import Ensembles","","public final class MyCloudFileSystem: CloudFileSystem, @unchecked Sendable {","","    public var isConnected: Bool { true }","","    public func connect() async throws {","        \/\/ Authenticate or establish a session","    }","","    public func fetchUserIdentity() async throws","        -> sending (any NSObjectProtocol & NSCoding & NSCopying)? {","        \/\/ Return a user token, or nil","        return nil","    }","","    public func fileExists(atPath path: String) async throws -> FileExistence {","        \/\/ Check your storage and return the result","    }","","    public func createDirectory(atPath path: String) async throws {","        \/\/ Create a directory marker or equivalent","    }","","    public func contentsOfDirectory(atPath path: String) async throws","        -> [any CloudItem] {","        \/\/ List immediate children as CloudFile\/CloudDirectory items","    }","","    public func removeItem(atPath path: String) async throws {","        \/\/ Delete a file or directory (and its contents)","    }","","    public func uploadLocalFile(","        atPath localPath: String,","        toPath remotePath: String","    ) async throws {","        let data = try Data(contentsOf: URL(fileURLWithPath: localPath))","        \/\/ Store data at remotePath in your backend","    }","","    public func downloadFile(","        atPath remotePath: String,","        toLocalFile localPath: String","    ) async throws {","        \/\/ Retrieve data from remotePath in your backend","        let data: Data = \/\/ ...fetch from backend","        try data.write(to: URL(fileURLWithPath: localPath), options: .atomic)","    }","}"],"type":"codeListing"},{"level":2,"anchor":"Reference-Implementations","text":"Reference Implementations","type":"heading"},{"inlineContent":[{"text":"Study the built-in backends as starting points:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"MemoryCloudFileSystem","type":"codeVoice"}]},{"text":" (in ","type":"text"},{"type":"codeVoice","code":"EnsemblesMemory"},{"text":") — The simplest implementation. An actor that stores files in a dictionary. Good for understanding the protocol’s expectations.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"LocalCloudFileSystem","type":"codeVoice"}]},{"text":" (in ","type":"text"},{"type":"codeVoice","code":"EnsemblesLocalFile"},{"text":") — Uses ","type":"text"},{"type":"codeVoice","code":"FileManager"},{"text":" to store files in a local directory. Shows how to map the protocol onto a real file system.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"CloudKitFileSystem","type":"codeVoice"}]},{"text":" (in ","type":"text"},{"type":"codeVoice","code":"EnsemblesCloudKit"},{"text":") — A production backend using CloudKit. Shows how to implement batch operations and setup hooks.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"PCloudCloudFileSystem","type":"codeVoice"}]},{"text":" (in ","type":"text"},{"type":"codeVoice","code":"EnsemblesPCloud"},{"text":") — A URLSession-based REST client with no SDK dependency. A good model for building backends against any REST API.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"BoxCloudFileSystem","type":"codeVoice"}]},{"text":" (in ","type":"text"},{"type":"codeVoice","code":"EnsemblesBox"},{"text":") — Wraps the Box Swift SDK. Demonstrates how to bridge an ID-based API (where files are identified by numeric IDs, not paths) onto the path-based ","type":"text"},{"type":"codeVoice","code":"CloudFileSystem"},{"text":" protocol using folder-walking and caching.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"S3CloudFileSystem","type":"codeVoice"}]},{"text":" (in ","type":"text"},{"type":"codeVoice","code":"EnsemblesS3"},{"text":") — Wraps the AWS SDK for Swift. Shows how to simulate directory semantics on a flat key-value store using key prefixes and delimiters.","type":"text"}]}]}],"type":"unorderedList"},{"content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"EnsemblesBox"},{"type":"text","text":" and "},{"type":"codeVoice","code":"EnsemblesS3"},{"type":"text","text":" (along with "},{"type":"codeVoice","code":"EnsemblesDropbox"},{"type":"text","text":", "},{"type":"codeVoice","code":"EnsemblesZip"},{"type":"text","text":", and "},{"type":"codeVoice","code":"EnsemblesMultipeer"},{"type":"text","text":") require an external SDK. With the source distribution, enabling the corresponding package trait resolves this automatically. With the binary distribution (XCFrameworks), you must add the external SDK as a separate package dependency — see the Available Backends table in the README for details."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"level":2,"anchor":"Optional-Batch-Operations","text":"Optional: Batch Operations","type":"heading"},{"inlineContent":[{"text":"If your backend can handle multiple files in a single request (reducing round trips), adopt ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemBatchOperations","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["extension MyCloudFileSystem: CloudFileSystemBatchOperations {","    public var fileUploadMaximumBatchSize: Int { 20 }","    public var fileDownloadMaximumBatchSize: Int { 20 }","","    public func uploadLocalFiles(","        atPaths localPaths: [String],","        toPaths remotePaths: [String]","    ) async throws {","        \/\/ Upload multiple files in one request","    }","","    public func downloadFiles(","        atPaths remotePaths: [String],","        toLocalFiles localPaths: [String]","    ) async throws {","        \/\/ Download multiple files in one request","    }","","    public func removeItems(atPaths paths: [String]) async throws {","        \/\/ Delete multiple items in one request","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"fileUploadMaximumBatchSize","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"fileDownloadMaximumBatchSize","type":"codeVoice"},{"text":" properties control how many files Ensembles passes per batch call. Default is 10 if you don’t override them.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Optional-Setup-Hooks","text":"Optional: Setup Hooks","type":"heading"},{"inlineContent":[{"text":"For backends that need initialization, caching, or repair logic, adopt ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemSetup","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["extension MyCloudFileSystem: CloudFileSystemSetup {","    public func performInitialPreparation() async throws {","        \/\/ One-time setup (e.g., create root directories)","    }","","    public func primeForActivity() async throws {","        \/\/ Called before each operation (e.g., refresh auth tokens,","        \/\/ cache directory listings)","    }","","    public func directoryExists(atPath path: String) async throws -> Bool {","        \/\/ Check directory existence","    }","","    public func repairEnsembleDirectory(atPath path: String) async throws {","        \/\/ Fix up issues like iCloud duplicates or stale locks","    }","}"],"type":"codeListing"},{"level":2,"anchor":"Threading-and-Sendable","text":"Threading and Sendable","type":"heading"},{"inlineContent":[{"text":"Cloud file systems must conform to ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":". If your implementation uses mutable state, you have several options:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"actor"},{"text":" isolation (as ","type":"text"},{"type":"codeVoice","code":"MemoryCloudFileSystem"},{"text":" does)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"@unchecked Sendable"},{"text":" with explicit locking (as ","type":"text"},{"type":"codeVoice","code":"LocalCloudFileSystem"},{"text":" does)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Make the type stateless, delegating state to a thread-safe service","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"All protocol methods are ","type":"text"},{"code":"async throws","type":"codeVoice"},{"text":", so you can freely call async APIs in your implementation.","type":"text"}],"type":"paragraph"}]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/Ensembles\/documentation\/Ensembles"]]},"metadata":{"title":"Custom Cloud Backends","modules":[{"name":"Ensembles"}],"roleHeading":"Article","role":"article"},"abstract":[{"text":"Implement the CloudFileSystem protocol to sync via any storage service.","type":"text"}],"identifier":{"url":"doc:\/\/Ensembles\/documentation\/Ensembles\/CustomCloudBackends","interfaceLanguage":"swift"},"schemaVersion":{"major":0,