ion/Ensembles/SyncOptions":{"title":"SyncOptions","url":"\/documentation\/ensembles\/syncoptions","abstract":[{"text":"Options that control which phases of a sync are executed.","type":"text"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SyncOptions","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SyncOptions","kind":"identifier"}],"type":"topic","kind":"symbol","navigatorTitle":[{"text":"SyncOptions","kind":"identifier"}]},"doc://Ensembles/documentation/Ensembles/SeedPolicy/mergeAllData":{"kind":"symbol","type":"topic","url":"\/documentation\/ensembles\/seedpolicy\/mergealldata","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"mergeAllData","kind":"identifier"}],"title":"SeedPolicy.mergeAllData","abstract":[{"text":"Import the local store contents and merge them with cloud data at the next merge.","type":"text"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SeedPolicy\/mergeAllData","role":"symbol"},"doc://Ensembles/documentation/Ensembles/CoreDataEnsemble/sync(options:)":{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/sync(options:)","role":"symbol","title":"sync(options:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sync","kind":"identifier"},{"text":"(","kind":"text"},{"text":"options","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SyncOptions","preciseIdentifier":"s:9Ensembles11SyncOptionsV","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"}],"type":"topic","abstract":[{"text":"Syncs changes with other peers.","type":"text"}],"url":"\/documentation\/ensembles\/coredataensemble\/sync(options:)"},"doc://Ensembles/documentation/Ensembles/SyncingPhase":{"url":"\/documentation\/ensembles\/syncingphase","role":"symbol","navigatorTitle":[{"text":"SyncingPhase","ki