{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Set up Ensembles to sync a Core Data persistent store across devices.","type":"text"}],"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate"],"anchor":"Essentials","generated":true}],"identifier":{"url":"doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensembles\/gettingstarted"]}],"hierarchy":{"paths":[["doc:\/\/Ensembles\/documentation\/Ensembles"]]},"metadata":{"title":"Getting Started","role":"article","modules":[{"name":"Ensembles"}],"roleHeading":"Article"},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Ensembles synchronizes a Core Data SQLite store by recording local changes as events and exchanging them through a cloud backend. This guide walks through the essential steps, starting with the simplest approach using "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Add Ensembles to Your Project","anchor":"Add-Ensembles-to-Your-Project","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Add the Ensembles package to your "},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":" or via Xcode’s package dependencies. Import the core module and one cloud backend:"}],"type":"paragraph"},{"syntax":"swift","code":["import Ensembles","import EnsemblesCloudKit   \/\/ or EnsemblesLocalFile, EnsemblesMemory"],"type":"codeListing"},{"text":"The Easy Way: EnsembleContainer","anchor":"The-Easy-Way-EnsembleContainer","level":2,"type":"heading"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer"},{"type":"text","text":" handles the most common setup: it creates the Core Data stack, sets up a delegate that auto-merges remote changes, and syncs automatically on save, on app activation, and on a timer."}],"type":"paragraph"},{"syntax":"swift","code":["let container = CoreDataEnsembleContainer(","    name: \"MainStore\",","    storeURL: storeURL,","    modelURL: modelURL,","    cloudFileSystem: CloudKitFileSystem(","        ubiquityContainerIdentifier: \"iCloud.com.example.app\"","    )",")","","\/\/ Supply global identifiers for deduplication","container?.globalIdentifiers = { objects in","    objects.map { $0.value(forKey: \"uniqueID\") as? String }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The container automatically attaches to the cloud and begins syncing. It provides a main-queue "},{"type":"codeVoice","code":"viewContext"},{"type":"text","text":" for your UI and merges remote changes into it automatically. Use "},{"type":"codeVoice","code":"didSaveMergeChanges"},{"type":"text","text":" for additional processing, and "},{"type":"codeVoice","code":"didEncounterError"},{"type":"text","text":" or "},{"type":"codeVoice","code":"didForceDetach"},{"type":"text","text":" for error handling."}],"type":"paragraph"},{"text":"Working with an Existing Stack","anchor":"Working-with-an-Existing-Stack","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"If you already have an "},{"type":"codeVoice","code":"NSPersistentContainer"},{"type":"text","text":" or "},{"type":"codeVoice","code":"NSManagedObjectContext"},{"type":"text","text":", pass it in:"}],"type":"paragraph"},{"syntax":"swift","code":["let container = CoreDataEnsembleContainer(","    persistentContainer: myPersistentContainer,","    cloudFileSystem: cloudFS",")"],"type":"codeListing"},{"text":"Auto-Sync Configuration","anchor":"Auto-Sync-Configuration","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Control when syncing occurs with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/AutoSyncPolicy"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["let config = EnsembleContainerConfiguration(","    autoSyncPolicy: [.onSave, .onTimer],   \/\/ Sync on save and timer, not on activation","    timerInterval: 30                       \/\/ Timer fires every 30 seconds",")","let container = CoreDataEnsembleContainer(","    name: \"MainStore\",","    storeURL: storeURL,","    modelURL: modelURL,","    cloudFileSystem: cloudFS,","    configuration: config",")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Set "},{"type":"codeVoice","code":"autoSyncPolicy"},{"type":"text","text":" to "},{"type":"codeVoice","code":".manual"},{"type":"text","text":" and call "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer\/sync()"},{"type":"text","text":" yourself for full control."}],"type":"paragraph"},{"text":"Backward Compatibility","anchor":"Backward-Compatibility","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"If you’re transitioning from Ensembles 2 and some users may still be on E2, set the compatibility mode:"}],"type":"paragraph"},{"syntax":"swift","code":["let config = EnsembleContainerConfiguration(","    compatibilityMode: .ensembles2Compatible",")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This restricts exports to formats that Ensembles 2 peers can parse. Switch to "},{"type":"codeVoice","code":".ensembles3"},{"type":"text","text":" (the default) once all users have upgraded."}],"type":"paragraph"},{"text":"The Manual Way: CoreDataEnsemble","anchor":"The-Manual-Way-CoreDataEnsemble","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"For more control over the sync lifecycle, use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble"},{"type":"text","text":" directly."}],"type":"paragraph"},{"text":"Create an Ensemble","anchor":"Create-an-Ensemble","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Initialize a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble"},{"type":"text","text":" with your persistent store URL, managed object model URL, and a cloud file system:"}],"type":"paragraph"},{"syntax":"swift","code":["let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.example.app\"",")","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")","ensemble?.delegate = self"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/ensembleIdentifier"},{"type":"text","text":" must be the same on all devices that should sync together. If you have multiple persistent stores, create one ensemble per store with a unique identifier."}],"type":"paragraph"},{"text":"Attach to the Cloud","anchor":"Attach-to-the-Cloud","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Before syncing, the ensemble must attach — this registers the device in the cloud and imports existing store data into the event log:"}],"type":"paragraph"},{"syntax":"swift","code":["try await ensemble?.attachPersistentStore()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Attachment is persistent: once attached, the ensemble stays attached across app launches until you explicitly detach. Check "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/isAttached"},{"type":"text","text":" to determine the current state."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Avoid saving to the persistent store while attaching. If a save is detected, attachment will fail with an error and you will need to retry."}]}],"style":"important","name":"Important","type":"aside"},{"text":"Seed Policies","anchor":"Seed-Policies","level":4,"type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SeedPolicy"},{"type":"text","text":" parameter controls how existing data in the store is handled:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SeedPolicy\/mergeAllData","isActive":true,"type":"reference"},{"text":" (default) — Imports local data so it can be merged with data from other devices.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SeedPolicy\/excludeLocalData","isActive":true,"type":"reference"},{"text":" — Ignores local data. Use this when you want to start fresh from cloud data, typically after deleting and recreating the store.","type":"text"}]}]}],"type":"unorderedList"},{"text":"Sync Changes","anchor":"Sync-Changes","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Call "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/sync(options:)"},{"type":"text","text":" periodically to sync — for example, when the app enters the foreground, on a timer, or in response to a push notification:"}],"type":"paragraph"},{"syntax":"swift","code":["try await ensemble?.sync()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"A sync downloads remote events, replays them into the local store, and uploads new local events. Sync errors are usually transient (incomplete downloads, save interruptions) — just retry later."}],"type":"paragraph"},{"text":"Sync Options","anchor":"Sync-Options","level":4,"type":"heading"},{"inlineContent":[{"type":"text","text":"For advanced control, pass "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SyncOptions"},{"type":"text","text":" to customize which phases run:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Download only — don't integrate into the store or upload","try await ensemble?.sync(options: .cloudFileRetrievalOnly)","","\/\/ Force a rebase to compact sync history","try await ensemble?.sync(options: .forceRebase)"],"type":"codeListing"},{"text":"Handle the Delegate","anchor":"Handle-the-Delegate","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Implement "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate"},{"type":"text","text":" to respond to sync events. The most important method merges remote changes into your main context:"}],"type":"paragraph"},{"syntax":"swift","code":["extension AppDelegate: CoreDataEnsembleDelegate {","    func coreDataEnsemble(","        _ ensemble: CoreDataEnsemble,","        didSaveMergeChangesWith notification: Notification","    ) {","        \/\/ Update the main context with merged changes","        viewContext.perform {","            self.viewContext.mergeChanges(fromContextDidSave: notification)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Other delegate methods let you:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Inspect and repair merge data"}],"type":"strong"},{"text":" before it’s committed (","type":"text"},{"code":"shouldSaveMergedChangesIn:reparationContext:","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Handle save failures"}],"type":"strong"},{"text":" during merging (","type":"text"},{"code":"didFailToSaveMergedChangesIn:error:reparationContext:","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"React to forced detaches"}],"type":"strong"},{"text":" caused by identity changes or data corruption (","type":"text"},{"code":"didDetachWithError:","type":"codeVoice"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Supply global identifiers"}],"type":"strong"},{"text":" for automatic deduplication (","type":"text"},{"code":"globalIdentifiersForManagedObjects:","type":"codeVoice"},{"text":")","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/ConflictResolution"},{"type":"text","text":" for more on conflict handling and the reparation context."}],"type":"paragraph"},{"text":"Detach","anchor":"Detach","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"To stop syncing, detach from the cloud:"}],"type":"paragraph"},{"syntax":"swift","code":["try await ensemble?.detachPersistentStore()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This removes local sync data (event logs and metadata). The persistent store itself is not affected. You can re-attach later to resume syncing."}],"type":"paragraph"},{"text":"Process Pending Changes","anchor":"Process-Pending-Changes","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"On iOS, the app may be suspended before Ensembles finishes recording a save. Call "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/processPendingChanges()"},{"type":"text","text":" — for example, in a background task — to ensure all changes are fully stored:"}],"type":"paragraph"},{"syntax":"swift","code":["try await ensemble?.processPendingChanges()"],"type":"codeListing"},{"text":"Monitor Activity","anchor":"Monitor-Activity","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Track long-running operations via "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/currentActivity"},{"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/activityProgress"},{"type":"text","text":", or observe these notifications:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"coreDataEnsembleDidBeginActivity","type":"codeVoice"},{"text":" — An activity started","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"coreDataEnsembleDidMakeProgressWithActivity","type":"codeVoice"},{"text":" — Progress updated (includes ","type":"text"},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SyncingPhase","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/AttachingPhase","isActive":true,"type":"reference"},{"text":")","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"coreDataEnsembleWillEndActivity","type":"codeVoice"},{"text":" — An activity finished (may include an error)","type":"text"}]}]}],"type":"unorderedList"}]}],"references":{"doc://Ensembles/documentation/Ensembles/CoreDataEnsembleDelegate":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"CoreDataEnsembleDelegate"}],"url":"\/documentation\/ensembles\/coredataensembledelegate","abstract":[{"text":"Methods invoked by ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Co