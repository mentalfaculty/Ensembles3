{"variants":[{"paths":["\/documentation\/ensembles\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/Ensembles\/documentation\/Ensembles"]]},"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted"},"abstract":[{"text":"Set up Ensembles to sync a Core Data or SwiftData persistent store across devices.","type":"text"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/SwiftDataIntegration","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate"],"anchor":"Essentials","title":"Essentials"}],"metadata":{"modules":[{"name":"Ensembles"}],"roleHeading":"Article","role":"article","title":"Getting Started"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"Ensembles synchronizes SQLite stores by recording local changes as events and exchanging them through a cloud backend. It works with both Core Data and SwiftData.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Using SwiftData?"}]},{"text":" See ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SwiftDataIntegration","isActive":true},{"text":" for a complete guide — you never need to touch Core Data directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This guide covers Core Data setup, starting with a complete working example using "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Add-Ensembles-to-Your-Project","text":"Add Ensembles to Your Project","type":"heading"},{"inlineContent":[{"text":"Add the Ensembles package to your ","type":"text"},{"type":"codeVoice","code":"Package.swift"},{"text":" or via Xcode’s package dependencies:","type":"text"}],"type":"paragraph"},{"syntax":null,"code":["https:\/\/github.com\/mentalfaculty\/Ensembles-3.git"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Import the core module and one cloud backend:"}],"type":"paragraph"},{"syntax":"swift","code":["import Ensembles","import EnsemblesCloudKit   \/\/ or EnsemblesLocalFile, EnsemblesMemory"],"type":"codeListing"},{"level":2,"anchor":"Complete-Example-Core-Data-with-CloudKit","text":"Complete Example: Core Data with CloudKit","type":"heading"},{"inlineContent":[{"type":"text","text":"Here’s a complete, working setup for a SwiftUI app that syncs via CloudKit. This uses "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer"},{"type":"text","text":", which creates the Core Data stack for you and syncs automatically."}],"type":"paragraph"},{"anchor":"1-Create-Your-Core-Data-Model","type":"heading","level":3,"text":"1. Create Your Core Data Model"},{"type":"paragraph","inlineContent":[{"text":"In Xcode, add a ","type":"text"},{"code":".xcdatamodeld","type":"codeVoice"},{"text":" file to your project (e.g., ","type":"text"},{"inlineContent":[{"type":"text","text":"Model.xcdatamodeld"}],"type":"strong"},{"text":"). Define your entities as usual. For this example, we’ll assume a ","type":"text"},{"code":"Note","type":"codeVoice"},{"type":"text","text":" entity with "},{"code":"title","type":"codeVoice"},{"type":"text","text":" (String) and "},{"type":"codeVoice","code":"uniqueID"},{"type":"text","text":" (String) attributes."}]},{"text":"2. Define Your Model with `Syncable`","type":"heading","anchor":"2-Define-Your-Model-with-Syncable","level":3},{"inlineContent":[{"type":"text","text":"For deduplication, conform your "},{"code":"NSManagedObject","type":"codeVoice"},{"type":"text","text":" subclass to the "},{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Syncable","type":"reference"},{"text":" protocol and specify which property holds the global identifier. A UUID assigned at creation time is usually the best choice:","type":"text"}],"type":"paragraph"},{"code":["import CoreData","import Ensembles","","class Note: NSManagedObject, Syncable {","    static let globalIdentifierKey = \"uniqueID\"","    @NSManaged var uniqueID: String","    @NSManaged var title: String","}"],"type":"codeListing","syntax":"swift"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A global identifier ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"must never change"}]},{"text":" once it has been assigned. Changing it after sync has begun will cause duplicates or data loss.","type":"text"}]}],"type":"aside","style":"important","name":"Important"},{"inlineContent":[{"type":"text","text":"Use a fixed, meaningful value instead of a UUID for singleton objects or reference data like tags, where two devices might independently create the same logical object."}],"type":"paragraph"},{"anchor":"3-Set-Up-the-Container","type":"heading","level":3,"text":"3. Set Up the Container"},{"type":"codeListing","syntax":"swift","code":["import SwiftUI","import Ensembles","import EnsemblesCloudKit","","@main","struct MyApp: App {","    let syncContainer: CoreDataEnsembleContainer","","    init() {","        \/\/ The model URL points to the .momd bundle compiled from your .xcdatamodeld","        let modelURL = Bundle.main.url(forResource: \"Model\", withExtension: \"momd\")!","","        \/\/ This creates a full Core Data stack automatically:","        \/\/ - SQLite store at Application Support\/MyNotes.sqlite","        \/\/ - Main-queue viewContext for your UI","        \/\/ - Auto-sync on save, on app activation, and on a 5-minute timer","        let container = CoreDataEnsembleContainer(","            name: \"MyNotes\",","            modelURL: modelURL,","            cloudFileSystem: CloudKitFileSystem(","                ubiquityContainerIdentifier: \"iCloud.com.example.mynotes\"","            )","        )!","","        self.syncContainer = container","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","                .environment(","                    \\.managedObjectContext,","                    syncContainer.viewContext","                )","        }","    }","}"]},{"inlineContent":[{"text":"That’s the complete setup. The container discovers ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Syncable"},{"text":" conformances automatically, attaches to the cloud, and begins syncing. Remote changes are merged into ","type":"text"},{"type":"codeVoice","code":"viewContext"},{"text":" so your UI stays up to date.","type":"text"}],"type":"paragraph"},{"anchor":"4-Respond-to-Events-Optional","type":"heading","level":3,"text":"4. Respond to Events (Optional)"},{"type":"codeListing","syntax":"swift","code":["\/\/ Called after remote changes are merged into viewContext","container.didSaveMergeChanges = { notification in","    print(\"Merged remote changes\")","}","","\/\/ Called if a sync fails","container.didEncounterError = { error in","    print(\"Sync error: \\(error)\")","}"]},{"anchor":"Using-a-Custom-Store-Location","type":"heading","level":2,"text":"Using a Custom Store Location"},{"inlineContent":[{"text":"If you need control over where the SQLite file lives, pass an explicit ","type":"text"},{"code":"storeURL","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let appSupport = FileManager.default.urls(","    for: .applicationSupportDirectory, in: .userDomainMask",").first!","let storeURL = appSupport.appendingPathComponent(\"MyApp\/data.sqlite\")","try FileManager.default.createDirectory(","    at: storeURL.deletingLastPathComponent(),","    withIntermediateDirectories: true",")","","let container = CoreDataEnsembleContainer(","    name: \"MyNotes\",","    storeURL: storeURL,","    modelURL: Bundle.main.url(forResource: \"Model\", withExtension: \"momd\")!,","    cloudFileSystem: CloudKitFileSystem(","        ubiquityContainerIdentifier: \"iCloud.com.example.mynotes\"","    )",")!"]},{"anchor":"Working-with-an-Existing-Core-Data-Stack","type":"heading","level":2,"text":"Working with an Existing Core Data Stack"},{"inlineContent":[{"text":"If you already have an ","type":"text"},{"code":"NSPersistentContainer","type":"codeVoice"},{"text":", pass it in directly:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let container = CoreDataEnsembleContainer(","    persistentContainer: myPersistentContainer,","    cloudFileSystem: cloudFS",")"]},{"inlineContent":[{"type":"text","text":"Or if you have an existing "},{"type":"codeVoice","code":"NSManagedObjectContext"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let container = CoreDataEnsembleContainer(","    name: \"MyNotes\",","    viewContext: myContext,","    persistentStoreURL: myStoreURL,","    managedObjectModel: myContext.persistentStoreCoordinator!.managedObjectModel,","    managedObjectModels: nil,","    cloudFileSystem: cloudFS",")"]},{"anchor":"Auto-Sync-Configuration","type":"heading","level":2,"text":"Auto-Sync Configuration"},{"inlineContent":[{"type":"text","text":"Control when syncing occurs with "},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/AutoSyncPolicy","type":"reference","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"code":["let config = EnsembleContainerConfiguration(","    autoSyncPolicy: [.onSave, .onTimer],   \/\/ Sync on save and timer, not on activation","    timerInterval: 30                       \/\/ Timer fires every 30 seconds",")","let container = CoreDataEnsembleContainer(","    name: \"MyNotes\",","    modelURL: modelURL,","    cloudFileSystem: cloudFS,","    configuration: config",")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Set ","type":"text"},{"code":"autoSyncPolicy","type":"codeVoice"},{"text":" to ","type":"text"},{"code":".manual","type":"codeVoice"},{"text":" and call ","type":"text"},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer\/sync()","isActive":true,"type":"reference"},{"text":" yourself for full control over timing.","type":"text"}],"type":"paragraph"},{"text":"Backward Compatibility with Ensembles 2","anchor":"Backward-Compatibility-with-Ensembles-2","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"If you’re transitioning from Ensembles 2 and some users may still be on E2, set the compatibility mode:"}],"type":"paragraph"},{"code":["let config = EnsembleContainerConfiguration(","    compatibilityMode: .ensembles2Compatible",")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"This restricts exports to formats that Ensembles 2 peers can parse. Switch to ","type":"text"},{"code":".ensembles3","type":"codeVoice"},{"text":" (the default) once all users have upgraded.","type":"text"}],"type":"paragraph"},{"text":"The Manual Way: CoreDataEnsemble","anchor":"The-Manual-Way-CoreDataEnsemble","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"For more control over the sync lifecycle, use "},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","isActive":true,"type":"reference"},{"type":"text","text":" directly. This is useful when you need to manage attach\/detach timing, handle specific delegate methods, or integrate with a complex Core Data stack."}],"type":"paragraph"},{"text":"Create and Attach","anchor":"Create-and-Attach","type":"heading","level":3},{"code":["import Ensembles","import EnsemblesCloudKit","","\/\/ Get the store URL from your persistent store coordinator","let store = persistentStoreCoordinator.persistentStores.first!","let storeURL = store.url!","let modelURL = Bundle.main.url(forResource: \"Model\", withExtension: \"momd\")!","","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MyNotes\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: CloudKitFileSystem(","        ubiquityContainerIdentifier: \"iCloud.com.example.mynotes\"","    )",")","ensemble?.delegate = self","","\/\/ Attach registers this device in the cloud","try await ensemble?.attachPersistentStore()"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/ensembleIdentifier"},{"text":" must be the same on all devices that should sync together. If you have multiple persistent stores, create one ensemble per store with a unique identifier.","type":"text"}],"type":"paragraph"},{"style":"important","name":"Important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Avoid saving to the persistent store while attaching. If a save is detected, attachment will fail with an error and you will need to retry."}],"type":"paragraph"}]},{"text":"Sync Changes","anchor":"Sync-Changes","type":"heading","level":3},{"inlineContent":[{"text":"Call ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/sync(options:)","type":"reference"},{"text":" periodically — for example, when the app enters the foreground, on a timer, or in response to a push notification:","type":"text"}],"type":"paragraph"},{"code":["try await ensemble?.sync()"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"A sync downloads remote events, replays them into the local store, and uploads new local events. Sync errors are usually transient — just retry later.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Handle the Delegate","anchor":"Handle-the-Delegate","type":"heading"},{"inlineContent":[{"type":"text","text":"Implement "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate","isActive":true},{"type":"text","text":" to respond to sync events. The most important method merges remote changes into your main context:"}],"type":"paragraph"},{"code":["extension AppDelegate: CoreDataEnsembleDelegate {","    func coreDataEnsemble(","        _ ensemble: CoreDataEnsemble,","        didSaveMergeChangesWith notification: Notification","    ) {","        viewContext.perform {","            self.viewContext.mergeChanges(fromContextDidSave: notification)","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"style":"tip","type":"aside","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"If your ","type":"text"},{"type":"codeVoice","code":"NSManagedObject"},{"text":" subclasses conform to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Syncable"},{"text":", you don’t need to implement ","type":"text"},{"type":"codeVoice","code":"globalIdentifiersForManagedObjects"},{"text":" — the ensemble discovers identifier properties automatically. You only need the delegate method if you use ","type":"text"},{"type":"codeVoice","code":"CoreDataEnsemble"},{"text":" directly without ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer"},{"text":".","type":"text"}]}]},{"inlineContent":[{"text":"Other delegate methods let you:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Inspect and repair merge data","type":"text"}],"type":"strong"},{"text":" before it’s committed (","type":"text"},{"type":"codeVoice","code":"shouldSaveMergedChangesIn:reparationContext:"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Handle save failures","type":"text"}]},{"type":"text","text":" during merging ("},{"type":"codeVoice","code":"didFailToSaveMergedChangesIn:error:reparationContext:"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"React to forced detaches"}],"type":"strong"},{"text":" caused by identity changes or data corruption (","type":"text"},{"code":"didDetachWithError:","type":"codeVoice"},{"text":")","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/ConflictResolution"},{"type":"text","text":" for more on conflict handling and the reparation context."}]},{"type":"heading","level":3,"anchor":"Detach","text":"Detach"},{"type":"paragraph","inlineContent":[{"text":"To stop syncing, detach from the cloud:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["try await ensemble?.detachPersistentStore()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This removes local sync data (event logs and metadata). The persistent store itself is not affected. You can re-attach later to resume syncing."}]},{"type":"heading","level":3,"anchor":"Seed-Policies","text":"Seed Policies"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SeedPolicy","isActive":true},{"type":"text","text":" parameter controls how existing data in the store is handled during attachment:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SeedPolicy\/mergeAllData","type":"reference","isActive":true},{"text":" (default) — Imports local data so it can be merged with data from other devices.","type":"text"}]}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SeedPolicy\/excludeLocalData"},{"text":" — Ignores local data. Use this when you want to start fresh from cloud data.","type":"text"}],"type":"paragraph"}]}]},{"level":3,"anchor":"Sync-Options","type":"heading","text":"Sync Options"},{"inlineContent":[{"text":"For advanced control, pass ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SyncOptions","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"code":["\/\/ Download only — don't integrate or upload","try await ensemble?.sync(options: .cloudFileRetrievalOnly)","","\/\/ Force a rebase to compact sync history","try await ensemble?.sync(options: .forceRebase)"],"type":"codeListing","syntax":"swift"},{"text":"Process Pending Changes","type":"heading","anchor":"Process-Pending-Changes","level":2},{"type":"paragraph","inlineContent":[{"text":"On iOS, the app may be suspended before Ensembles finishes recording a save. Call ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/processPendingChanges()","isActive":true},{"type":"text","text":" — for example, in a background task — to ensure all changes are fully stored:"}]},{"type":"codeListing","code":["try await ensemble?.processPendingChanges()"],"syntax":"swift"},{"type":"heading","text":"Monitor Activity","anchor":"Monitor-Activity","level":2},{"type":"paragraph","inlineContent":[{"text":"Track long-running operations via ","type":"text"},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/currentActivity","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/activityProgress"},{"text":", or observe these notifications:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"coreDataEnsembleDidBeginActivity","type":"codeVoice"},{"type":"text","text":" — An activity started"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"coreDataEnsembleDidMakeProgressWithActivity"},{"text":" — Progress updated (includes ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SyncingPhase","isActive":true},{"text":" or ","type":"text"},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/AttachingPhase","type":"reference","isActive":true},{"text":")","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"coreDataEnsembleWillEndActivity","type":"codeVoice"},{"type":"text","text":" — An activity finished (may include an error)"}],"type":"paragraph"}]}]}]}],"references":{"doc://Ensembles/documentation/Ensembles/AutoSyncPolicy":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AutoSyncPolicy"}],"abstract":[{"type":"text","text":"Controls when automatic merges occur."}],"type":"topic","title":"AutoSyncPolicy","url":"\/documentation\/ensembles\/autosyncpolicy","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/AutoSyncPolicy","role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"AutoSyncPolicy"}]},"doc://Ensembles/documentation/Ensembles/CoreDataEnsembleContainer/sync()":{"type":"topic","title":"sync()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"sync","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"async","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer\/sync()","abstract":[{"text":"Attach if needed and merge changes with peers.","type":"text"}],"kind":"symbol","url":"\/documentation\/ensembles\/coredataensemblecontainer\/sync()"},"doc://Ensembles/documentation/Ensembles/CoreDataEnsembleDelegate":{"type":"topic","title":"CoreDataEnsembleDelegate","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CoreDataEnsembleDelegate","kind":"identifier"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate","abstract":[{"type":"text","text":"Methods invoked by "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","isActive":true},{"text":" to inform of sync-related changes.","type":"text"}],"kind":"symbol","url":"\/documentation\/ensembles\/coredataensembledelegate","navigatorTitle":[{"text":"CoreDataEnsembleDelegate","kind":"identifier"}]},"doc://Ensembles/documentation/Ensembles/CoreDataEnsembleContainer":{"type":"topic","title":"CoreDataEnsembleContainer","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"CoreDataEnsembleContainer","kind":"identifier"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer","abstract":[{"type":"text","text":"A high-level container that sets up a "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","isActive":true},{"text":" with automatic syncing,","type":"text"},{"text":" ","type":"text"},{"text":"delegate management, and optional Core Data stack creation.","type":"text"}],"kind":"symbol","url":"\/documentation\/ensembles\/coredataensemblecontainer","navigatorTitle":[{"text":"CoreDataEnsembleContainer","kind":"identifier"}]},"doc://Ensembles/documentation/Ensembles/CoreDataEnsemble/currentActivity":{"type":"topic","title":"currentActivity","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"currentActivity","kind":"identifier"},{"text":": ","kind":"text"},{"text":"EnsembleActivity","kind":"typeIdentifier","preciseIdentifier":"s:9Ensembles16EnsembleActivityO"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/currentActivity","abstract":[{"type":"text","text":"The activity currently being undertaken, if any."}],"kind":"symbol","url":"\/documentation\/ensembles\/coredataensemble\/currentactivity"},"doc://Ensembles/documentation/Ensembles/CoreDataEnsemble/sync(options:)":{"type":"topic","title":"sync(options:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sync","kind":"identifier"},{"text":"(","kind":"text"},{"text":"options","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:9Ensembles11SyncOptionsV","text":"SyncOptions","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/sync(options:)","abstract":[{"type":"text","text":"Syncs changes with other peers."}],"kind":"symbol","url":"\/documentation\/ensembles\/coredataensemble\/sync(options:)"},"doc://Ensembles/documentation/Ensembles/SwiftDataIntegration":{"abstract":[{"type":"text","text":"Sync SwiftData models with Ensembles using "},{"code":"SwiftDataEnsembleContainer","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","title":"SwiftData Integration","url":"\/documentation\/ensembles\/swiftdataintegration","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SwiftDataIntegration","role":"article","kind":"article"},"doc://Ensembles/documentation/Ensembles/SyncingPhase":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SyncingPhase","kind":"identifier"}],"abstract":[{"type":"text","text":"The phase of a sync operation currently in progress."}],"type":"topic","title":"SyncingPhase","url":"\/documentation\/ensembles\/syncingphase","identifier":"