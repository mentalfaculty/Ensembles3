{"kind":"article","hierarchy":{"paths":[["doc:\/\/Ensembles\/documentation\/Ensembles"]]},"sections":[],"variants":[{"paths":["\/documentation\/ensembles\/architecture"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"anchor":"Articles","identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/ConflictResolution","doc:\/\/Ensembles\/documentation\/Ensembles\/CustomCloudBackends","doc:\/\/Ensembles\/documentation\/Ensembles\/MigratingFromEnsembles2"],"generated":true,"title":"Articles"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Ensembles\/documentation\/Ensembles\/Architecture"},"metadata":{"role":"article","title":"Architecture","modules":[{"name":"Ensembles"}],"roleHeading":"Article"},"abstract":[{"type":"text","text":"Understand how Ensembles synchronizes Core Data stores using event sourcing."}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Ensembles uses an event-sourcing architecture. Every change to a Core Data persistent store is recorded as an event. Events are exchanged between devices through a pluggable cloud backend and replayed to bring each device’s store into a consistent state.","type":"text"}]},{"text":"Event Sourcing Model","type":"heading","level":2,"anchor":"Event-Sourcing-Model"},{"type":"paragraph","inlineContent":[{"text":"When the app saves to the monitored persistent store, a ","type":"text"},{"code":"SaveMonitor","type":"codeVoice"},{"text":" captures the inserted, updated, and deleted objects and records them as a modification event in a separate event store database. Each event records the full set of property changes and is tagged with a revision that tracks causal ordering across peers.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The event store is a separate SQLite database from your app’s store — Ensembles never modifies your model or schema. Events are stored locally until they are exported to the cloud, and remote events are imported and kept locally until they are integrated.","type":"text"}]},{"text":"The Sync Flow","type":"heading","level":2,"anchor":"The-Sync-Flow"},{"type":"paragraph","inlineContent":[{"text":"A call to ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/sync(options:)","isActive":true},{"text":" proceeds through several phases:","type":"text"}]},{"text":"1. Preparation","type":"heading","level":3,"anchor":"1-Preparation"},{"type":"paragraph","inlineContent":[{"text":"The ensemble connects to the cloud backend, verifies the device’s identity (cloud account and hardware), and checks that the device is still registered. If identity has changed (e.g., the user signed out of iCloud), the ensemble forces a detach.","type":"text"}]},{"text":"2. Import","type":"heading","level":3,"anchor":"2-Import"},{"type":"paragraph","inlineContent":[{"text":"New data files, baselines, and events are downloaded from the cloud and stored locally. File downloads can be batched for backends that support ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemBatchOperations","isActive":true},{"text":".","type":"text"}]},{"text":"3. Baseline Consolidation","type":"heading","level":3,"anchor":"3-Baseline-Consolidation"},{"type":"paragraph","inlineContent":[{"text":"Old events are compacted into a baseline snapshot. A baseline captures the full state of the store at a point in time, allowing events before that point to be discarded. This keeps the sync data from growing without bound.","type":"text"}]},{"text":"4. Rebasing","type":"heading","level":3,"anchor":"4-Rebasing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the event history grows large, the ensemble can rebase — compressing the history relative to the latest baseline. Rebasing runs automatically when Ensembles estimates a significant space saving, or can be triggered with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SyncOptions\/forceRebase"},{"type":"text","text":"."}]},{"level":3,"anchor":"5-Integration","type":"heading","text":"5. Integration"},{"inlineContent":[{"text":"Remote events are replayed into the persistent store in three stages:","type":"text"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Insert"}]},{"text":" — New objects are created in the store.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Update"}],"type":"strong"},{"text":" — Attributes and relationships are updated. When multiple peers have changed the same attribute, the value from the most recent event (by causal ordering) wins.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Delete"}]},{"type":"text","text":" — Objects marked as deleted are removed."}]}]}]},{"inlineContent":[{"type":"text","text":"Before the integrated changes are saved, the delegate can inspect and repair them via "},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate\/coreDataEnsemble(_:shouldSaveMergedChangesIn:reparationContext:)","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"level":3,"anchor":"6-Export","type":"heading","text":"6. Export"},{"inlineContent":[{"text":"New local events, baselines, and data files are uploaded to the cloud. This phase can be suppressed with ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SyncOptions\/suppressCloudFileDeposition"},{"text":".","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"7-Cleanup","type":"heading","text":"7. Cleanup"},{"inlineContent":[{"text":"Outdated remote files (events that have been superseded by baselines) are removed from the cloud.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Key-Components","type":"heading","text":"Key Components"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Component"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Role"}]}]],[[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","isActive":true,"type":"reference"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Main coordinator. Serializes all operations via an internal "},{"type":"codeVoice","code":"AsyncStream"},{"type":"text","text":"."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"EventStore"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Manages the local event database (a separate SQLite database)."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"CloudManager"}]}],[{"type":"paragraph","inlineContent":[{"text":"Orchestrates cloud file operations: snapshot, import, export, cleanup.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"EventIntegrator","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Replays remote events into the app’s persistent store."}]}]],[[{"type":"paragraph","inlineContent":[{"code":"SaveMonitor","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Observes "},{"code":"NSManagedObjectContextDidSave","type":"codeVoice"},{"type":"text","text":" to capture local changes."}]}]],[[{"type":"paragraph","inlineContent":[{"code":"RevisionManager","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Tracks causal ordering of events across distributed peers."}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"BaselineConsolidator"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"Rebaser"}]}],[{"type":"paragraph","inlineContent":[{"text":"Consolidates event history into compact snapshots.","type":"text"}]}]]],"type":"table","header":"row"},{"text":"Cloud Backends","type":"heading","level":2,"anchor":"Cloud-Backends"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All cloud backends implement the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem"},{"type":"text","text":" protocol. This is the primary extension point. See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CustomCloudBackends"},{"type":"text","text":" for a guide to adding your own."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two optional protocols extend the base:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemBatchOperations","type":"reference","isActive":true},{"text":" — Adds batch upload, download, and delete for backends that support them (reduces round trips).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemSetup","type":"reference","isActive":true},{"type":"text","text":" — Adds one-time preparation, priming, and directory repair hooks."}],"type":"paragraph"}]}]},{"text":"Model Versioning","type":"heading","level":2,"anchor":"Model-Versioning"},{"type":"paragraph","inlineContent":[{"text":"Each event is stamped with a model version hash (either a full entity-hash dictionary or a compressed MD5). During integration, ","type":"text"},{"type":"codeVoice","code":"RevisionManager"},{"text":" checks every incoming event’s model version against the local ","type":"text"},{"type":"codeVoice","code":"managedObjectModels"},{"text":" array — a list of all ","type":"text"},{"type":"codeVoice","code":"NSManagedObjectModel"},{"text":" instances the app supports.","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"When hashes match","type":"text"}]},{"type":"text","text":", the event is integrable and proceeds through the sync flow."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"When hashes don’t match","type":"text"}],"type":"strong"},{"text":", the event is flagged with ","type":"text"},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/EnsembleError\/unknownModelVersion","type":"reference","isActive":true},{"text":" and excluded from integration. This prevents applying changes that reference entities or attributes the current app version doesn’t understand.","type":"text"}]}]}],"type":"unorderedList"},{"text":"Providing Model Versions","level":3,"anchor":"Providing-Model-Versions","type":"heading"},{"inlineContent":[{"type":"text","text":"For "},{"inlineContent":[{"text":"Core Data","type":"text"}],"type":"strong"},{"text":" projects using ","type":"text"},{"code":".xcdatamodeld","type":"codeVoice"},{"text":" bundles, the URL-based convenience initializers on ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble"},{"type":"text","text":" automatically load all model versions from the bundle via "},{"type":"codeVoice","code":"loadAllModelVersions(from:)"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For "},{"inlineContent":[{"text":"SwiftData","type":"text"}],"type":"strong"},{"type":"text","text":" projects, "},{"code":"SwiftDataEnsemble","type":"codeVoice"},{"text":" builds in-memory models from ","type":"text"},{"code":"@Model","type":"codeVoice"},{"text":" types or ","type":"text"},{"type":"codeVoice","code":"VersionedSchema"},{"type":"text","text":" entries."}]},{"type":"paragraph","inlineContent":[{"text":"You can also pass ","type":"text"},{"code":"managedObjectModels","type":"codeVoice"},{"text":" directly to the designated initializer when you have in-memory models from other sources.","type":"text"}]},{"type":"heading","level":3,"text":"The `managedObjectModels` Array","anchor":"The-managedObjectModels-Array"},{"inlineContent":[{"type":"text","text":"If "},{"code":"managedObjectModels","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", model version checking is disabled and all events are treated as integrable. This is appropriate for testing but not recommended in production."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the array is non-nil, it must contain all model versions that any peer in the sync group might produce. When a peer upgrades its schema and starts emitting events with a new model hash, other peers must also be updated to include that model version or they will reject those events."}],"type":"paragraph"},{"text":"Handling Breaking Migrations","level":3,"anchor":"Handling-Breaking-Migrations","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Ensembles does not perform Core Data model migration itself — it only checks compatibility. If you add or rename entities or attributes, you must:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Include both the old and new "},{"type":"codeVoice","code":"NSManagedObjectModel"},{"text":" in the ","type":"text"},{"code":"managedObjectModels","type":"codeVoice"},{"text":" array.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Perform any necessary lightweight or custom migration on the app’s persistent store before attaching the ensemble."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Ensure all peers in the sync group are updated to understand the new schema before they sync events from upgraded peers.","type":"text"}]}]}]},{"text":"Data Flow Diagram","anchor":"Data-Flow-Diagram","level":2,"type":"heading"},{"syntax":null,"code":["┌─────────────┐     save      ┌─────────────┐    export    ┌───────────┐","│  App's Core │ ───────────── │  Event      │ ──────────── │   Cloud   │","│  Data Store │               │  Store      │              │  Backend  │","│             │ ◄──────────── │             │ ◄─────────── │           │","└─────────────┘   integrate   └─────────────┘    import    └───────────┘"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Local saves flow right: captured by the event store, then exported to the cloud. Remote changes flow left: imported from the cloud into the event store, then integrated into the app’s store."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://Ensembles/documentation/Ensembles/ConflictResolution":{"role":"article","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/ConflictResolution","title":"Conflict Resolution","type":"topic","url":"\/documentation\/ensembles\/conflictresolution","kind":"article","abstract":[{"type":"text","text":"Understand how Ensembles resolves conflicts and how to customize the process."}]},"doc://Ensembles/documentation/Ensembles":{"title":"Ensembles","abstract":[{"type":"text","text":"Sync Core Data and SwiftData stores across devices using event sourcing."}],"url":"\/documentation\/ensembles","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles","type":"topic","kind":"symbol","role":"collection"},"doc://Ensembles/documentation/Ensembles/CoreDataEnsemble":{"type":"topic","title":"CoreDataEnsemble","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CoreDataEnsemble","kind":"identifier"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","abstract":[{"type":"text","text":"The central class of Ensembles, representing a set of synchronizing persistent stores."}],"kind":"symbol","url":"\/documentation\/ensembles\/coredataensemble","navigatorTitle":[{"kind":"identifier","text":"CoreDataEnsemble"}]},"doc://Ensembles/documentation/Ensembles/CloudFileSystemSetup":{"navigatorTitle":[{"text":"CloudFileSystemSetup","kind":"identifier"}],"title":"CloudFileSystemSetup","abstract":[{"text":"Optional setup and maintenance operations for cloud file systems.","type":"text"}],"type":"topic","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemSetup","url":"\/documentation\/ensembles\/cloudfilesystemsetup","kind":"symbol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CloudFileSystemSetup","kind":"identifier"}]},"doc://Ensembles/documentation/Ensembles/EnsembleError/unknownModelVersion":{"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"unknownModelVersion"}],"abstract":[{"text":"An event references a model version not known to this device. Permanent — update the app to include all model versions.","type":"text"}],"type":"topic","title":"EnsembleError.unknownModelVersion","url":"\/documentation\/ensembles\/ensembleerror\/unknownmodelversion","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/EnsembleError\/unknownModelVersion","role":"symbol","kind":"symbol"},"doc://Ensembles/documentation/Ensembles/CoreDataEnsemble/sync(options:)":{"type":"topic","title":"sync(options:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sync","kind":"identifier"},{"text":"(","kind":"text"},{"text":"options","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:9Ensembles11SyncOptionsV","text":"SyncOptions","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble\/sync(options:)","abstract":[{"type":"text","text":"Syncs changes with other peers."}],"kind":"symbol","url":"\/documentation\/ensembles\/coredataensemble\/sync(options:)"},"doc://Ensembles/documentation/Ensembles/SyncOptions/forceRebase":{"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"forceRebase"},{"kind":"text","text":": "},{"preciseIdentifier":"s:9Ensembles11SyncOptionsV","kind":"typeIdentifier","text":"SyncOptions"}],"abstract":[{"text":"Force a rebase to compress sync data. More expensive but reduces storage.","type":"text"}],"type":"topic","title":"forceRebase","url":"\/documentation\/ensembles\/syncoptions\/forcerebase","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SyncOptions\/forceRebase","role":"symbol","kind":"symbol"},"doc://Ensembles/documentation/Ensembles/CloudFileSystemBatchOperations":{"navigatorTitle":[{"text":"CloudFileSystemBatchOperations","kind":"identifier"}],"title":"CloudFileSystemBatchOperations","type":"topic","url":"\/documentation\/ensembles\/cloudfilesystembatchoperations","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystemBatchOperations","abstract":[{"text":"Optional batch and setup operations for cloud file systems.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"CloudFileSystemBatchOperations","kind":"identifier"}]},"doc://Ensembles/documentation/Ensembles/CustomCloudBackends":{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CustomCloudBackends","kind":"article","abstract":[{"text":"Implement the CloudFileSystem protocol to sync via any storage service.","type":"text"}],"url":"\/documentation\/ensembles\/customcloudbackends","type":"topic","title":"Custom Cloud Backends","role":"article"},"doc://Ensembles/documentation/Ensembles/MigratingFromEnsembles2":{"type":"topic","title":"Migrating from Ensembles 2","role":"article","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/MigratingFromEnsembles2","abstract":[{"type":"text","text":"Transition an existing Ensembles 2 (Objective-C) app to Ensembles 3."}],"kind":"article","url":"\/documentation\/ensembles\/migratingfromensembles2"},"doc://Ensembles/documentation/Ensembles/CoreDataEnsembleDelegate/coreDataEnsemble(_:shouldSaveMergedChangesIn:reparationContext:)":{"kind":"symbol","required":true,"title":"coreDataEnsemble(_:shouldSaveMergedChangesIn:reparationContext:)","abstract":[{"type":"text","text":"Invoked when the ensemble is about to save merged changes into the persistent store."}],"role":"symbol","defaultImplementations":1,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate\/coreDataEnsemble(_:shouldSaveMergedChangesIn:reparationContext:)","url":"\/documentation\/ensembles\/coredataensembledelegate\/coredataensemble(_:shouldsavemergedchangesin:reparationcontext:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"coreDataEnsemble"},{"kind":"text","text":"("},{"preciseIdentifier":"s:9Ensembles16CoreDataEnsembleC","kind":"typeIdentifier","text":"CoreDataEnsemble"},{"kind":"text","text":", "},{"kind":"externalParam","text":"shouldSaveMergedChangesIn"},{"text":": ","kind":"text"},{"text":"NSManagedObjectContext","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSManagedObjectContext"},{"kind":"text","text":", "},{"kind":"externalParam","text":"reparationContext"},{"kind":"text","text":": "},{"preciseIdentifier":"c:objc(cs)NSManagedObjectContext","text":"NSManagedObjectContext","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}]},"doc://Ensembles/documentation/Ensembles/SyncOptions/suppressCloudFileDeposition":{"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"suppressCloudFileDeposition","kind":"identifier"},{"text":": ","kind":"text"},{"text":"SyncOptions","preciseIdentifier":"s:9Ensembles11SyncOptionsV","kind":"typeIdentifier"}],"abstract":[{"text":"Import and integrate data, but do not upload any data to the cloud.","type":"text"}],"type":"topic","title":"suppressCloudFileDeposition","url":"\/documentation\/ensembles\/syncoptions\/suppresscloudfiledeposition","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/SyncOptions\/suppressCloudFileDeposition","role":"symbol","kind":"symbol"},"doc://Ensembles/documentation/Ensembles/CloudFileSystem":{"type":"topic","title":"CloudFileSystem","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CloudFileSystem","kind":"identifier"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CloudFileSystem","abstract":[{"type":"text","text":"A cloud file system facilitates data transfer between devices."}],"kind":"symbol","url":"\/documentation\/ensembles\/cloudfilesystem","navigatorTitle":[{"text":"CloudFileSystem","kind":"identifier"}]}}}