{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensembles\/swiftdataintegration"]}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"EnsemblesSwiftData"},{"type":"text","text":" module provides SwiftData-native APIs for Ensembles sync. You never need to touch Core Data directly — just pass your "},{"type":"codeVoice","code":"@Model"},{"type":"text","text":" types and get a syncing "},{"type":"codeVoice","code":"ModelContainer"},{"type":"text","text":" back."}]},{"text":"Complete Example: SwiftData with CloudKit","type":"heading","anchor":"Complete-Example-SwiftData-with-CloudKit","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here’s a complete, working setup for a SwiftUI app that syncs SwiftData models via CloudKit."}]},{"type":"heading","level":3,"anchor":"1-Define-Your-Models","text":"1. Define Your Models"},{"type":"codeListing","code":["import SwiftData","import EnsemblesSwiftData","","@Model","class Note {","    var title: String","    var body: String","    var createdAt: Date","    var uniqueID: String","","    init(title: String, body: String) {","        self.title = title","        self.body = body","        self.createdAt = Date()","        self.uniqueID = UUID().uuidString","    }","}","","\/\/ Conform to Syncable for automatic deduplication","extension Note: Syncable {","    static let globalIdentifierKey = \"uniqueID\"","}"],"syntax":"swift"},{"type":"heading","level":3,"anchor":"2-Set-Up-the-Container","text":"2. Set Up the Container"},{"type":"codeListing","code":["import SwiftUI","import EnsemblesSwiftData","import EnsemblesCloudKit","","@main","struct MyApp: App {","    let syncContainer: SwiftDataEnsembleContainer","","    init() {","        \/\/ This creates a full SwiftData stack automatically:","        \/\/ - SQLite store at Application Support\/MyNotes.sqlite","        \/\/ - ModelContainer for your SwiftUI views","        \/\/ - Auto-sync on save, on app activation, and on a 5-minute timer","        let container = SwiftDataEnsembleContainer(","            name: \"MyNotes\",","            modelTypes: [Note.self],","            cloudFileSystem: CloudKitFileSystem(","                ubiquityContainerIdentifier: \"iCloud.com.example.mynotes\"","            )","        )!","","        self.syncContainer = container","    }","","    var body: some Scene {","        WindowGroup {","            ContentView()","                .modelContainer(syncContainer.modelContainer)","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"That’s the complete setup. The container creates a "},{"type":"codeVoice","code":"ModelContainer"},{"type":"text","text":", attaches to the cloud, and syncs automatically. Your "},{"type":"codeVoice","code":"@Query"},{"type":"text","text":" properties update automatically when remote changes arrive, thanks to persistent history tracking (enabled by default)."}]},{"anchor":"3-Use-in-Views","type":"heading","text":"3. Use in Views","level":3},{"type":"codeListing","code":["struct ContentView: View {","    @Query var notes: [Note]","    @Environment(\\.modelContext) var modelContext","","    var body: some View {","        List(notes) { note in","            Text(note.title)","        }","        .toolbar {","            Button(\"Add\") {","                modelContext.insert(Note(title: \"New Note\", body: \"\"))","            }","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"No extra save calls needed — SwiftData auto-saves, which triggers Ensembles to sync."}]},{"anchor":"Using-a-Custom-Store-Location","type":"heading","text":"Using a Custom Store Location","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need control over where the SQLite file lives:"}]},{"type":"codeListing","code":["let appSupport = FileManager.default.urls(","    for: .applicationSupportDirectory, in: .userDomainMask",").first!","let storeURL = appSupport.appendingPathComponent(\"MyApp\/data.sqlite\")","try FileManager.default.createDirectory(","    at: storeURL.deletingLastPathComponent(),","    withIntermediateDirectories: true",")","","let container = SwiftDataEnsembleContainer(","    name: \"MyNotes\",","    storeURL: storeURL,","    modelTypes: [Note.self],","    cloudFileSystem: cloudFS",")!"],"syntax":"swift"},{"anchor":"Global-Identifiers-with-Syncable","type":"heading","text":"Global Identifiers with `Syncable`","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When two devices independently create the “same” object (e.g., a tag with the same name), Ensembles needs a "},{"type":"strong","inlineContent":[{"type":"text","text":"global identifier"}]},{"type":"text","text":" to recognize they represent the same entity and merge them instead of duplicating."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"SwiftData models declare a global identifier by conforming to the "},{"type":"codeVoice","code":"Syncable"},{"type":"text","text":" protocol:"}]},{"type":"codeListing","code":["@Model","class Tag: Syncable {","    static let globalIdentifierKey = \"name\"","    var name: String","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"globalIdentifierKey"},{"type":"text","text":" names a property whose value uniquely identifies the object across all devices. When two objects of the same entity have the same global identifier value, Ensembles merges them into one."}]},{"style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A global identifier "},{"type":"strong","inlineContent":[{"text":"must never change","type":"text"}]},{"type":"text","text":" once it has been assigned to an object. Changing an identifier after sync has begun will cause Ensembles to treat the object as a different entity, leading to duplicates or data loss."}]}],"name":"Important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A UUID is usually the best choice for a global identifier — assign it once at creation time and it’s guaranteed unique across all devices:"}]},{"type":"codeListing","code":["@Model","class Note: Syncable {","    static let globalIdentifierKey = \"uniqueID\"","    var uniqueID: String","    var title: String","","    init(title: String) {","        self.uniqueID = UUID().uuidString","        self.title = title","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use a "},{"type":"strong","inlineContent":[{"type":"text","text":"fixed, meaningful value"}]},{"type":"text","text":" instead when two devices might independently create the same logical object — for example, singleton settings objects or tags that are identified by name:"}]},{"type":"codeListing","code":["@Model","class Tag: Syncable {","    static let globalIdentifierKey = \"name\"  \/\/ Two \"Work\" tags merge into one","    var name: String","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Not all entities need global identifiers — only those where independent creation of “the same” object is likely (reference data, categories, user profiles). Entities that are always created explicitly by the user (photos, drawings) typically don’t need them."}]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Entities that do not conform to "},{"type":"codeVoice","code":"Syncable"},{"type":"text","text":" (and have no global identifier provided via a closure) are synced normally but are "},{"type":"strong","inlineContent":[{"text":"not deduplicated","type":"text"}]},{"type":"text","text":". If the same logical object is created independently on two devices, both copies will exist after sync."}]}],"name":"Note"},{"anchor":"Auto-Sync-Configuration","type":"heading","text":"Auto-Sync Configuration","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Control when syncing occurs:"}]},{"type":"codeListing","code":["let config = EnsembleContainerConfiguration(","    autoSyncPolicy: [.onSave, .onTimer],","    timerInterval: 60",")","let container = SwiftDataEnsembleContainer(","    name: \"MyNotes\",","    modelTypes: [Note.self],","    cloudFileSystem: cloudFS,","    configuration: config",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set "},{"type":"codeVoice","code":"autoSyncPolicy"},{"type":"text","text":" to "},{"type":"codeVoice","code":".manual"},{"type":"text","text":" and call "},{"type":"codeVoice","code":"container.sync()"},{"type":"text","text":" yourself for full control."}]},{"anchor":"Responding-to-Events","type":"heading","text":"Responding to Events","level":2},{"type":"codeListing","code":["\/\/ Called after remote changes are merged into the store","container.didSaveMergeChanges = { notification in","    print(\"Merged remote changes\")","}","","\/\/ Called if a sync fails","container.didEncounterError = { error in","    print(\"Sync error: \\(error)\")","}","","\/\/ Called if the ensemble is forced to detach","container.didForceDetach = { error in","    print(\"Forced detach: \\(error)\")","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer","isActive":true},{"type":"text","text":", the SwiftData container does not need to merge changes into a view context — persistent history tracking (enabled by default) causes "},{"type":"codeVoice","code":"@Query"},{"type":"text","text":" properties to update automatically. Use "},{"type":"codeVoice","code":"didSaveMergeChanges"},{"type":"text","text":" for additional processing such as refreshing non-SwiftData UI state."}]},{"anchor":"Computed-Identifiers-Core-Data","type":"heading","text":"Computed Identifiers (Core Data)","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"For compound or computed identifiers on "},{"type":"codeVoice","code":"NSManagedObject"},{"type":"text","text":" subclasses, override "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Syncable\/globalIdentifier(from:)","isActive":true},{"type":"text","text":" instead of "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Syncable\/globalIdentifierKey","isActive":true},{"type":"text","text":". The parameter is typed as "},{"type":"codeVoice","code":"Self"},{"type":"text","text":", so you get direct property access:"}]},{"type":"codeListing","code":["class Person: NSManagedObject, Syncable {","    @NSManaged var firstName: String","    @NSManaged var lastName: String","","    static func globalIdentifier(from person: Person) -> String {","        \"\\(person.firstName).\\(person.lastName)\"","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is called only when "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Syncable\/globalIdentifierKey","isActive":true},{"type":"text","text":" is empty (the default when you don’t override it)."}]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Syncable\/globalIdentifier(from:)"},{"type":"text","text":" only works with "},{"type":"codeVoice","code":"NSManagedObject"},{"type":"text","text":" subclasses."},{"type":"text","text":" "},{"type":"text","text":"For SwiftData "},{"type":"codeVoice","code":"@Model"},{"type":"text","text":" types, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Syncable\/globalIdentifierKey"},{"type":"text","text":"."}]}],"name":"Note"},{"anchor":"Conflict-Resolution","type":"heading","text":"Conflict Resolution","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Ensembles resolves concurrent changes automatically using attribute-level last-writer-wins (see "},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/ConflictResolution","isActive":true},{"type":"text","text":"). For most apps this works transparently — but because each attribute is resolved independently, a merge can combine values that are individually valid but together violate a business rule (e.g., "},{"type":"codeVoice","code":"startDate"},{"type":"text","text":" from one device and "},{"type":"codeVoice","code":"endDate"},{"type":"text","text":" from another, where start ends up after end)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"With Core Data, you can intercept and repair these cases using the reparation context delegate methods. SwiftData models don’t have "},{"type":"codeVoice","code":"NSManagedObject"},{"type":"text","text":" subclasses, so those delegate methods aren’t directly useful."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The best approach for SwiftData is to "},{"type":"strong","inlineContent":[{"text":"design your model so that attribute-level merging always produces valid results","type":"text"}]},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Avoid cross-attribute invariants","type":"text"}]},{"type":"text","text":" where possible. For example, store a "},{"code":"startDate","type":"codeVoice"},{"type":"text","text":" and a "},{"type":"codeVoice","code":"duration"},{"type":"text","text":" instead of "},{"type":"codeVoice","code":"startDate"},{"type":"text","text":" and "},{"type":"codeVoice","code":"endDate"},{"type":"text","text":" — either attribute can be updated independently without breaking validity."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Use computed properties","type":"text"}]},{"text":" for derived values instead of storing them. A stored ","type":"text"},{"type":"codeVoice","code":"total"},{"text":" that must equal ","type":"text"},{"type":"codeVoice","code":"quantity * price"},{"type":"text","text":" will break if "},{"type":"codeVoice","code":"quantity"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"price"},{"text":" are updated on different devices. Compute it instead.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Validate after sync","type":"text"}],"type":"strong"},{"text":" by observing ","type":"text"},{"code":"didSaveMergeChanges","type":"codeVoice"},{"text":" and checking invariants in your app logic. Fix invalid combinations by saving corrected values — those corrections propagate as new events.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need the full reparation context for complex conflict handling, access the underlying "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble"},{"text":" via ","type":"text"},{"code":".coreDataEnsemble","type":"codeVoice"},{"text":" and set its delegate directly. Note that this replaces the internal delegate bridge, so you’ll need to handle global identifiers and save notifications yourself:","type":"text"}]},{"type":"codeListing","code":["ensemble?.coreDataEnsemble.delegate = myCustomDelegate"],"syntax":"swift"},{"level":2,"anchor":"Using-SwiftDataEnsemble-Directly","text":"Using SwiftDataEnsemble Directly","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"If you manage your own ","type":"text"},{"type":"codeVoice","code":"ModelContainer"},{"text":" or need more control, use ","type":"text"},{"type":"codeVoice","code":"SwiftDataEnsemble"},{"text":" directly:","type":"text"}]},{"type":"codeListing","code":["import EnsemblesSwiftData","import EnsemblesCloudKit","","\/\/ Get the store URL from your existing ModelContainer","let modelContainer = try ModelContainer(for: Note.self)","let storeURL = modelContainer.configurations.first!.url","","let ensemble = SwiftDataEnsemble(","    ensembleIdentifier: \"MyNotes\",","    persistentStoreURL: storeURL,","    modelTypes: [Note.self],","    cloudFileSystem: CloudKitFileSystem(","        ubiquityContainerIdentifier: \"iCloud.com.example.mynotes\"","    )",")","","try await ensemble?.attachPersistentStore()","try await ensemble?.sync()"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Access the underlying "},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","type":"reference","isActive":true},{"text":" via the ","type":"text"},{"type":"codeVoice","code":".coreDataEnsemble"},{"text":" property for advanced operations:","type":"text"}]},{"type":"codeListing","code":["ensemble?.coreDataEnsemble.compatibilityMode = .ensembles2Compatible"],"syntax":"swift"},{"text":"Model Versioning with VersionedSchema","type":"heading","anchor":"Model-Versioning-with-VersionedSchema","level":2},{"type":"paragraph","inlineContent":[{"text":"When you first ship your app, pass your current ","type":"text"},{"type":"codeVoice","code":"@Model"},{"text":" types to ","type":"text"},{"type":"codeVoice","code":"modelTypes:"},{"text":" — this is all you need for a single model version.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When your model evolves (e.g., you add a property to ","type":"text"},{"type":"codeVoice","code":"Note"},{"text":"), you need to tell Ensembles about all versions so it can accept sync events recorded against any of them. Do this by switching from ","type":"text"},{"type":"codeVoice","code":"modelTypes:"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"migrationPlan:"},{"text":".","type":"text"}]},{"text":"1. Define Versioned Schemas","type":"heading","anchor":"1-Define-Versioned-Schemas","level":3},{"type":"paragraph","inlineContent":[{"text":"Move your model types into ","type":"text"},{"type":"codeVoice","code":"VersionedSchema"},{"text":" enums — one per version:","type":"text"}]},{"type":"codeListing","code":["enum MySchemaV1: VersionedSchema {","    static var versionIdentifier: Schema.Version = .init(1, 0, 0)","    static var models: [any PersistentModel.Type] { [Note.self] }","","    @Model class Note {","        var title: String","        var uniqueID: String","    }","}","","enum MySchemaV2: VersionedSchema {","    static var versionIdentifier: Schema.Version = .init(2, 0, 0)","    static var models: [any PersistentModel.Type] { [Note.self] }","","    @Model class Note {","        var title: String","        var body: String       \/\/ Added in V2","        var uniqueID: String","    }","}"],"syntax":"swift"},{"text":"2. Create a Migration Plan","type":"heading","anchor":"2-Create-a-Migration-Plan","level":3},{"type":"codeListing","code":["enum MyMigrationPlan: SchemaMigrationPlan {","    static var schemas: [any VersionedSchema.Type] {","        [MySchemaV1.self, MySchemaV2.self]","    }","    static var stages: [MigrationStage] {","        [migrateV1toV2]","    }","    static let migrateV1toV2 = MigrationStage.lightweight(","        fromVersion: MySchemaV1.self,","        toVersion: MySchemaV2.self","    )","}"],"syntax":"swift"},{"text":"3. Use `migrationPlan:` Instead of `modelTypes:`","type":"heading","anchor":"3-Use-migrationPlan-Instead-of-modelTypes","level":3},{"type":"codeListing","code":["let container = SwiftDataEnsembleContainer(","    name: \"MyNotes\",","    storeURL: storeURL,","    migrationPlan: MyMigrationPlan.self,","    cloudFileSystem: cloudFS",")!"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Ensembles converts each ","type":"text"},{"type":"codeVoice","code":"VersionedSchema"},{"text":" into a Core Data model and passes all of them to the underlying ","type":"text"},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","type":"reference","isActive":true},{"text":". This allows version compatibility checking during sync — events from a device still running V1 can be correctly merged on a device running V2, and vice versa.","type":"text"}]},{"text":"Persistent History Tracking","type":"heading","anchor":"Persistent-History-Tracking","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SwiftDataEnsembleContainer"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"SwiftDataEnsemble"},{"text":" enable persistent history tracking by default. This allows SwiftData to detect changes that Ensembles merges into the store, so your ","type":"text"},{"type":"codeVoice","code":"@Query"},{"text":" properties stay up to date automatically.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you provide custom ","type":"text"},{"type":"codeVoice","code":"persistentStoreOptions"},{"text":", make sure to include these keys:","type":"text"}]},{"type":"codeListing","code":["let options: [String: Any] = [","    NSPersistentHistoryTrackingKey: true as NSNumber,","    NSPersistentStoreRemoteChangeNotificationPostOptionKey: true as NSNumber,","]"],"syntax":"swift"}]}],"kind":"article","metadata":{"role":"article","platforms":[{"introducedAt":"17.0","beta":false,"name":"iOS"},{"introducedAt":"14.0","beta":false,"name":"macOS"},{"introducedAt":"17.0","beta":false,"name":"tvOS"},{"introducedAt":"10.0","beta":false,"name":"watchOS"}],"roleHeading":"Article","modules":[{"name":"Ensembles"}],"title":"SwiftData Integration"},"hierarchy":{"paths":[["doc:\/\/Ensembles\/documentation\/Ensembles"]]},"abstract":[{"type":"text","text":"Sync SwiftData models with Ensembles using "},{"type":"codeVoice","code":"SwiftDataEnsembleContainer"},{"type":"text","text":"."}],"identifier":{"url":"doc:\/\/Ensembles\/documentation\/Ensembles\/SwiftDataIntegration","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted","doc:\/\/Ensembles\/documentation\/Ensembles\/ConflictResolution"],"title":"Related Documentation"},{"generated":true,"anchor":"Essentials","identifiers":["doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate"],"title":"Essentials"}],"references":{"doc://Ensembles/documentation/Ensembles/CoreDataEnsembleDelegate":{"navigatorTitle":[{"text":"CoreDataEnsembleDelegate","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"Methods invoked by ","type":"text"},{"type":"reference","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","isActive":true},{"text":" to inform of sync-related changes.","type":"text"}],"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CoreDataEnsembleDelegate","kind":"identifier"}],"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleDelegate","type":"topic","title":"CoreDataEnsembleDelegate","url":"\/documentation\/ensembles\/coredataensembledelegate"},"doc://Ensembles/documentation/Ensembles":{"kind":"symbol","abstract":[{"text":"Sync Core Data and SwiftData stores across devices using event sourcing.","type":"text"}],"role":"collection","title":"Ensembles","type":"topic","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles","url":"\/documentation\/ensembles"},"doc://Ensembles/documentation/Ensembles/Syncable/globalIdentifierKey":{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Syncable\/globalIdentifierKey","abstract":[{"text":"The name of the property whose value uniquely identifies this object","type":"text"},{"text":" ","type":"text"},{"text":"across all devices.","type":"text"}],"kind":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"globalIdentifierKey","kind":"identifier"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"}],"title":"globalIdentifierKey","url":"\/documentation\/ensembles\/syncable\/globalidentifierkey","required":true,"role":"symbol","type":"topic","defaultImplementations":1},"doc://Ensembles/documentation/Ensembles/CoreDataEnsembleContainer":{"navigatorTitle":[{"text":"CoreDataEnsembleContainer","kind":"identifier"}],"kind":"symbol","abstract":[{"text":"A high-level container that sets up a ","type":"text"},{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","type":"reference","isActive":true},{"text":" with automatic syncing,","type":"text"},{"text":" ","type":"text"},{"text":"delegate management, and optional Core Data stack creation.","type":"text"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CoreDataEnsembleContainer","kind":"identifier"}],"title":"CoreDataEnsembleContainer","type":"topic","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsembleContainer","url":"\/documentation\/ensembles\/coredataensemblecontainer"},"doc://Ensembles/documentation/Ensembles/ConflictResolution":{"identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/ConflictResolution","abstract":[{"text":"Understand how Ensembles resolves conflicts and how to customize the process.","type":"text"}],"kind":"article","title":"Conflict Resolution","url":"\/documentation\/ensembles\/conflictresolution","role":"article","type":"topic"},"doc://Ensembles/documentation/Ensembles/CoreDataEnsemble":{"abstract":[{"text":"The central class of Ensembles, representing a set of synchronizing persistent stores.","type":"text"}],"navigatorTitle":[{"text":"CoreDataEnsemble","kind":"identifier"}],"kind":"symbol","title":"CoreDataEnsemble","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/CoreDataEnsemble","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CoreDataEnsemble","kind":"identifier"}],"role":"symbol","url":"\/documentation\/ensembles\/coredataensemble"},"doc://Ensembles/documentation/Ensembles/Syncable/globalIdentifier(from:)":{"defaultImplementations":1,"required":true,"kind":"symbol","abstract":[{"type":"text","text":"Returns a global identifier from the object instance."}],"role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"globalIdentifier","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"from"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"}],"title":"globalIdentifier(from:)","type":"topic","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/Syncable\/globalIdentifier(from:)","url":"\/documentation\/ensembles\/syncable\/globalidentifier(from:)"},"doc://Ensembles/documentation/Ensembles/GettingStarted":{"kind":"article","abstract":[{"text":"Set up Ensembles to sync a Core Data or SwiftData persistent store across devices.","type":"text"}],"role":"article","identifier":"doc:\/\/Ensembles\/documentation\/Ensembles\/GettingStarted","type":"topic","title":"Getting Started","url":"\/documentation\/ensembles\/gettingstarted"}}}