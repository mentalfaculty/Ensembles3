{"metadata":{"title":"EnsemblesCloudKit","externalID":"EnsemblesCloudKit","modules":[{"name":"EnsemblesCloudKit"}],"roleHeading":"Framework","role":"collection","symbolKind":"module"},"hierarchy":{"paths":[[]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"EnsemblesCloudKit provides ","type":"text"},{"isActive":true,"identifier":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystem","type":"reference"},{"text":", an implementation of the Ensembles ","type":"text"},{"code":"CloudFileSystem","type":"codeVoice"},{"text":" protocol that stores sync data in iCloud using CloudKit. It handles file upload, download, and directory management through CloudKit record operations.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"CloudKit is the recommended backend for most apps — it requires no server setup, no authentication UI, and syncs automatically across all of a user’s iCloud devices.","type":"text"}]},{"anchor":"Xcode-Setup","type":"heading","level":3,"text":"Xcode Setup"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Open your Xcode project and select the app target.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Go to ","type":"text"},{"inlineContent":[{"text":"Signing & Capabilities","type":"text"}],"type":"emphasis"},{"text":" and click ","type":"text"},{"inlineContent":[{"text":"+ Capability","type":"text"}],"type":"strong"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Add ","type":"text"},{"inlineContent":[{"text":"iCloud","type":"text"}],"type":"strong"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Check ","type":"text"},{"inlineContent":[{"text":"CloudKit","type":"text"}],"type":"strong"},{"text":" under iCloud services.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Create or select a CloudKit container (e.g., ","type":"text"},{"code":"iCloud.com.yourcompany.yourapp","type":"codeVoice"},{"text":"). The container identifier must be unique across all apps.","type":"text"}]}]}]},{"anchor":"Quick-Start","type":"heading","level":3,"text":"Quick Start"},{"syntax":"swift","type":"codeListing","code":["import Ensembles","import EnsemblesCloudKit","","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")","try await ensemble?.attachPersistentStore()","try await ensemble?.sync()"]},{"type":"paragraph","inlineContent":[{"text":"Or use the container for a simpler setup:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let container = CoreDataEnsembleContainer(","    name: \"MainStore\",","    storeURL: storeURL,","    modelURL: modelURL,","    cloudFileSystem: CloudKitFileSystem(","        ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"","    )",")"]},{"anchor":"Database-Scope","type":"heading","level":3,"text":"Database Scope"},{"type":"paragraph","inlineContent":[{"text":"CloudKit offers three database scopes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Private database","type":"text"}],"type":"strong"},{"text":" (default) — Syncs across the current user’s own iCloud devices. Data is only accessible to the signed-in iCloud account. This is the recommended scope for most apps.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Public database","type":"text"}],"type":"strong"},{"text":" — Data is accessible to all users of the app, even without iCloud sign-in. Uses different quota limits (per-app rather than per-user). Useful for shared reference data.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Shared database","type":"text"}],"type":"strong"},{"text":" — Used with ","type":"text"},{"code":"CKShare","type":"codeVoice"},{"text":" for sharing specific data between users.","type":"text"}]}]}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Private database (default)","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","","\/\/ Public database","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\",","    rootDirectory: \"SharedData\",","    usePublicDatabase: true,","    schemaVersion: .v2",")"]},{"anchor":"Schema-Versions","type":"heading","level":3,"text":"Schema Versions"},{"type":"paragraph","inlineContent":[{"text":"CloudKit uses record types to store sync data. Two schema versions are available:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":".v1","type":"codeVoice"}],"type":"strong"},{"text":" — The original schema with three record types: ","type":"text"},{"code":"CDEFileSystemNode","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CDEItem","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"CDEDataFile","type":"codeVoice"},{"text":". Compatible with Ensembles 2 CloudKit data.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":".v2","type":"codeVoice"}],"type":"strong"},{"text":" — A simplified schema that removes the ","type":"text"},{"code":"CDEDataFile","type":"codeVoice"},{"text":" record type. Slightly more efficient but not readable by E2 peers using CloudKit.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The default is ","type":"text"},{"code":".v1","type":"codeVoice"},{"text":" for backward compatibility. Use ","type":"text"},{"code":".v2","type":"codeVoice"},{"text":" for new apps that don’t need E2 compatibility.","type":"text"}]},{"anchor":"Publishing-Schema-to-Production","type":"heading","level":3,"text":"Publishing Schema to Production"},{"content":[{"inlineContent":[{"text":"You ","type":"text"},{"type":"strong","inlineContent":[{"text":"must","type":"text"}]},{"text":" deploy the CloudKit schema to production before submitting your app to the App Store. Without this step, the app will fail to sync for end users.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"type":"paragraph","inlineContent":[{"text":"In the ","type":"text"},{"inlineContent":[{"text":"development environment","type":"text"}],"type":"strong"},{"text":", CloudKit creates record types automatically on first use. Before submitting to the App Store:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Run your app at least once in the development environment so that CloudKit creates the necessary record types.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Open ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/icloud.developer.apple.com\/dashboard\/"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Select your container.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Go to ","type":"text"},{"inlineContent":[{"text":"Schema → Deploy to Production","type":"text"}],"type":"emphasis"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Review and deploy.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The production schema cannot be modified once deployed (only extended with new fields), so test thoroughly in development first.","type":"text"}]},{"anchor":"Sharing-with-CKShare","type":"heading","level":3,"text":"Sharing with CKShare"},{"type":"paragraph","inlineContent":[{"text":"For apps that share data between users via ","type":"text"},{"code":"CKShare","type":"codeVoice"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\",","    sharingIdentifier: \"com.yourcompany.yourapp.shared\",","    shareOwnerName: ownerRecordName",")"]},{"type":"paragraph","inlineContent":[{"text":"Implement ","type":"text"},{"isActive":true,"identifier":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystemDelegate","type":"reference"},{"text":" to handle share setup and participant management.","type":"text"}]},{"anchor":"Data-Security","type":"heading","level":3,"text":"Data Security"},{"type":"paragraph","inlineContent":[{"text":"Ensembles stores all sync data as ","type":"text"},{"code":"CKAsset","type":"codeVoice"},{"text":" binary files attached to CloudKit records — not as structured record fields. The contents are opaque serialized event logs that are not human-readable, even without encryption.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"CloudKit encrypts all data at rest on Apple’s servers. With ","type":"text"},{"isActive":true,"identifier":"https:\/\/support.apple.com\/en-us\/102651","type":"reference"},{"text":" (ADP) enabled, ","type":"text"},{"code":"CKAsset","type":"codeVoice"},{"text":" data is end-to-end encrypted — Apple cannot read it. Without ADP, Apple manages the encryption keys and could theoretically access the data.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For apps that need end-to-end encryption regardless of the user’s ADP setting, wrap the CloudKit backend with ","type":"text"},{"code":"EnsemblesEncrypted","type":"codeVoice"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["import EnsemblesEncrypted","","let encryptedFS = EncryptedCloudFileSystem(","    cloudFileSystem: CloudKitFileSystem(","        ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"","    ),","    password: \"user-supplied-password\"",")"]},{"type":"paragraph","inlineContent":[{"text":"This encrypts data with AES-256-GCM before it ever reaches CloudKit, so security does not depend on Apple’s infrastructure.","type":"text"}]},{"anchor":"Custom-Zones","type":"heading","level":3,"text":"Custom Zones"},{"type":"paragraph","inlineContent":[{"text":"By default, ","type":"text"},{"code":"CloudKitFileSystem","type":"codeVoice"},{"text":" creates a custom record zone in the private database for efficient change tracking via ","type":"text"},{"code":"CKServerChangeToken","type":"codeVoice"},{"text":". The zone is created automatically on first connection.","type":"text"}]},{"text":"Delegate","level":3,"anchor":"Delegate","type":"heading"},{"inlineContent":[{"text":"Implement ","type":"text"},{"identifier":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystemDelegate","isActive":true,"type":"reference"},{"text":" to customize CloudKit behavior, handle errors, and manage sharing:","type":"text"}],"type":"paragraph"},{"code":["cloudFS.delegate = self"],"syntax":"swift","type":"codeListing"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit"},"topicSections":[{"title":"Cloud File System","identifiers":["doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystem","doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystemDelegate"],"anchor":"Cloud-File-System"},{"title":"Enumerations","anchor":"Enumerations","identifiers":["doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitSchemaVersion","doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/DatabaseScope"],"generated":true}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/ensemblescloudkit"],"traits":[{"interf