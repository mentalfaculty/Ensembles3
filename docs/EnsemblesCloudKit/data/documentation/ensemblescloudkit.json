{"sections":[],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"EnsemblesCloudKit provides ","type":"text"},{"isActive":true,"identifier":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystem","type":"reference"},{"text":", an implementation of the Ensembles ","type":"text"},{"type":"codeVoice","code":"CloudFileSystem"},{"text":" protocol that stores sync data in iCloud using CloudKit. It handles file upload, download, and directory management through CloudKit record operations.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"CloudKit is the recommended backend for most apps — it requires no server setup, no authentication UI, and syncs automatically across all of a user’s iCloud devices.","type":"text"}]},{"text":"Xcode Setup","type":"heading","level":3,"anchor":"Xcode-Setup"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Open your Xcode project and select the app target."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Go to "},{"inlineContent":[{"type":"text","text":"Signing & Capabilities"}],"type":"emphasis"},{"type":"text","text":" and click "},{"inlineContent":[{"type":"text","text":"+ Capability"}],"type":"strong"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Add "},{"inlineContent":[{"type":"text","text":"iCloud"}],"type":"strong"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Check "},{"inlineContent":[{"type":"text","text":"CloudKit"}],"type":"strong"},{"type":"text","text":" under iCloud services."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Create or select a CloudKit container (e.g., "},{"code":"iCloud.com.yourcompany.yourapp","type":"codeVoice"},{"type":"text","text":"). The container identifier must be unique across all apps."}],"type":"paragraph"}]}]},{"text":"Quick Start","type":"heading","level":3,"anchor":"Quick-Start"},{"type":"codeListing","code":["import Ensembles","import EnsemblesCloudKit","","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")","try await ensemble?.attachPersistentStore()","try await ensemble?.sync()"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Or use the container for a simpler setup:","type":"text"}]},{"type":"codeListing","code":["let container = CoreDataEnsembleContainer(","    name: \"MainStore\",","    storeURL: storeURL,","    modelURL: modelURL,","    cloudFileSystem: CloudKitFileSystem(","        ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"","    )",")"],"syntax":"swift"},{"text":"Database Scope","type":"heading","level":3,"anchor":"Database-Scope"},{"type":"paragraph","inlineContent":[{"text":"CloudKit offers three database scopes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Private database"}],"type":"strong"},{"type":"text","text":" (default) — Syncs across the current user’s own iCloud devices. Data is only accessible to the signed-in iCloud account. This is the recommended scope for most apps."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Public database","type":"text"}],"type":"strong"},{"text":" — Data is accessible to all users of the app, even without iCloud sign-in. Uses different quota limits (per-app rather than per-user). Useful for shared reference data.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Shared database","type":"text"}],"type":"strong"},{"text":" — Used with ","type":"text"},{"type":"codeVoice","code":"CKShare"},{"text":" for sharing specific data between users.","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Private database (default)","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","","\/\/ Public database","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\",","    rootDirectory: \"SharedData\",","    usePublicDatabase: true,","    schemaVersion: .v2",")"]},{"text":"Schema Versions","level":3,"anchor":"Schema-Versions","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"CloudKit uses record types to store sync data. Two schema versions are available:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":".v1"}],"type":"strong"},{"type":"text","text":" — The original schema with three record types: "},{"code":"CDEFileSystemNode","type":"codeVoice"},{"type":"text","text":", "},{"code":"CDEItem","type":"codeVoice"},{"type":"text","text":", and "},{"code":"CDEDataFile","type":"codeVoice"},{"type":"text","text":". Compatible with Ensembles 2 CloudKit data."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"codeVoice","code":".v2"}],"type":"strong"},{"text":" — A simplified schema that removes the ","type":"text"},{"code":"CDEDataFile","type":"codeVoice"},{"text":" record type. Slightly more efficient but not readable by E2 peers using CloudKit.","type":"text"}]}]}]},{"inlineContent":[{"text":"The default is ","type":"text"},{"type":"codeVoice","code":".v1"},{"text":" for backward compatibility. Use ","type":"text"},{"type":"codeVoice","code":".v2"},{"text":" for new apps that don’t need E2 compatibility.","type":"text"}],"type":"paragraph"},{"anchor":"Publishing-Schema-to-Production","level":3,"type":"heading","text":"Publishing Schema to Production"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the "},{"type":"strong","inlineContent":[{"type":"text","text":"development environment"}]},{"type":"text","text":", CloudKit creates record types automatically on first use. Before submitting to the App Store:"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Open "},{"type":"reference","identifier":"https:\/\/icloud.developer.apple.com\/dashboard\/","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Select your container.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Go to ","type":"text"},{"inlineContent":[{"text":"Schema → Deploy to Production","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Review and deploy."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"The production schema cannot be modified once deployed (only extended with new fields), so test thoroughly in development first."}],"type":"paragraph"},{"text":"Sharing with CKShare","anchor":"Sharing-with-CKShare","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"For apps that share data between users via "},{"type":"codeVoice","code":"CKShare"},{"type":"text","text":":"}]},{"syntax":"swift","code":["let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\",","    sharingIdentifier: \"com.yourcompany.yourapp.shared\",","    shareOwnerName: ownerRecordName",")"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement "},{"identifier":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystemDelegate","isActive":true,"type":"reference"},{"type":"text","text":" to handle share setup and participant management."}]},{"level":3,"type":"heading",