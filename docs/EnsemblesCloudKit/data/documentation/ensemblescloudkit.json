{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"EnsemblesCloudKit provides "},{"identifier":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystem","isActive":true,"type":"reference"},{"text":", an implementation of the Ensembles ","type":"text"},{"type":"codeVoice","code":"CloudFileSystem"},{"text":" protocol that stores sync data in iCloud using CloudKit. It handles file upload, download, and directory management through CloudKit record operations.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"CloudKit is the recommended backend for most apps — it requires no server setup, no authentication UI, and syncs automatically across all of a user’s iCloud devices.","type":"text"}],"type":"paragraph"},{"level":3,"type":"heading","text":"Xcode Setup","anchor":"Xcode-Setup"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Open your Xcode project and select the app target.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Go to ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Signing & Capabilities","type":"text"}]},{"text":" and click ","type":"text"},{"type":"strong","inlineContent":[{"text":"+ Capability","type":"text"}]},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Add ","type":"text"},{"type":"strong","inlineContent":[{"text":"iCloud","type":"text"}]},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Check ","type":"text"},{"type":"strong","inlineContent":[{"text":"CloudKit","type":"text"}]},{"text":" under iCloud services.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Create or select a CloudKit container (e.g., ","type":"text"},{"type":"codeVoice","code":"iCloud.com.yourcompany.yourapp"},{"text":"). The container identifier must be unique across all apps.","type":"text"}]}]}]},{"level":3,"type":"heading","text":"Quick Start","anchor":"Quick-Start"},{"type":"codeListing","syntax":"swift","code":["import Ensembles","import EnsemblesCloudKit","","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")","try await ensemble?.attachPersistentStore()","try await ensemble?.sync()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or use the container for a simpler setup:"}]},{"type":"codeListing","syntax":"swift","code":["let container = CoreDataEnsembleContainer(","    name: \"MainStore\",","    storeURL: storeURL,","    modelURL: modelURL,","    cloudFileSystem: CloudKitFileSystem(","        ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"","    )",")"]},{"level":3,"text":"Database Scope","type":"heading","anchor":"Database-Scope"},{"type":"paragraph","inlineContent":[{"type":"text","text":"CloudKit offers three database scopes:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Private database","type":"text"}]},{"text":" (default) — Syncs across the current user’s own iCloud devices. Data is only accessible to the signed-in iCloud account. This is the recommended scope for most apps.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Public database","type":"text"}]},{"text":" — Data is accessible to all users of the app, even without iCloud sign-in. Uses different quota limits (per-app rather than per-user). Useful for shared reference data.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Shared database","type":"text"}]},{"type":"text","text":" — Used with "},{"type":"codeVoice","code":"CKShare"},{"type":"text","text":" for sharing specific data between users."}]}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Private database (default)","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","","\/\/ Public database","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\",","    rootDirectory: \"SharedData\",","    usePublicDatabase: true,","    schemaVersion: .v2",")"]},{"level":3,"type":"heading","text":"Schema Versions","anchor":"Schema-Versions"},{"inlineContent":[{"type":"text","text":"CloudKit uses record types to store sync data. Two schema versions are available:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":".v1","type":"codeVoice"}],"type":"strong"},{"text":" — The original schema with three record types: ","type":"text"},{"type":"codeVoice","code":"CDEFileSystemNode"},{"text":", ","type":"text"},{"code":"CDEItem","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"CDEDataFile","type":"codeVoice"},{"type":"text","text":". Compatible with Ensembles 2 CloudKit data."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":".v2","type":"codeVoice"}],"type":"strong"},{"type":"text","text":" — A simplified schema that removes the "},{"type":"codeVoice","code":"CDEDataFile"},{"type":"text","text":" record type. Slightly more efficient but not readable by E2 peers using CloudKit."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The default is ","type":"text"},{"type":"codeVoice","code":".v1"},{"text":" for backward compatibility. Use ","type":"text"},{"type":"codeVoice","code":".v2"},{"text":" for new apps that don’t need E2 compatibility.","type":"text"}]},{"level":3,"text":"Publishing Schema to Production","type":"heading","anchor":"Publishing-Schema-to-Production"},{"style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You "},{"inlineContent":[{"text":"must","type":"text"}],"type":"strong"},{"type":"text","text":" deploy the CloudKit schema to production before submitting your app to the App Store. Without this step, the app will fail to sync for end users."}]}],"name":"Important"},{"type":"paragraph","inlineContent":[{"text":"In the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"development environment"}]},{"text":", CloudKit creates record types automatically on first use. Before submitting to the App Store:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Run your app at least once in the development environment so that CloudKit creates the necessary record types.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Open ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/icloud.developer.apple.com\/dashboard\/"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Select your container.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Go to ","type":"text"},{"inlineContent":[{"text":"Schema → Deploy to Production","type":"text"}],"type":"emphasis"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Review and deploy.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"The production schema cannot be modified once deployed (only extended with new fields), so test thoroughly in development first.","type":"text"}]},{"text":"Sharing with CKShare","anchor":"Sharing-with-CKShare","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"For apps that share data between users via ","type":"text"},{"type":"codeVoice","code":"CKShare"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\",","    sharingIdentifier: \"com.yourcompany.yourapp.shared\",","    shareOwnerName: ownerRecordName",")"]},{"type":"paragraph","inlineContent":[{"text":"Implement ","type":"text"},{"isActive":true,"identifier":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystemDelegate","type":"reference"},{"text":" to handle share setup and participant management.","type":"text"}]},{"level":3,"text":"Data Security","type":"heading","anchor":"Data-Security"},{"type":"paragraph","inlineContent":[{"text":"Ensembles stores all sync data as ","type":"text"},{"type":"codeVoice","code":"CKAsset"},{"text":" binary files attached to CloudKit records — not as structured record fields. The contents are opaque serialized event logs that are not human-readable, even without encryption.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"CloudKit encrypts all data at rest on Apple’s servers. With ","type":"text"},{"identifier":"https:\/\/support.apple.com\/en-us\/102651","isActive":true,"type":"reference"},{"text":" (ADP) enabled, ","type":"text"},{"type":"codeVoice","code":"CKAsset"},{"text":" data is end-to-end encrypted — Apple cannot read it. Without ADP, Apple manages the encryption keys and could theoretically access the data.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For apps that need end-to-end encryption regardless of the user’s ADP setting, wrap the CloudKit backend with ","type":"text"},{"type":"codeVoice","code":"EnsemblesEncrypted"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import EnsemblesEncrypted","","let encryptedFS = EncryptedCloudFileSystem(","    cloudFileSystem: CloudKitFileSystem(","        ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"","    ),","    password: \"user-supplied-password\"",")"]},{"type":"paragraph","inlineContent":[{"text":"This encrypts data with AES-256-GCM before it ever reaches CloudKit, so security does not depend on Apple’s infrastructure.","type":"text"}]},{"text":"Custom Zones","anchor":"Custom-Zones","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"By default, ","type":"text"},{"type":"codeVoice","code":"CloudKitFileSystem"},{"text":" creates a custom record zone in the private database for efficient change tracking via ","type":"text"},{"type":"codeVoice","code":"CKServerChangeToken"},{"text":". The zone is created automatically on first connection.","type":"text"}]},{"text":"Delegate","anchor":"Delegate","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"Implement ","type":"text"},{"isActive":true,"identifier":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystemDelegate","type":"reference"},{"text":" to customize CloudKit behavior, handle errors, and manage sharing:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["cloudFS.delegate = self"]}]}],"identifier":{"url":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/ensemblescloudkit"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"topicSections":[{"title":"Cloud File System","anchor":"Cloud-File-System","identifiers":["doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystem","doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystemDelegate"]},{"title":"Enumerations","identifiers":["doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitSchemaVersion","doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/DatabaseScope"],"anchor":"Enumerations","generated":true}],"sections":[],"metadata":{"title":"EnsemblesCloudKit","modules":[{"name":"EnsemblesCloudKit"}],"role":"collection","roleHeading":"Framework","symbolKind":"module","externalID":"Ensemble