udKit"}],"type":"strong"},{"type":"text","text":" under iCloud services."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Create or select a CloudKit container (e.g., ","type":"text"},{"code":"iCloud.com.yourcompany.yourapp","type":"codeVoice"},{"text":"). The container identifier must be unique across all apps.","type":"text"}]}]}]},{"anchor":"Quick-Start","type":"heading","text":"Quick Start","level":3},{"type":"codeListing","syntax":"swift","code":["import Ensembles","import EnsemblesCloudKit","","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")","try await ensemble?.attachPersistentStore()","try await ensemble?.sync()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or use the container for a simpler setup:"}]},{"type":"codeListing","syntax":"swift","code":["let container = CoreDataEnsembleContainer(","    name: \"MainStore\",","    storeURL: storeURL,","    modelURL: modelURL,","    cloudFileSystem: CloudKitFileSystem(","        ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"","    )",")"]},{"anchor":"Database-Scope","type":"heading","text":"Database Scope","level":3},{"type":"paragraph","inlineContent":[{"text":"CloudKit offers three database scopes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Private database"}]},{"type":"text","text":" (default) — Syncs across the current user’s own iCloud devices. Data is only accessible to the signed-in iCloud account. This is the recommended scope for most apps."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Public database","type":"text"}]},{"text":" — Data is accessible to all users of the app, even without iCloud sign-in. Uses different quota limits (per-app rather than per-user). Useful for shared reference data.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Shared database"}]},{"type":"text","text":" — Used with "},{"code":"CKShare","type":"codeVoice"},{"type":"text","text":" for sharing specific data between users."}],"type":"paragraph"}]}]},{"code":["\/\/ Private database (default)","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","","\/\/ Public database","let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\",","    rootDirectory: \"SharedData\",","    usePublicDatabase: true,","    schemaVersion: .v2",")"],"type":"codeListing","syntax":"swift"},{"type":"heading","level":3,"text":"Schema Versions","anchor":"Schema-Versions"},{"type":"paragraph","inlineContent":[{"text":"CloudKit uses record types to store sync data. Two schema versions are available:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":".v1","type":"codeVoice"}]},{"text":" — The original schema with three record types: ","type":"text"},{"code":"CDEFileSystemNode","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CDEItem","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"CDEDataFile","type":"codeVoice"},{"text":". Compatible with Ensembles 2 CloudKit data.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":".v2","type":"codeVoice"}]},{"text":" — A simplified schema that removes the ","type":"text"},{"code":"CDEDataFile","type":"codeVoice"},{"text":" record type. Slightly more efficient but not readable by E2 peers using CloudKit.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"The default is ","type":"text"},{"code":".v1","type":"codeVoice"},{"text":" for backward compatibility. Use ","type":"text"},{"code":".v2","type":"codeVoice"},{"text":" for new apps that don’t need E2 compatibility.","type":"text"}]},{"type":"heading","level":3,"text":"Publishing Schema to Production","anchor":"Publishing-Schema-to-Production"},{"content":[{"type":"paragraph","inlineContent":[{"text":"You ","type":"text"},{"inlineContent":[{"text":"must","type":"text"}],"type":"strong"},{"text":" deploy the CloudKit schema to production before submitting your app to the App Store. Without this step, the app will fail to sync for end users.","type":"text"}]}],"type":"aside","name":"Important","style":"important"},{"type":"paragraph","inlineContent":[{"text":"In the ","type":"text"},{"type":"strong","inlineContent":[{"text":"development environment","type":"text"}]},{"text":", CloudKit creates record types automatically on first use. Before submitting to the App Store:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Run your app at least once in the development environment so that CloudKit creates the necessary record types.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Open ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/icloud.developer.apple.com\/dashboard\/"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Select your container.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Go to ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Schema → Deploy to Production","type":"text"}]},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Review and deploy.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"The production schema cannot be modified once deployed (only extended with new fields), so test thoroughly in development first.","type":"text"}]},{"type":"heading","level":3,"text":"Sharing with CKShare","anchor":"Sharing-with-CKShare"},{"type":"paragraph","inlineContent":[{"text":"For apps that share data between users via ","type":"text"},{"code":"CKShare","type":"codeVoice"},{"text":":","type":"text"}]},{"code":["let cloudFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\",","    sharingIdentifier: \"com.yourcompany.yourapp.shared\",","    shareOwnerName: ownerRecordName",")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Implement ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/EnsemblesCloudKit\/documentation\/EnsemblesCloudKit\/CloudKitFileSystemDelegate"},{"text":" to handle share setup and participant management.","type":"text"}]},{"type":"heading","level":3,"text":"Data Security","anchor":"Data-Security"},{"type":"paragraph","inlineContent":[{"text":"Ensembles stores all sync data as ","type":"text"},{"code":"CKAsset","type":"codeVoice"},{"text":" binary files attached to CloudKit records — not as structured record fields. The contents are opaque serialized event logs that are not human-readable, even without encryption.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"CloudKit encrypts all data at rest on Apple’s servers. With ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/support.apple.com\/en-us\/102651"},{"text":" (ADP) enabled, ","type":"text"},{"code":"CKAsset","type":"codeVoice"},{"text":" data is end-to-end encrypted — Apple cannot read it. Without ADP, Apple manages the encryption keys and could theoretically access the data.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For apps that need end-to-end encryption regardless of the user’s ADP setting, wrap the CloudKit backend with ","type":"text"},{"code":"EnsemblesEncrypted","type":"codeVoice"},{"text":":","type":"text"}]},{"code":["import EnsemblesEncrypted","","let encrypt