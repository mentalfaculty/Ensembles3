{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OneDriveCloudFileSystem","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"This backend communicates directly with Microsoft’s Graph API — no third-party SDK"},{"type":"text","text":" "},{"type":"text","text":"is required. Authentication is handled via an OAuth 2.0 access token passed as"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"Bearer"},{"text":" header on every request.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Microsoft Graph supports native path-based addressing using the colon syntax:"},{"type":"text","text":" "},{"type":"codeVoice","code":"\/me\/drive\/root:\/path\/to\/item:"},{"type":"text","text":". This means Ensembles paths map directly to"},{"text":" ","type":"text"},{"text":"OneDrive paths without any ID resolution or caching — similar to the pCloud backend.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Two initialization paths are available:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Simple: static access token (app manages refresh externally)","let cloudFS = OneDriveCloudFileSystem(accessToken: \"your-token\")","","\/\/ Authenticator: auto-refreshes expired tokens","let cloudFS = OneDriveCloudFileSystem(authenticator: authenticator)"]},{"level":2,"text":"Setup","type":"heading","anchor":"Setup"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Register an app in the "},{"type":"reference","isActive":true,"identifier":"https:\/\/portal.azure.com\/"},{"type":"text","text":" under"},{"type":"text","text":" "},{"type":"emphasis","inlineContent":[{"text":"Azure Active Directory → App registrations → New registration","type":"text"}]}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Under "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Authentication"}]},{"type":"text","text":", add a platform: "},{"type":"strong","inlineContent":[{"type":"text","text":"Mobile and desktop applications"}]}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the redirect URI (e.g. "},{"type":"codeVoice","code":"msauth.com.yourapp:\/\/auth"},{"type":"text","text":")"}]}]}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Note the "},{"type":"strong","inlineContent":[{"type":"text","text":"Application (client) ID"}]},{"type":"text","text":" from the overview page"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Configure the authenticator and file system:"}]}]}]},{"type":"codeListing","syntax":"swift","code":["let config = OneDriveAuthenticator.Configuration(","    clientID: \"your-app-client-id\",","    redirectURI: \"msauth.com.yourapp:\/\/auth\"",")","let authenticator = OneDriveAuthenticator(configuration: config)","try await authenticator.authorize(presenting: window)","","let cloudFS = OneDriveCloudFileSystem(authenticator: authenticator)","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MyStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The authenticator stores tokens in the Keychain and refreshes them automatically."},{"type":"text","text":" "},{"type":"text","text":"The default scopes are "},{"type":"codeVoice","code":"Files.ReadWrite"},{"type":"text","text":" and "},{"type":"codeVoice","code":"offline_access"},{"type":"text","text":" (required for refresh"},{"type":"text","text":" "},{"type":"text","text":"tokens). The default tenant is "},{"type":"codeVoice","code":"common"},{"type":"text","text":" (supports both personal and work accounts)."}]},{"type":"heading","text":"Threading","anchor":"Threading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This class is "},{"type":"codeVoice","code":"@unchecked Sendable"},{"type":"text","text":". All network calls go through a shared"},{"type":"text","text":" "},{"type":"codeVoice","code":"URLSession"},{"type":"text","text":" instance, which is thread-safe. Mutable state ("},{"type":"codeVoice","code":"loggedIn"},{"type":"text","text":" flag)"},{"type":"text","text":" "},{"type":"text","text":"is accessed only from async methods that are serialized by the ensemble’s operation queue."}]}]}],"seeAlsoSections":[{"anchor":"Cloud-File-System","title":"Cloud File System","identifiers":["doc:\/\/EnsemblesOneDrive\/documentation\/EnsemblesOneDrive\/OneDriveAuthenticator"],"generated":true}],"kind":"symbol","relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/EnsemblesOneDrive\/9Ensembles15CloudFileSystemP","doc:\/\/EnsemblesOneDrive\/s8SendableP","doc:\/\/EnsemblesOneDrive\/s16SendableMetatypeP"],"type":"conformsTo"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"metadata":{"roleHeading":"Class","role":"symbol","symbolKind":"class","title":"OneDriveCloudFileSystem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"OneDriveCloudFileSystem","kind":"identifier"}],"externalID":"s:17EnsemblesOneDrive0bC15CloudFileSystemC","modules":[{"name":"EnsemblesOneDrive"}],"navigatorTitle":[{"text":"OneDriveCloudFileSystem","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/EnsemblesOneDrive\/documentation\/EnsemblesOneDrive"]]},"abstract":[{"type":"text","text":"A cloud file system backed by the Microsoft Graph REST API v1.0 using "},{"code":"URLSession","type":"codeVoice"},{"text":".","type":"text"}],"top