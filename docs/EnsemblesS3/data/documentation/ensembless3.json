{"hierarchy":{"paths":[[]]},"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"EnsemblesS3 provides ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem"},{"text":", an implementation of the Ensembles ","type":"text"},{"type":"codeVoice","code":"CloudFileSystem"},{"text":" protocol that stores sync data in an Amazon S3 bucket. It uses the official ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/awslabs\/aws-sdk-swift"},{"text":" for all API operations.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"S3 is a natural fit for Ensembles — it’s highly durable, globally available, and cost-effective for the small files that Ensembles exchanges. S3-compatible services (MinIO, DigitalOcean Spaces, Backblaze B2, Cloudflare R2) can also be used by configuring the ","type":"text"},{"type":"codeVoice","code":"S3Client"},{"text":" with a custom endpoint.","type":"text"}],"type":"paragraph"},{"text":"S3 as a File System","anchor":"S3-as-a-File-System","type":"heading","level":3},{"inlineContent":[{"text":"S3 is a flat key-value store, not a hierarchical file system. ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem"},{"text":" simulates directory semantics using key prefixes and ","type":"text"},{"type":"codeVoice","code":"\/"},{"text":" delimiters — the standard S3 convention. For example, the Ensembles path ","type":"text"},{"type":"codeVoice","code":"ensembleId\/events\/data.json"},{"text":" maps to the S3 key ","type":"text"},{"type":"codeVoice","code":"prefix\/ensembleId\/events\/data.json"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Directory creation writes a zero-byte marker object with a trailing ","type":"text"},{"type":"codeVoice","code":"\/"},{"text":" in the key. Directory listing uses ","type":"text"},{"type":"codeVoice","code":"ListObjectsV2"},{"text":" with a delimiter to discover “subdirectories” via common prefixes.","type":"text"}],"type":"paragraph"},{"text":"Authentication","anchor":"Authentication","type":"heading","level":3},{"inlineContent":[{"text":"The AWS SDK for Swift supports multiple credential sources (environment variables, IAM roles, SSO, credential files). Your app creates and configures an ","type":"text"},{"type":"codeVoice","code":"S3Client"},{"text":", then injects it:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import EnsemblesS3","import AWSS3","","let s3Client = try await S3Client()  \/\/ Uses default credential chain","let cloudFileSystem = S3CloudFileSystem(","    client: s3Client,","    bucketName: \"my-ensembles-bucket\",","    keyPrefix: \"sync\/\"  \/\/ Optional: isolate Ensembles data under a prefix",")"],"type":"codeListing"},{"text":"Setup","anchor":"Setup","type":"heading","level":3},{"syntax":"swift","code":["let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: S3CloudFileSystem(","        client: s3Client,","        bucketName: \"my-bucket\",","        keyPrefix: \"ensembles\/\"","    )",")","try await ensemble?.attachPersistentStore()"],"type":"codeListing"},{"text":"Key Prefix","anchor":"Key-Prefix","type":"heading","level":3},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/keyPrefix"},{"text":" parameter isolates Ensembles data within a shared bucket. For example, with ","type":"text"},{"type":"codeVoice","code":"keyPrefix: \"ensembles\/\""},{"text":", the path ","type":"text"},{"type":"codeVoice","code":"\/MyStore\/events\/abc.json"},{"text":" maps to the S3 key ","type":"text"},{"type":"codeVoice","code":"ensembles\/MyStore\/events\/abc.json"},{"text":". A trailing ","type":"text"},{"type":"codeVoice","code":"\/"},{"text":" is added automatically if omitted.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"keyPrefix"},{"text":" is empty (the default), Ensembles data is stored at the bucket root.","type":"text"}],"type":"paragraph"},{"text":"S3-Compatible Services","anchor":"S3-Compatible-Services","type":"heading","level":3},{"inlineContent":[{"text":"To use an S3-compatible service, configure the ","type":"text"},{"type":"codeVoice","code":"S3Client"},{"text":" with a custom endpoint:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let config = try await S3Client.S3ClientConfiguration()","config.endpoint = \"https:\/\/s3.us-east-1.amazonaws.com\"  \/\/ or MinIO, R2, etc.","let s3Client = S3Client(config: config)"],"type":"codeListing"},{"text":"Error Handling","anchor":"Error-Handling","type":"heading","level":3},{"inlineContent":[{"text":"AWS SDK errors are mapped to ","type":"text"},{"type":"codeVoice","code":"EnsembleError"},{"text":" cases:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"AccessDenied"},{"type":"text","text":", "},{"type":"codeVoice","code":"InvalidAccessKeyId"},{"type":"text","text":", and "},{"type":"codeVoice","code":"SignatureDoesNotMatch"},{"type":"text","text":" map to "},{"type":"codeVoice","code":"EnsembleError\/authenticationFailure"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NoSuchKey"},{"type":"text","text":", "},{"type":"codeVoice","code":"NoSuchBucket"},{"type":"text","text":", and "},{"type":"codeVoice","code":"NotFound"},{"type":"text","text":" map to "},{"type":"codeVoice","code":"EnsembleError\/fileAccessFailed"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"All other errors map to "},{"type":"codeVoice","code":"EnsembleError\/serverError"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"type":"heading","text":"Dependencies","anchor":"Dependencies","level":3},{"inlineContent":[{"type":"text","text":"This module depends on the "},{"isActive":true,"identifier":"https:\/\/github.com\/awslabs\/aws-sdk-swift","overridingTitleInlineContent":[{"type":"text","text":"AWS SDK for Swift"}],"type":"reference","overridingTitle":"AWS SDK for Swift"},{"type":"text","text":" ("},{"code":"AWSS3","type":"codeVoice"},{"type":"text","text":" module)."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"metadata":{"roleHeading":"Framework","modules":[{"name":"EnsemblesS3"}],"symbolKind":"module","role":"collection","externalID":"EnsemblesS3","title":"EnsemblesS3"},"abstract":[{"type":"text","text":"An Amazon S3-based cloud backend for Ensembles."}],"kind":"symbol","identifier":{"url":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/ensembless3"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"title":"Cloud File System","anchor":"Cloud-File-System","identifiers":["doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"https://github.com/awslabs/aws-sdk-swift":{"identifier":"https:\/\/github.com\/awslabs\/aws-sdk-swift","title":"AWS SDK for Swift","titleInlineContent":[{"type":"text","text":"AWS SDK for Swift"}],"url":"https:\/\/github.com\/awslabs\/aws-sdk-swift","type":"link"},"doc://EnsemblesS3/documentation/EnsemblesS3/S3CloudFileSystem":{"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"S3CloudFileSystem"}],"identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem","type":"topic","role":"symbol","navigatorTitle":[{"text":"S3CloudFileSystem","kind":"identifier"}],"title":"S3CloudFileSystem","url":"\/documentation\/ensembless3\/s3cloudfilesystem","abstract":[{"type":"text","text":"A cloud file system backed by Amazon S3, using the AWS SDK for Swift."}]},"doc://EnsemblesS3/documentation/EnsemblesS3/S3CloudFileSystem/keyPrefix":{"type":"topic","abstract":[{"type":"text","text":"Optional key prefix within the bucket (e.g. “ensembles\/”)."},{"type":"text","text":" "},{"type":"text","text":"If set, all keys are prefixed with this value."}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"keyPrefix","kind":"identifier"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"}],"kind":"symbol","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/keyPrefix","url":"\/documentation\/ensembless3\/s3cloudfilesystem\/keyprefix","role":"symbol","title":"keyPrefix"},"doc://EnsemblesS3/documentation/EnsemblesS3":{"identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3","type":"topic","kind":"symbol","url":"\/documentation\/ensembless3","title":"EnsemblesS3","abstract":[{"type":"text","text":"An Amazon S3-based cloud backend for Ensembles."}],"role":"collection"}}}