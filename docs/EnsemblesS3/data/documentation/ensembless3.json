{"topicSections":[{"identifiers":["doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem"],"anchor":"Cloud-File-System","title":"Cloud File System"}],"identifier":{"url":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3","interfaceLanguage":"swift"},"sections":[],"metadata":{"modules":[{"name":"EnsemblesS3"}],"role":"collection","title":"EnsemblesS3","externalID":"EnsemblesS3","roleHeading":"Framework","symbolKind":"module"},"kind":"symbol","abstract":[{"type":"text","text":"An Amazon S3-based cloud backend for Ensembles."}],"hierarchy":{"paths":[[]]},"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"EnsemblesS3 provides "},{"type":"reference","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem","isActive":true},{"type":"text","text":", an implementation of the Ensembles "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" protocol that stores sync data in an Amazon S3 bucket. It uses the official "},{"type":"reference","identifier":"https:\/\/github.com\/awslabs\/aws-sdk-swift","isActive":true},{"type":"text","text":" for all API operations."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"S3 is a natural fit for Ensembles — it’s highly durable, globally available, and cost-effective for the small files that Ensembles exchanges. S3-compatible services (MinIO, DigitalOcean Spaces, Backblaze B2, Cloudflare R2) can also be used by configuring the "},{"type":"codeVoice","code":"S3Client"},{"type":"text","text":" with a custom endpoint."}]},{"type":"heading","level":3,"text":"S3 as a File System","anchor":"S3-as-a-File-System"},{"type":"paragraph","inlineContent":[{"type":"text","text":"S3 is a flat key-value store, not a hierarchical file system. "},{"type":"reference","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem","isActive":true},{"type":"text","text":" simulates directory semantics using key prefixes and "},{"type":"codeVoice","code":"\/"},{"type":"text","text":" delimiters — the standard S3 convention. For example, the Ensembles path "},{"type":"codeVoice","code":"ensembleId\/events\/data.json"},{"type":"text","text":" maps to the S3 key "},{"type":"codeVoice","code":"prefix\/ensembleId\/events\/data.json"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Directory creation writes a zero-byte marker object with a trailing "},{"type":"codeVoice","code":"\/"},{"type":"text","text":" in the key. Directory listing uses "},{"type":"codeVoice","code":"ListObjectsV2"},{"type":"text","text":" with a delimiter to discover “subdirectories” via common prefixes."}]},{"type":"heading","level":3,"text":"Authentication","anchor":"Authentication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The AWS SDK for Swift supports multiple credential sources (environment variables, IAM roles, SSO, credential files). Your app creates and configures an "},{"type":"codeVoice","code":"S3Client"},{"type":"text","text":", then injects it:"}]},{"type":"codeListing","code":["import EnsemblesS3","import AWSS3","","let s3Client = try await S3Client()  \/\/ Uses default credential chain","let cloudFileSystem = S3CloudFileSystem(","    client: s3Client,","    bucketName: \"my-ensembles-bucket\",","    keyPrefix: \"sync\/\"  \/\/ Optional: isolate Ensembles data under a prefix",")"],"syntax":"swift"},{"type":"heading","level":3,"text":"Setup","anchor":"Setup"},{"type":"codeListing","code":["let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: S3CloudFileSystem(","        client: s3Client,","        bucketName: \"my-bucket\",","        keyPrefix: \"ensembles\/\"","    )",")","try await ensemble?.attachPersistentStore()"],"syntax":"swift"},{"type":"heading","level":3,"text":"Key Prefix","anchor":"Key-Prefix"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/keyPrefix","isActive":true},{"type":"text","text":" parameter isolates Ensembles data within a shared bucket. For example, with "},{"type":"codeVoice","code":"keyPrefix: \"ensembles\/\""},{"type":"text","text":", the path "},{"type":"codeVoice","code":"\/MyStore\/events\/abc.json"},{"type":"text","text":" maps to the S3 key "},{"type":"codeVoice","code":"ensembles\/MyStore\/events\/abc.json"},{"type":"text","text":". A trailing "},{"type":"codeVoice","code":"\/"},{"type":"text","text":" is added automatically if omitted."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"keyPrefix"},{"type":"text","text":" is empty (the default), Ensembles data is stored at the bucket root."}]},{"type":"heading","level":3,"text":"S3-Compatible Services","anchor":"S3-Compatible-Services"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use an S3-compatible service, configure the "},{"type":"codeVoice","code":"S3Client"},{"type":"text","text":" with a custom endpoint:"}]},{"type":"codeListing","code":["let config = try await S3Client.S3ClientConfiguration()","config.endpoint = \"https:\/\/s3.us-east-1.amazonaws.com\"  \/\/ or MinIO, R2, etc.","let s3Client = S3Client(config: config)"],"syntax":"swift"},{"type":"heading","level":3,"text":"Error Handling","anchor":"Error-Handling"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AWS SDK errors are mapped to "},{"type":"codeVoice","code":"EnsembleError"},{"type":"text","text":" cases:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"AccessDenied"},{"type":"text","text":", "},{"type":"codeVoice","code":"InvalidAccessKeyId"},{"type":"text","text":", and "},{"type":"codeVoice","code":"SignatureDoesNotMatch"},{"type":"text","text":" map to "},{"type":"codeVoice","code":"EnsembleError\/authenticationFailure"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"NoSuchKey"},{"type":"text","text":", "},{"type":"codeVoice","code":"NoSuchBucket"},{"type":"text","text":", and "},{"type":"codeVoice","code":"NotFound"},{"type":"text","text":" map to "},{"type":"codeVoice","code":"EnsembleError\/fileAccessFailed"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"All other errors map to "},{"type":"codeVoice","code":"EnsembleError\/serverError"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"type":"heading","level":3,"text":"Dependencies","anchor":"Dependencies"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This module depends on the "},{"type":"reference","identifier":"https:\/\/github.com\/awslabs\/aws-sdk-swift","isActive":true,"overridingTitle":"AWS SDK for Swift","overridingTitleInlineContent":[{"text":"AWS SDK for Swift","type":"text"}]},{"type":"text","text":" ("},{"type":"codeVoice","code":"AWSS3"},{"type":"text","text":" module)."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensembless3"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://EnsemblesS3/documentation/EnsemblesS3":{"url":"\/documentation\/ensembless3","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3","type":"topic","title":"EnsemblesS3","role":"collection","kind":"symbol","abstract":[{"type":"text","text":"An Amazon S3-based cloud backend for Ensembles."}]},"https://github.com/awslabs/aws-sdk-swift":{"type":"link","url":"https:\/\/github.com\/awslabs\/aws-sdk-swift","title":"AWS SDK for Swift","identifier":"https:\/\/github.com\/awslabs\/aws-sdk-swift","titleInlineContent":[{"type":"text","text":"AWS SDK for Swift"}]},"doc://EnsemblesS3/documentation/EnsemblesS3/S3CloudFileSystem/keyPrefix":{"url":"\/documentation\/ensembless3\/s3cloudfilesystem\/keyprefix","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/keyPrefix","type":"topic","title":"keyPrefix","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Optional key prefix within the bucket (e.g. “ensembles\/”)."},{"type":"text","text":" "},{"type":"text","text":"If set, all keys are prefixed with this value."}],"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"keyPrefix"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}]},"doc://EnsemblesS3/documentation/EnsemblesS3/S3CloudFileSystem":{"type":"topic","url":"\/documentation\/ensembless3\/s3cloudfilesystem","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"S3CloudFileSystem"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem","title":"S3CloudFileSystem","navigatorTitle":[{"kind":"identifier","text":"S3CloudFileSystem"}],"abstract":[{"type":"text","text":"A cloud file system backed by Amazon S3, using the AWS SDK for Swift."}]}}}