{"sections":[],"identifier":{"url":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"An Amazon S3-based cloud backend for Ensembles."}],"metadata":{"modules":[{"name":"EnsemblesS3"}],"title":"EnsemblesS3","roleHeading":"Framework","externalID":"EnsemblesS3","symbolKind":"module","role":"collection"},"topicSections":[{"title":"Cloud File System","identifiers":["doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem"],"anchor":"Cloud-File-System"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","hierarchy":{"paths":[[]]},"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"EnsemblesS3 provides "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem"},{"type":"text","text":", an implementation of the Ensembles "},{"code":"CloudFileSystem","type":"codeVoice"},{"type":"text","text":" protocol that stores sync data in an Amazon S3 bucket. It uses the official "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/awslabs\/aws-sdk-swift"},{"type":"text","text":" for all API operations."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"S3 is a natural fit for Ensembles — it’s highly durable, globally available, and cost-effective for the small files that Ensembles exchanges. S3-compatible services (MinIO, DigitalOcean Spaces, Backblaze B2, Cloudflare R2) can also be used by configuring the "},{"code":"S3Client","type":"codeVoice"},{"type":"text","text":" with a custom endpoint."}],"type":"paragraph"},{"anchor":"S3-as-a-File-System","type":"heading","text":"S3 as a File System","level":3},{"inlineContent":[{"type":"text","text":"S3 is a flat key-value store, not a hierarchical file system. "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem"},{"type":"text","text":" simulates directory semantics using key prefixes and "},{"code":"\/","type":"codeVoice"},{"type":"text","text":" delimiters — the standard S3 convention. For example, the Ensembles path "},{"code":"ensembleId\/events\/data.json","type":"codeVoice"},{"type":"text","text":" maps to the S3 key "},{"code":"prefix\/ensembleId\/events\/data.json","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Directory creation writes a zero-byte marker object with a trailing "},{"code":"\/","type":"codeVoice"},{"type":"text","text":" in the key. Directory listing uses "},{"code":"ListObjectsV2","type":"codeVoice"},{"type":"text","text":" with a delimiter to discover “subdirectories” via common prefixes."}],"type":"paragraph"},{"anchor":"Authentication","type":"heading","text":"Authentication","level":3},{"inlineContent":[{"type":"text","text":"The AWS SDK for Swift supports multiple credential sources (environment variables, IAM roles, SSO, credential files). Your app creates and configures an "},{"code":"S3Client","type":"codeVoice"},{"type":"text","text":", then injects it:"}],"type":"paragraph"},{"syntax":"swift","code":["import EnsemblesS3","import AWSS3","","let s3Client = try await S3Client()  \/\/ Uses default credential chain","let cloudFileSystem = S3CloudFileSystem(","    client: s3Client,","    bucketName: \"my-ensembles-bucket\",","    keyPrefix: \"sync\/\"  \/\/ Optional: isolate Ensembles data under a prefix",")"],"type":"codeListing"},{"anchor":"Setup","type":"heading","text":"Setup","level":3},{"syntax":"swift","code":["let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: S3CloudFileSystem(","        client: s3Client,","        bucketName: \"my-bucket\",","        keyPrefix: \"ensembles\/\"","    )",")","try await ensemble?.attachPersistentStore()"],"type":"codeListing"},{"anchor":"Key-Prefix","type":"heading","text":"Key Prefix","level":3},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/keyPrefix"},{"type":"text","text":" parameter isolates Ensembles data within a shared bucket. For example, with "},{"code":"keyPrefix: \"ensembles\/\"","type":"codeVoice"},{"type":"text","text":", the path "},{"code":"\/MyStore\/events\/abc.json","type":"codeVoice"},{"type":"text","text":" maps to the S3 key "},{"code":"ensembles\/MyStore\/events\/abc.json","type":"codeVoice"},{"type":"text","text":". A trailing "},{"code":"\/","type":"codeVoice"},{"type":"text","text":" is added automatically if omitted."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"keyPrefix","type":"codeVoice"},{"type":"text","text":" is empty (the default), Ensembles data is stored at the bucket root."}],"type":"paragraph"},{"anchor":"S3-Compatible-Services","type":"heading","text":"S3-Compatible Services","level":3},{"inlineContent":[{"type":"text","text":"To use an S3-compatible service, configure the "},{"code":"S3Client","type":"codeVoice"},{"type":"text","text":" with a custom endpoint:"}],"type":"paragraph"},{"syntax":"swift","code":["let config = try await S3Client.S3ClientConfiguration()","config.endpoint = \"https:\/\/s3.us-east-1.amazonaws.com\"  \/\/ or MinIO, R2, etc.","let s3Client = S3Client(config: config)"],"type":"codeListing"},{"anchor":"Error-Handling","type":"heading","text":"Error Handling","level":3},{"inlineContent":[{"type":"text","text":"AWS SDK errors are mapped to "},{"code":"EnsembleError","type":"codeVoice"},{"type":"text","text":" cases:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"AccessDenied"},{"type":"text","text":", "},{"type":"codeVoice","code":"InvalidAccessKeyId"},{"type":"text","text":", and "},{"type":"codeVoice","code":"SignatureDoesNotMatch"},{"type":"text","text":" map to "},{"type":"codeVoice","code":"EnsembleError\/authenticationFailure"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"NoSuchKey"},{"type":"text","text":", "},{"type":"codeVoice","code":"NoSuchBucket"},{"type":"text","text":", and "},{"type":"codeVoice","code":"NotFound"},{"type":"text","text":" map to "},{"type":"codeVoice","code":"EnsembleError\/fileAccessFailed"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"All other errors map to "},{"type":"codeVoice","code":"EnsembleError\/serverError"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Dependencies","type":"heading","text":"Dependencies","level":3},{"inlineContent":[{"type":"text","text":"This module depends on the "},{"isActive":true,"overridingTitle":"AWS SDK for Swift","type":"reference","identifier":"https:\/\/github.com\/awslabs\/aws-sdk-swift","overridingTitleInlineContent":[{"text":"AWS SDK for Swift","type":"text"}]},{"type":"text","text":" ("},{"code":"AWSS3","type":"codeVoice"},{"type":"text","text":" module)."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensembless3"]}],"references":{"https://github.com/awslabs/aws-sdk-swift":{"url":"https:\/\/github.com\/awslabs\/aws-sdk-swift","type":"link","title":"AWS SDK for Swift","titleInlineContent":[{"type":"text","text":"AWS SDK for Swift"}],"identifier":"https:\/\/github.com\/awslabs\/aws-sdk-swift"},"doc://EnsemblesS3/documentation/EnsemblesS3/S3CloudFileSystem/keyPrefix":{"abstract":[{"type":"text","text":"Optional key prefix within the bucket (e.g. “ensembles\/”)."},{"type":"text","text":" "},{"type":"text","text":"If set, all keys are prefixed with this value."}],"type":"topic","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/keyPrefix","role":"symbol","url":"\/documentation\/ensembless3\/s3cloudfilesystem\/keyprefix","title":"keyPrefix","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"keyPrefix","kind":"identifier"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}],"kind":"symbol"},"doc://EnsemblesS3/documentation/EnsemblesS3":{"kind":"symbol","role":"collection","url":"\/documentation\/ensembless3","title":"EnsemblesS3","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3","abstract":[{"text":"An Amazon S3-based cloud backend for Ensembles.","type":"text"}],"type":"topic"},"doc://EnsemblesS3/documentation/EnsemblesS3/S3CloudFileSystem":{"abstract":[{"type":"text","text":"A cloud file system backed by Amazon S3, using the AWS SDK for Swift."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"S3CloudFileSystem"}],"url":"\/documentation\/ensembless3\/s3cloudfilesystem","title":"S3CloudFileSystem","kind":"symbol","type":"topic","identifier":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"S3CloudFileSystem"}]}}}