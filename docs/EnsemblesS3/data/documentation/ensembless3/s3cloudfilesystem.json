he","type":"text"},{"text":" ","type":"text"},{"text":"standard S3 convention. For example, the Ensembles path","type":"text"},{"text":" ","type":"text"},{"code":"ensembleId\/events\/data.json","type":"codeVoice"},{"text":" maps to the S3 key","type":"text"},{"text":" ","type":"text"},{"code":"<keyPrefix>ensembleId\/events\/data.json","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Directory creation writes a zero-byte marker object with a trailing ","type":"text"},{"code":"\/","type":"codeVoice"},{"text":" key.","type":"text"},{"text":" ","type":"text"},{"text":"Directory listing uses ","type":"text"},{"code":"ListObjectsV2","type":"codeVoice"},{"text":" with a delimiter to discover","type":"text"},{"text":" ","type":"text"},{"text":"“subdirectories” via common prefixes. This approach is compatible with S3","type":"text"},{"text":" ","type":"text"},{"text":"console browsing and third-party tools.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The app configures an ","type":"text"},{"code":"S3Client","type":"codeVoice"},{"text":" with its own credentials and injects it","type":"text"},{"text":" ","type":"text"},{"text":"at init time:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let s3Client = try await S3Client()","let cloudFS = S3CloudFileSystem(","    client: s3Client,","    bucketName: \"my-bucket\",","    keyPrefix: \"ensembles\/\"",")"],"type":"codeListing"},{"text":"Authentication","level":2,"anchor":"Authentication","type":"heading"},{"inlineContent":[{"type":"text","text":"The AWS SDK for Swift resolves credentials automatically from the standard"},{"type":"text","text":" "},{"type":"text","text":"credential provider chain. Configure credentials using any of:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Environment variables"}]},{"type":"text","text":": "},{"type":"codeVoice","code":"AWS_ACCESS_KEY_ID"},{"type":"text","text":", "},{"type":"codeVoice","code":"AWS_SECRET_ACCESS_KEY"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and optionally "},{"type":"codeVoice","code":"AWS_SESSION_TOKEN"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Shared credentials file"}]},{"type":"text","text":": "},{"type":"codeVoice","code":"~\/.aws\/credentials"},{"type":"text","text":" (set via "},{"type":"codeVoice","code":"aws configure"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"IAM role"}]},{"type":"text","text":": Automatic on EC2, ECS, and Lambda"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"SSO"}]},{"type":"text","text":": Run "},{"type":"codeVoice","code":"aws sso login"},{"type":"text","text":", then configure "},{"type":"codeVoice","code":"~\/.aws\/config"}],"type":"paragraph"}]}],"type":"unorderedList"},{"syntax":"swift","code":["\/\/ Default credentials (auto-resolved from environment\/config)","let s3Client = try await S3Client()","","\/\/ Explicit region","let config = try await S3Client.S3ClientConfiguration(region: \"us-west-2\")","let s3Client = S3Client(config: config)"],"type":"codeListing"},{"text":"Compatible Services","anchor":"Compatible-Services","type":"heading","level":2},{"inlineContent":[{"text":"This backend works with any S3-compatible service by configuring a custom","type":"text"},{"text":" ","type":"text"},{"text":"endpoint on the ","type":"text"},{"code":"S3Client","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"MinIO"}]},{"type":"text","text":" — self-hosted object storage"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"tex