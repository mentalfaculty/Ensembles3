{"abstract":[{"text":"A cloud file system backed by Amazon S3, using the AWS SDK for Swift.","type":"text"}],"kind":"symbol","variants":[{"paths":["\/documentation\/ensembless3\/s3cloudfilesystem"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/EnsemblesS3\/9Ensembles15CloudFileSystemP","doc:\/\/EnsemblesS3\/s8SendableP","doc:\/\/EnsemblesS3\/s16SendableMetatypeP"],"type":"conformsTo"}],"hierarchy":{"paths":[["doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem","interfaceLanguage":"swift"},"sections":[],"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/init(client:bucketName:keyPrefix:)"]},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/bucketName","doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/client","doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/isConnected","doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/keyPrefix"]},{"title":"Instance Methods","anchor":"Instance-Methods","generated":true,"identifiers":["doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/connect()","doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/contentsOfDirectory(atPath:)","doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/createDirectory(atPath:)","doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/downloadFile(atPath:toLocalFile:)","doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/fetchUserIdentity()","doc:\/\/EnsemblesS3\/documentation\/EnsemblesS3\/S3CloudFileSystem\/fileExists(atPath: