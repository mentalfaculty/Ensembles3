{"hierarchy":{"paths":[[]]},"metadata":{"symbolKind":"module","role":"collection","modules":[{"name":"EnsemblesBox"}],"title":"EnsemblesBox","roleHeading":"Framework","externalID":"EnsemblesBox"},"sections":[],"identifier":{"url":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox","interfaceLanguage":"swift"},"topicSections":[{"title":"Cloud File System","anchor":"Cloud-File-System","identifiers":["doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem"]}],"variants":[{"paths":["\/documentation\/ensemblesbox"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"inlineContent":[{"text":"EnsemblesBox provides ","type":"text"},{"identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem","type":"reference","isActive":true},{"text":", an implementation of the Ensembles ","type":"text"},{"type":"codeVoice","code":"CloudFileSystem"},{"text":" protocol that stores sync data on ","type":"text"},{"identifier":"https:\/\/www.box.com","type":"reference","isActive":true},{"text":". It uses the official Box Swift SDK (","type":"text"},{"type":"codeVoice","code":"BoxSdkGen"},{"text":") for all API operations.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Box is widely used in enterprise environments and offers strong administrative controls, compliance features, and large storage quotas.","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"The-ID-Problem","text":"The ID Problem"},{"inlineContent":[{"text":"Unlike path-based services (pCloud, WebDAV, S3), Box identifies every file and folder by a numeric ID. The Ensembles ","type":"text"},{"type":"codeVoice","code":"CloudFileSystem"},{"text":" protocol uses string paths like ","type":"text"},{"type":"codeVoice","code":"ensembleId\/events\/file.json"},{"text":". ","type":"text"},{"identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem","type":"reference","isActive":true},{"text":" bridges this gap by walking the folder hierarchy to resolve paths to Box IDs, caching the mappings to minimize API calls.","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Authentication","text":"Authentication"},{"inlineContent":[{"text":"Box supports multiple authentication methods (OAuth 2.0, Developer Token, Client Credentials Grant, JWT). Your app creates and configures a ","type":"text"},{"type":"codeVoice","code":"BoxClient"},{"text":" with the appropriate auth, then injects it:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["import EnsemblesBox","import BoxSdkGen","","\/\/ Developer token (for testing)","let auth = BoxDeveloperTokenAuth(token: \"your-dev-token\")","let boxClient = BoxClient(auth: auth)","let cloudFileSystem = BoxCloudFileSystem(client: boxClient)"],"syntax":"swift"},{"type":"heading","level":3,"anchor":"Setup","text":"Setup"},{"type":"codeListing","code":["let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: BoxCloudFileSystem(client: boxClient)",")","try await ensemble?.attachPersistentStore()"],"syntax":"swift"},{"type":"heading","level":3,"anchor":"Path-Resolution-and-Caching","text":"Path Resolution and Caching"},{"inlineContent":[{"text":"When Ensembles requests an operation on path ","type":"text"},{"type":"codeVoice","code":"\/ensembleId\/events\/file.json"},{"text":", the backend:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Starts at the Box root folder (ID ","type":"text"},{"code":"\"0\"","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Lists the root folder to find ","type":"text"},{"code":"ensembleId","type":"codeVoice"},{"text":" and gets its folder ID.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Lists that folder to find ","type":"text"},{"code":"events","type":"codeVoice"},{"text":" and gets its folder ID.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Lists that folder to find ","type":"text"},{"code":"file.json","type":"codeVoice"},{"text":" and gets its file ID.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"text":"Each resolved ID is cached in an internal dictionary. Subsequent operations on the same path skip the API calls. The cache is invalidated when items are deleted or when not-found errors suggest staleness.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Folder listings are paginated automatically (up to 1000 items per page) to handle large directories.","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"anchor":"Error-Handling","text":"Error Handling"},{"inlineContent":[{"text":"Box SDK errors are mapped to ","type":"text"},{"type":"codeVoice","code":"EnsembleError"},{"text":" cases:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Authentication failures (401, unauthorized) map to ","type":"text"},{"code":"EnsembleError\/authenticationFailure","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Not-found errors (404) map to ","type":"text"},{"code":"EnsembleError\/fileAccessFailed","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Conflict errors (409, item already exists) are handled internally with retry logic.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"All other errors map to ","type":"text"},{"code":"EnsembleError\/serverError","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":3,"anchor":"Dependencies","text":"Dependencies"},{"inlineContent":[{"text":"This module depends on the ","type":"text"},{"identifier":"https:\/\/github.com\/box\/box-ios-sdk","type":"reference","isActive":true},{"text":" v10+ (","type":"text"},{"type":"codeVoice","code":"BoxSdkGen"},{"text":" module). The SDK has zero external dependencies of its own.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"A Box-based cloud backend for Ensembles."}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://EnsemblesBox/documentation/EnsemblesBox/BoxCloudFileSystem":{"role":"symbol","identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem","navigatorTitle":[{"text":"BoxCloudFileSystem","kind":"identifier"}],"abstract":[{"text":"A cloud file system backed by Box, using the Box Swift SDK (","type":"text"},{"code":"BoxSdkGen","type":"codeVoice"},{"text":").","type":"text"}],"url":"\/documentation\/ensemblesbox\/boxcloudfilesystem","kind":"symbol","type":"topic","title":"BoxCloudFileSystem","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BoxCloudFileSystem","kind":"identifier"}]},"doc://EnsemblesBox/documentation/EnsemblesBox":{"role":"collection","title":"EnsemblesBox","identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox","type":"topic","abstract":[{"text":"A Box-based cloud backend for Ensembles.","type":"text"}],"url":"\/documentation\/ensemblesbox","kind":"symbol"},"https://github.com/box/box-ios-sdk":{"type":"link","title":"Box iOS SDK","titleInlineContent":[{"type":"text","text":"Box iOS SDK"}],"url":"https:\/\/github.com\/box\/box-ios-sdk","identifier":"https:\/\/github.com\/box\/box-ios-sdk"},"https://www.box.com":{"type":"link","title":"Box","titleInlineContent":[{"type":"text","text":"Box"}],"url":"https:\/\/www.box.com","identifier":"https:\/\/www.box.com"}}}