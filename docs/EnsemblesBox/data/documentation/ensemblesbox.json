{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Framework","modules":[{"name":"EnsemblesBox"}],"externalID":"EnsemblesBox","symbolKind":"module","role":"collection","title":"EnsemblesBox"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox"},"hierarchy":{"paths":[[]]},"kind":"symbol","topicSections":[{"title":"Cloud File System","identifiers":["doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem"],"anchor":"Cloud-File-System"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"EnsemblesBox provides "},{"type":"reference","identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem","isActive":true},{"type":"text","text":", an implementation of the Ensembles "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" protocol that stores sync data on "},{"type":"reference","identifier":"https:\/\/www.box.com","isActive":true},{"type":"text","text":". It uses the official Box Swift SDK ("},{"type":"codeVoice","code":"BoxSdkGen"},{"type":"text","text":") for all API operations."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Box is widely used in enterprise environments and offers strong administrative controls, compliance features, and large storage quotas."}],"type":"paragraph"},{"anchor":"The-ID-Problem","type":"heading","text":"The ID Problem","level":3},{"inlineContent":[{"type":"text","text":"Unlike path-based services (pCloud, WebDAV, S3), Box identifies every file and folder by a numeric ID. The Ensembles "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" protocol uses string paths like "},{"type":"codeVoice","code":"ensembleId\/events\/file.json"},{"type":"text","text":". "},{"type":"reference","identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem","isActive":true},{"type":"text","text":" bridges this gap by walking the folder hierarchy to resolve paths to Box IDs, caching the mappings to minimize API calls."}],"type":"paragraph"},{"anchor":"Authentication","type":"heading","text":"Authentication","level":3},{"inlineContent":[{"type":"text","text":"Box supports multiple authentication methods (OAuth 2.0, Developer Token, Client Credentials Grant, JWT). Your app creates and configures a "},{"type":"codeVoice","code":"BoxClient"},{"type":"text","text":" with the appropriate auth, then injects it:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import EnsemblesBox","import BoxSdkGen","","\/\/ Developer token (for testing)","let auth = BoxDeveloperTokenAuth(token: \"your-dev-token\")","let boxClient = BoxClient(auth: auth)","let cloudFileSystem = BoxCloudFileSystem(client: boxClient)"]},{"anchor":"Setup","type":"heading","text":"Setup","level":3},{"type":"codeListing","syntax":"swift","code":["let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: BoxCloudFileSystem(client: boxClient)",")","try await ensemble?.attachPersistentStore()"]},{"anchor":"Path-Resolution-and-Caching","type":"heading","text":"Path Resolution and Caching","level":3},{"inlineContent":[{"type":"text","text":"When Ensembles requests an operation on path "},{"type":"codeVoice","code":"\/ensembleId\/events\/file.json"},{"type":"text","text":", the backend:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Starts at the Box root folder (ID ","type":"text"},{"code":"\"0\"","type":"codeVoice"},{"text":").","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Lists the root folder to find ","type":"text"},{"code":"ensembleId","type":"codeVoice"},{"text":" and gets its folder ID.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Lists that folder to find ","type":"text"},{"code":"events","type":"codeVoice"},{"text":" and gets its folder ID.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Lists that folder to find ","type":"text"},{"code":"file.json","type":"codeVoice"},{"text":" and gets its file ID.","type":"text"}]}]}],"type":"orderedList"},{"inlineContent":[{"type":"text","text":"Each resolved ID is cached in an internal dictionary. Subsequent operations on the same path skip the API calls. The cache is invalidated when items are deleted or when not-found errors suggest staleness."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Folder listings are paginated automatically (up to 1000 items per page) to handle large directories."}],"type":"paragraph"},{"anchor":"Error-Handling","type":"heading","text":"Error Handling","level":3},{"inlineContent":[{"type":"text","text":"Box SDK errors are mapped to "},{"type":"codeVoice","code":"EnsembleError"},{"type":"text","text":" cases:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Authentication failures (401, unauthorized) map to ","type":"text"},{"code":"EnsembleError\/authenticationFailure","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Not-found errors (404) map to ","type":"text"},{"code":"EnsembleError\/fileAccessFailed","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Conflict errors (409, item already exists) are handled internally with retry logic.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"All other errors map to ","type":"text"},{"code":"EnsembleError\/serverError","type":"codeVoice"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Dependencies","type":"heading","text":"Dependencies","level":3},{"inlineContent":[{"type":"text","text":"This module depends on the "},{"type":"reference","identifier":"https:\/\/github.com\/box\/box-ios-sdk","isActive":true},{"type":"text","text":" v10+ ("},{"type":"codeVoice","code":"BoxSdkGen"},{"type":"text","text":" module). The SDK has zero external dependencies of its own."}],"type":"paragraph"}]}],"sections":[],"abstract":[{"type":"text","text":"A Box-based cloud backend for Ensembles."}],"variants":[{"paths":["\/documentation\/ensemblesbox"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://EnsemblesBox/documentation/EnsemblesBox":{"title":"EnsemblesBox","identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox","kind":"symbol","type":"topic","role":"collection","url":"\/documentation\/ensemblesbox","abstract":[{"type":"text","text":"A Box-based cloud backend for Ensembles."}]},"https://github.com/box/box-ios-sdk":{"url":"https:\/\/github.com\/box\/box-ios-sdk","type":"link","title":"Box iOS SDK","titleInlineContent":[{"type":"text","text":"Box iOS SDK"}],"identifier":"https:\/\/github.com\/box\/box-ios-sdk"},"doc://EnsemblesBox/documentation/EnsemblesBox/BoxCloudFileSystem":{"url":"\/documentation\/ensemblesbox\/boxcloudfilesystem","type":"topic","title":"BoxCloudFileSystem","identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem","role":"symbol","abstract":[{"type":"text","text":"A cloud file system backed by Box, using the Box Swift SDK ("},{"code":"BoxSdkGen","type":"codeVoice"},{"type":"text","text":")."}],"kind":"symbol","navigatorTitle":[{"text":"BoxCloudFileSystem","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BoxCloudFileSystem","kind":"identifier"}]},"https://www.box.com":{"url":"https:\/\/www.box.com","type":"link","title":"Box","titleInlineContent":[{"type":"text","text":"Box"}],"identifier":"https:\/\/www.box.com"}}}