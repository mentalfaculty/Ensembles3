{"metadata":{"modules":[{"name":"EnsemblesBox"}],"title":"EnsemblesBox","role":"collection","roleHeading":"Framework","symbolKind":"module","externalID":"EnsemblesBox"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"EnsemblesBox provides ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem"},{"text":", an implementation of the Ensembles ","type":"text"},{"code":"CloudFileSystem","type":"codeVoice"},{"text":" protocol that stores sync data on ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/www.box.com"},{"text":". It uses the official Box Swift SDK (","type":"text"},{"code":"BoxSdkGen","type":"codeVoice"},{"text":") for all API operations.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Box is widely used in enterprise environments and offers strong administrative controls, compliance features, and large storage quotas.","type":"text"}]},{"type":"heading","level":3,"anchor":"The-ID-Problem","text":"The ID Problem"},{"type":"paragraph","inlineContent":[{"text":"Unlike path-based services (pCloud, WebDAV, S3), Box identifies every file and folder by a numeric ID. The Ensembles ","type":"text"},{"code":"CloudFileSystem","type":"codeVoice"},{"text":" protocol uses string paths like ","type":"text"},{"code":"ensembleId\/events\/file.json","type":"codeVoice"},{"text":". ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem"},{"text":" bridges this gap by walking the folder hierarchy to resolve paths to Box IDs, caching the mappings to minimize API calls.","type":"text"}]},{"type":"heading","level":3,"anchor":"Authentication","text":"Authentication"},{"type":"paragraph","inlineContent":[{"text":"Box supports multiple authentication methods (OAuth 2.0, Developer Token, Client Credentials Grant, JWT). Your app creates and configures a ","type":"text"},{"code":"BoxClient","type":"codeVoice"},{"text":" with the appropriate auth, then injects it:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import EnsemblesBox","import BoxSdkGen","","\/\/ Developer token (for testing)","let auth = BoxDeveloperTokenAuth(token: \"your-dev-token\")","let boxClient = BoxClient(auth: auth)","let cloudFileSystem = BoxCloudFileSystem(client: boxClient)"]},{"type":"heading","level":3,"anchor":"Setup","text":"Setup"},{"type":"codeListing","syntax":"swift","code":["let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: BoxCloudFileSystem(client: boxClient)",")","try await ensemble?.attachPersistentStore()"]},{"type":"heading","level":3,"anchor":"Path-Resolution-and-Caching","text":"Path Resolution and Caching"},{"type":"paragraph","inlineContent":[{"text":"When Ensembles requests an operation on path ","type":"text"},{"code":"\/ensembleId\/events\/file.json","type":"codeVoice"},{"text":", the backend:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Starts at the Box root folder (ID ","type":"text"},{"code":"\"0\"","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Lists the root folder to find ","type":"text"},{"code":"ensembleId","type":"codeVoice"},{"text":" and gets its folder ID.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Lists that folder to find ","type":"text"},{"code":"events","type":"codeVoice"},{"text":" and gets its folder ID.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Lists that folder to find ","type":"text"},{"code":"file.json","type":"codeVoice"},{"text":" and gets its file ID.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Each resolved ID is cached in an internal dictionary. Subsequent operations on the same path skip the API calls. The cache is invalidated when items are deleted or when not-found errors suggest staleness.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Folder listings are paginated automatically (up to 1000 items per page) to handle large directories.","type":"text"}]},{"type":"heading","level":3,"anchor":"Error-Handling","text":"Error Handling"},{"type":"paragraph","inlineContent":[{"text":"Box SDK errors are mapped to ","type":"text"},{"code":"EnsembleError","type":"codeVoice"},{"text":" cases:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Authentication failures (401, unauthorized) map to ","type":"text"},{"code":"EnsembleError\/authenticationFailure","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Not-found errors (404) map to ","type":"text"},{"code":"EnsembleError\/fileAccessFailed","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Conflict errors (409, item already exists) are handled internally with retry logic.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"All other errors map to ","type":"text"},{"code":"EnsembleError\/serverError","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":3,"anchor":"Dependencies","text":"Dependencies"},{"type":"paragraph","inlineContent":[{"text":"This module depends on the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/box\/box-ios-sdk"},{"text":" v10+ (","type":"text"},{"code":"BoxSdkGen","type":"codeVoice"},{"text":" module). The SDK has zero external dependencies of its own.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfac