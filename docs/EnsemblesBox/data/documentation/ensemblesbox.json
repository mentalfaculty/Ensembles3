{"abstract":[{"type":"text","text":"A Box-based cloud backend for Ensembles."}],"hierarchy":{"paths":[[]]},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"EnsemblesBox provides "},{"identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem","type":"reference","isActive":true},{"type":"text","text":", an implementation of the Ensembles "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" protocol that stores sync data on "},{"identifier":"https:\/\/www.box.com","type":"reference","isActive":true},{"type":"text","text":". It uses the official Box Swift SDK ("},{"type":"codeVoice","code":"BoxSdkGen"},{"type":"text","text":") for all API operations."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Box is widely used in enterprise environments and offers strong administrative controls, compliance features, and large storage quotas."}],"type":"paragraph"},{"text":"The ID Problem","anchor":"The-ID-Problem","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Unlike path-based services (pCloud, WebDAV, S3), Box identifies every file and folder by a numeric ID. The Ensembles "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" protocol uses string paths like "},{"type":"codeVoice","code":"ensembleId\/events\/file.json"},{"type":"text","text":". "},{"identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem","type":"reference","isActive":true},{"type":"text","text":" bridges this gap by walking the folder hierarchy to resolve paths to Box IDs, caching the mappings to minimize API calls."}],"type":"paragraph"},{"text":"Authentication","anchor":"Authentication","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Box supports multiple authentication methods (OAuth 2.0, Developer Token, Client Credentials Grant, JWT). Your app creates and configures a "},{"type":"codeVoice","code":"BoxClient"},{"type":"text","text":" with the appropriate auth, then injects it:"}],"type":"paragraph"},{"code":["import EnsemblesBox","import BoxSdkGen","","\/\/ Developer token (for testing)","let auth = BoxDeveloperTokenAuth(token: \"your-dev-token\")","let boxClient = BoxClient(auth: auth)","let cloudFileSystem = BoxCloudFileSystem(client: boxClient)"],"syntax":"swift","type":"codeListing"},{"text":"Setup","anchor":"Setup","type":"heading","level":3},{"code":["let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: BoxCloudFileSystem(client: boxClient)",")","try await ensemble?.attachPersistentStore()"],"syntax":"swift","type":"codeListing"},{"text":"Path Resolution and Caching","anchor":"Path-Resolution-and-Caching","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"When Ensembles requests an operation on path "},{"type":"codeVoice","code":"\/ensembleId\/events\/file.json"},{"type":"text","text":", the backend:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Starts at the Box root folder (ID ","type":"text"},{"code":"\"0\"","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Lists the root folder to find ","type":"text"},{"code":"ensembleId","type":"codeVoice"},{"text":" and gets its folder ID.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Lists that folder to find ","type":"text"},{"code":"events","type":"codeVoice"},{"text":" and gets its folder ID.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Lists that folder to find ","type":"text"},{"code":"file.json","type":"codeVoice"},{"text":" and gets its file ID.","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Each resolved ID is cached in an internal dictionary. Subsequent operations on the same path skip the API calls. The cache is invalidated when items are deleted or when not-found errors suggest staleness."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Folder listings are paginated automatically (up to 1000 items per page) to handle large directories."}],"type":"paragraph"},{"text":"Error Handling","anchor":"Error-Handling","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Box SDK errors are mapped to "},{"type":"codeVoice","code":"EnsembleError"},{"type":"text","text":" cases:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Authentication failures (401, unauthorized) map to ","type":"text"},{"code":"EnsembleError\/authenticationFailure","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Not-found errors (404) map to ","type":"text"},{"code":"EnsembleError\/fileAccessFailed","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Conflict errors (409, item already exists) are handled internally with retry logic.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"All other errors map to ","type":"text"},{"code":"EnsembleError\/serverError","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"text":"Dependencies","anchor":"Dependencies","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"This module depends on the "},{"identifier":"https:\/\/github.com\/box\/box-ios-sdk","type":"reference","isActive":true},{"type":"text","text":" v10+ ("},{"type":"codeVoice","code":"BoxSdkGen"},{"type":"text","text":" module). The SDK has zero external dependencies of its own."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox","interfaceLanguage":"swift"},"topicSections":[{"anchor":"Cloud-File-System","identifiers":["doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem"],"title":"Cloud File System"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"EnsemblesBox","roleHeading":"Framework","symbolKind":"module","modules":[{"name":"EnsemblesBox"}],"externalID":"EnsemblesBox","role":"collection"},"variants":[{"paths":["\/documentation\/ensemblesbox"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","references":{"https://www.box.com":{"titleInlineContent":[{"type":"text","text":"Box"}],"url":"https:\/\/www.box.com","type":"link","title":"Box","identifier":"https:\/\/www.box.com"},"https://github.com/box/box-ios-sdk":{"titleInlineContent":[{"type":"text","text":"Box iOS SDK"}],"url":"https:\/\/github.com\/box\/box-ios-sdk","type":"link","title":"Box iOS SDK","identifier":"https:\/\/github.com\/box\/box-ios-sdk"},"doc://EnsemblesBox/documentation/EnsemblesBox":{"abstract":[{"text":"A Box-based cloud backend for Ensembles.","type":"text"}],"role":"collection","kind":"symbol","type":"topic","url":"\/documentation\/ensemblesbox","identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox","title":"EnsemblesBox"},"doc://EnsemblesBox/documentation/EnsemblesBox/BoxCloudFileSystem":{"abstract":[{"text":"A cloud file system backed by Box, using the Box Swift SDK (","type":"text"},{"type":"codeVoice","code":"BoxSdkGen"},{"type":"text","text":")."}],"role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BoxCloudFileSystem","kind":"identifier"}],"url":"\/documentation\/ensemblesbox\/boxcloudfilesystem","identifier":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem","title":"BoxCloudFileSystem","navigatorTitle":[{"text":"BoxCloudFileSystem","kind":"identifier"}]}}}