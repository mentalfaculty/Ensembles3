{"metadata":{"role":"symbol","roleHeading":"Class","externalID":"s:12EnsemblesBox0B15CloudFileSystemC","modules":[{"name":"EnsemblesBox"}],"navigatorTitle":[{"text":"BoxCloudFileSystem","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BoxCloudFileSystem","kind":"identifier"}],"symbolKind":"class","title":"BoxCloudFileSystem"},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BoxCloudFileSystem","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"aside","style":"important","content":[{"inlineContent":[{"text":"This backend requires the ","type":"text"},{"identifier":"https:\/\/github.com\/box\/box-ios-sdk.git","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"package. With the source distribution, enable the ","type":"text"},{"type":"codeVoice","code":"Box"},{"text":" package trait and SPM resolves it","type":"text"},{"text":" ","type":"text"},{"text":"automatically. With the binary distribution (XCFrameworks), add BoxSDK as a separate","type":"text"},{"text":" ","type":"text"},{"text":"package dependency in your project.","type":"text"}],"type":"paragraph"}],"name":"Important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Box uses numeric IDs rather than paths to identify files and folders. This backend"},{"type":"text","text":" "},{"type":"text","text":"bridges the path-based "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" protocol onto Box’s ID-based API by"},{"type":"text","text":" "},{"type":"text","text":"walking the folder hierarchy to resolve Ensembles paths"},{"type":"text","text":" "},{"type":"text","text":"(e.g. "},{"type":"codeVoice","code":"ensembleId\/events\/file.json"},{"type":"text","text":") to Box folder and file IDs."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Resolved IDs are cached in internal dictionaries to minimize API calls. The cache"},{"type":"text","text":" "},{"type":"text","text":"is invalidated when items are deleted or when not-found errors indicate stale entries."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The app creates and configures a "},{"type":"codeVoice","code":"BoxClient"},{"type":"text","text":" with its own authentication"},{"type":"text","text":" "},{"type":"text","text":"and injects it at init time:"}]},{"code":["let auth = BoxDeveloperTokenAuth(token: \"your-token\")","let client = BoxClient(auth: auth)","let cloudFS = BoxCloudFileSystem(client: client)"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","text":"Authentication","anchor":"Authentication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Box Swift SDK supports multiple authentication methods. Create a"},{"type":"text","text":" "},{"type":"codeVoice","code":"BoxClient"},{"type":"text","text":" with the appropriate auth for your use case:"}]},{"level":3,"type":"heading","text":"Developer Token (testing only)","anchor":"Developer-Token-testing-only"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Get a short-lived token from "},{"type":"reference","identifier":"https:\/\/developer.box.com\/","isActive":true},{"type":"text","text":" "},{"type":"text","text":"under your app’s configuration page. These tokens expire after 60 minutes."}]},{"code":["let auth = BoxDeveloperTokenAuth(token: \"your-developer-token\")","let client = BoxClient(auth: auth)","let cloudFS = BoxCloudFileSystem(client: client)"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","text":"OAuth 2.0 (production apps)","anchor":"OAuth-20-production-apps"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register your app at "},{"type":"reference","overridingTitleInlineContent":[{"text":"developer.box.com","type":"text"}],"identifier":"https:\/\/developer.box.com\/","isActive":true,"overridingTitle":"developer.box.com"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"configure an OAuth 2.0 redirect URI:"}]},{"code":["let config = OAuthConfig(clientId: \"your-client-id\", clientSecret: \"your-secret\")","let auth = BoxOAuth(config: config)","\/\/ Call auth.authorize(url:) with your redirect URL after the OAuth flow","let client = BoxClient(auth: auth)","let cloudFS = BoxCloudFileSystem(client: client)"],"type":"codeListing","syntax":"swift"},{"level":3,"type":"heading","text":"Client Credentials Grant (server-side)","anchor":"Client-Credentials-Grant-server-side"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For server-to-server integration without user interaction:"}]},{"code":["let config = CCGConfig(","    clientId: \"your-client-id\",","    clientSecret: \"your-secret\",","    userId: \"user-id\"",")","let auth = BoxCCGAuth(config: config)","let client = BoxClient(auth: auth)","let cloudFS = BoxCloudFileSystem(client: client)"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","text":"Threading","anchor":"Threading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This class is "},{"type":"codeVoice","code":"@unchecked Sendable"},{"type":"text","text":". The "},{"type":"codeVoice","code":"BoxClient"},{"type":"text","text":" handles its own thread"},{"type":"text","text":" "},{"type":"text","text":"safety internally. Mutable state (caches, "},{"type":"codeVoice","code":"loggedIn"},{"type":"text","text":" flag) is accessed only"},{"type":"text","text":" "},{"type":"text","text":"from async methods that are serialized by the ensemble’s operation queue."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/ensemblesbox\/boxcloudfilesystem"],"traits":[{"interfaceLanguage":"swift"}]}],"hierar