{"abstract":[{"text":"A cloud file system backed by Box, using the Box Swift SDK (","type":"text"},{"type":"codeVoice","code":"BoxSdkGen"},{"text":").","type":"text"}],"hierarchy":{"paths":[["doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BoxCloudFileSystem","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"content":[{"type":"paragraph","inlineContent":[{"text":"This backend requires the ","type":"text"},{"identifier":"https:\/\/github.com\/box\/box-ios-sdk.git","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"package. With the source distribution, enable the ","type":"text"},{"type":"codeVoice","code":"Box"},{"text":" package trait and SPM resolves it","type":"text"},{"text":" ","type":"text"},{"text":"automatically. With the binary distribution (XCFrameworks), add BoxSDK as a separate","type":"text"},{"text":" ","type":"text"},{"text":"package dependency in your project.","type":"text"}]}],"type":"aside","name":"Important","style":"important"},{"type":"paragraph","inlineContent":[{"text":"Box uses numeric IDs rather than paths to identify files and folders. This backend","type":"text"},{"text":" ","type":"text"},{"text":"bridges the path-based ","type":"text"},{"type":"codeVoice","code":"CloudFileSystem"},{"text":" protocol onto Box’s ID-based API by","type":"text"},{"text":" ","type":"text"},{"text":"walking the folder hierarchy to resolve Ensembles paths","type":"text"},{"text":" ","type":"text"},{"text":"(e.g. ","type":"text"},{"type":"codeVoice","code":"ensembleId\/events\/file.json"},{"text":") to Box folder and file IDs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Resolved IDs are cached in internal dictionaries to minimize API calls. The cache","type":"text"},{"text":" ","type":"text"},{"text":"is invalidated when items are deleted or when not-found errors indicate stale entries.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The app creates and configures a ","type":"text"},{"type":"codeVoice","code":"BoxClient"},{"text":" with its own authentication","type":"text"},{"text":" ","type":"text"},{"text":"and injects it at init time:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let auth = BoxDeveloperTokenAuth(token: \"your-token\")","let client = BoxClient(auth: auth)","let cloudFS = BoxCloudFileSystem(client: client)"]},{"text":"Authentication","type":"heading","level":2,"anchor":"Authentication"},{"type":"paragraph","inlineContent":[{"text":"The Box Swift SDK supports multiple authentication methods. Create a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"BoxClient"},{"text":" with the appropriate auth for your use case:","type":"text"}]},{"text":"Developer Token (testing only)","type":"heading","level":3,"anchor":"Developer-Token-testing-only"},{"type":"paragraph","inlineContent":[{"text":"Get a short-lived token from ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.box.com\/"},{"text":" ","type":"text"},{"text":"under your app’s configuration page. These tokens expire after 60 minutes.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let auth = BoxDeveloperTokenAuth(token: \"your-developer-token\")","let client = BoxClient(auth: auth)","let cloudFS = BoxCloudFileSystem(client: client)"]},{"text":"OAuth 2.0 (production apps)","type":"heading","level":3,"anchor":"OAuth-20-production-apps"},{"type":"paragraph","inlineContent":[{"text":"Register your app at ","type":"text"},{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"developer.box.com","type":"text"}],"overridingTitle":"developer.box.com","identifier":"https:\/\/developer.box.com\/"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"text":"configure an OAuth 2.0 redirect URI:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let config = OAuthConfig(clientId: \"your-client-id\", clientSecret: \"your-secret\")","let auth = BoxOAuth(config: config)","\/\/ Call auth.authorize(url:) with your redirect URL after the OAuth flow","let client = BoxClient(auth: auth)","let cloudFS = BoxCloudFileSystem(client: client)"]},{"text":"Client Credentials Grant (server-side)","type":"heading","level":3,"anchor":"Client-Credentials-Grant-server-side"},{"type":"paragraph","inlineContent":[{"text":"For server-to-server integration without user interaction:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let config = CCGConfig(","    clientId: \"your-client-id\",","    clientSecret: \"your-secret\",","    userId: \"user-id\"",")","let auth = BoxCCGAuth(config: config)","let client = BoxClient(auth: auth)","let cloudFS = BoxCloudFileSystem(client: client)"]},{"text":"Threading","type":"heading","level":2,"anchor":"Threading"},{"type":"paragraph","inlineContent":[{"text":"This class is ","type":"text"},{"type":"codeVoice","code":"@unchecked Sendable"},{"text":". The ","type":"text"},{"type":"codeVoice","code":"BoxClient"},{"text":" handles its own thread","type":"text"},{"text":" ","type":"text"},{"text":"safety internally. Mutable state (caches, ","type":"text"},{"type":"codeVoice","code":"loggedIn"},{"text":" flag) is accessed only","type":"text"},{"text":" ","type":"text"},{"text":"from async methods that are serialized by the ensemble’s operation queue.","type":"text"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem"},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/EnsemblesBox\/documentation\/EnsemblesBox\/BoxCloudFileSystem\/init(client:)"],"anchor":"Initializers","generated":true},{"title":"Instance