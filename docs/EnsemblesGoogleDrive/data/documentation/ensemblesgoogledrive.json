{"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"EnsemblesGoogleDrive provides "},{"isActive":true,"identifier":"doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem","type":"reference"},{"type":"text","text":", an implementation of the Ensembles "},{"code":"CloudFileSystem","type":"codeVoice"},{"type":"text","text":" protocol that stores sync data on Google Drive. It communicates directly with the Google Drive REST API v3 using "},{"code":"URLSession","type":"codeVoice"},{"type":"text","text":" — no third-party SDK required."}]},{"type":"paragraph","inlineContent":[{"text":"Google Drive uses file IDs rather than paths internally. The backend transparently bridges between Ensembles’ path-based ","type":"text"},{"code":"CloudFileSystem","type":"codeVoice"},{"text":" protocol and Google Drive’s ID-based system, caching folder and file IDs to minimize API calls.","type":"text"}]},{"level":3,"anchor":"Authentication","type":"heading","text":"Authentication"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The included "},{"type":"reference","identifier":"doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveAuthenticator","isActive":true},{"text":" handles the full OAuth 2.0 authorization code flow, stores tokens in the Keychain, and automatically refreshes expired tokens.","type":"text"}]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Google Cloud Console setup:","type":"text"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Go to "},{"identifier":"https:\/\/console.cloud.google.com\/","type":"reference","isActive":true},{"text":" and create a project (or select an existing one).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable the "},{"type":"strong","inlineContent":[{"text":"Google Drive API","type":"text"}]},{"type":"text","text":" under "},{"type":"emphasis","inlineContent":[{"text":"APIs & Services → Library","type":"text"}]},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Go to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"APIs & Services → Credentials"}]},{"type":"text","text":" and create an "},{"type":"strong","inlineContent":[{"text":"OAuth 2.0 Client ID","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select "},{"type":"strong","inlineContent":[{"text":"iOS","type":"text"}]},{"text":" as the application type and enter your app’s bundle identifier.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Note the "},{"type":"strong","inlineContent":[{"type":"text","text":"Client ID"}]},{"type":"text","text":" (looks like "},{"code":"123456789-abc.apps.googleusercontent.com","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Set the redirect URI to: ","type":"text"},{"code":"com.googleusercontent.apps.YOUR-CLIENT-ID:\/oauthredirect","type":"codeVoice"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Code:","type":"text"}],"type":"strong"}]},{"syntax":"swift","type":"codeListing","code":["import EnsemblesGoogleDrive","","let config = GoogleDriveAuthenticator.Configuration(","    clientID: \"YOUR-CLIENT-ID.apps.googleusercontent.com\",","    redirectURI: \"com.googleusercontent.apps.YOUR-CLIENT-ID:\/oauthredirect\"",")","let authenticator = GoogleDriveAuthenticator(configuration: config)","","\/\/ One-time interactive authorization (presents a web sign-in sheet)","try await authenticator.authorize(presenting: window)","","\/\/ Create the cloud file system","let cloudFS = GoogleDriveCloudFileSystem(authenticator: authenticator)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On subsequent launches, the authenticator restores tokens from the Keychain and refreshes them automatically. Call "},{"code":"authenticator.isAuthorized","type":"codeVoice"},{"type":"text","text":" to check if stored credentials exist."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For apps that manage tokens externally, pass a static access token instead:"}]},{"syntax":"swift","type":"codeListing","code":["let cloudFS = GoogleDriveCloudFileSystem(accessToken: \"your-token\")"]},{"anchor":"Setup","type":"heading","level":3,"text":"Setup"},{"syntax":"swift","type":"codeListing","code":["import Ensembles","import EnsemblesGoogleDrive","","let cloudFS = GoogleDriveCloudFileSystem(authenticator: authenticator)","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")","try await ensemble?.attachPersistentStore()"]},{"anchor":"API-Details","type":"heading","level":3,"text":"API Details"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The backend uses the Google Drive REST API v3 with the "},{"type":"codeVoice","code":"drive.file"},{"type":"text","text":" scope, which limits access to files the app creates. Ensembles paths are resolved to Google Drive file IDs via folder traversal, with results cached in memory."}]},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Operation"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Google Drive API"}]}]],[[{"inlineContent":[{"text":"Connect \/ Identity","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"GET \/about?fields=user"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"File existence","type":"text"}]}],[{"inlineContent":[{"type":"codeVoice","code":"GET \/files"},{"type":"text","text":" (query by name + parent)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Create directory","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"POST \/files"},{"type":"text","text":" (folder MIME type)"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"List directory","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"GET \/files","type":"codeVoice"},{"text":" (query by parent)","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Remove item"}],"type":"paragraph"}],[{"inlineContent":[{"code":"DELETE \/files\/{id}","type":"codeVoice"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Upload"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"POST \/upload\/files"},{"text":" (multipart)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Download"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GET \/files\/{id}?alt=media"}]}]]],"header":"row"},{"anchor":"Error-Handling","text":"Error Handling","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"HTTP errors are mapped to "},{"type":"codeVoice","code":"EnsembleError"},{"text":" cases:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"401 Unauthorized"}]},{"text":" maps to ","type":"text"},{"type":"codeVoice","code":"EnsembleError.authenticationFailure"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"404 Not Found","type":"text"}],"type":"strong"},{"text":" maps to ","type":"text"},{"code":"EnsembleError.fileAccessFailed","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Other HTTP errors map to "},{"type":"codeVoice","code":"EnsembleError.serverError"},{"text":".","type":"text"}]}]}]},{