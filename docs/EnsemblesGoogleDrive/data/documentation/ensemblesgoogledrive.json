{"topicSections":[{"title":"Cloud File System","anchor":"Cloud-File-System","identifiers":["doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem","doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveAuthenticator"]}],"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensemblesgoogledrive"]}],"metadata":{"title":"EnsemblesGoogleDrive","role":"collection","roleHeading":"Framework","modules":[{"name":"EnsemblesGoogleDrive"}],"externalID":"EnsemblesGoogleDrive","symbolKind":"module"},"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive"},"abstract":[{"text":"A Google Drive cloud backend for Ensembles.","type":"text"}],"hierarchy":{"paths":[[]]},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"EnsemblesGoogleDrive provides ","type":"text"},{"identifier":"doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem","isActive":true,"type":"reference"},{"type":"text","text":", an implementation of the Ensembles "},{"code":"CloudFileSystem","type":"codeVoice"},{"type":"text","text":" protocol that stores sync data on Google Drive. It communicates directly with the Google Drive REST API v3 using "},{"code":"URLSession","type":"codeVoice"},{"text":" — no third-party SDK required.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Google Drive uses file IDs rather than paths internally. The backend transparently bridges between Ensembles’ path-based "},{"code":"CloudFileSystem","type":"codeVoice"},{"type":"text","text":" protocol and Google Drive’s ID-based system, caching folder and file IDs to minimize API calls."}]},{"type":"heading","level":3,"text":"Authentication","anchor":"Authentication"},{"inlineContent":[{"type":"text","text":"The included "},{"isActive":true,"type":"reference","identifier":"doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveAuthenticator"},{"text":" handles the full OAuth 2.0 authorization code flow, stores tokens in the Keychain, and automatically refreshes expired tokens.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Google Cloud Console setup:"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Go to "},{"type":"reference","identifier":"https:\/\/console.cloud.google.com\/","isActive":true},{"type":"text","text":" and create a project (or select an existing one)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Enable the "},{"inlineContent":[{"type":"text","text":"Google Drive API"}],"type":"strong"},{"type":"text","text":" under "},{"inlineContent":[{"type":"text","text":"APIs & Services → Library"}],"type":"emphasis"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Go to "},{"inlineContent":[{"type":"text","text":"APIs & Services → Credentials"}],"type":"emphasis"},{"type":"text","text":" and create an "},{"inlineContent":[{"type":"text","text":"OAuth 2.0 Client ID"}],"type":"strong"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Select "},{"inlineContent":[{"type":"text","text":"iOS"}],"type":"strong"},{"type":"text","text":" as the application type and enter your app’s bundle identifier."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Note the "},{"inlineContent":[{"text":"Client ID","type":"text"}],"type":"strong"},{"type":"text","text":" (looks like "},{"type":"codeVoice","code":"123456789-abc.apps.googleusercontent.com"},{"type":"text","text":")."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the redirect URI to: "},{"type":"codeVoice","code":"com.googleusercontent.apps.YOUR-CLIENT-ID:\/oauthredirect"}]}]}],"type":"orderedList"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Code:"}]}],"type":"paragraph"},{"syntax":"swift","code":["import EnsemblesGoogleDrive","","let config = GoogleDriveAuthenticator.Configuration(","    clientID: \"YOUR-CLIENT-ID.apps.googleusercontent.com\",","    redirectURI: \"com.googleusercontent.apps.YOUR-CLIENT-ID:\/oauthredirect\"",")","let authenticator = GoogleDriveAuthenticator(configuration: config)","","\/\/ One-time interactive authorization (presents a web sign-in sheet)","try await authenticator.authorize(presenting: window)","","\/\/ Create the cloud file system","let cloudFS = GoogleDriveCloudFileSystem(authenticator: authenticator)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"On subsequent launches, the authenticator restores tokens from the Keychain and refreshes them automatically. Call "},{"code":"authenticator.isAuthorized","type":"codeVoice"},{"type":"text","text":" to check if stored credentials exist."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For apps that manage tokens externally, pass a static access token instead:"}],"type":"paragraph"},{"syntax":"swift","code":["let cloudFS = GoogleDriveCloudFileSystem(accessToken: \"your-token\")"],"type":"codeListing"},{"level":3,"type":"heading","anchor":"Setup","text":"Setup"},{"syntax":"swift","code":["import Ensembles","import EnsemblesGoogleDrive","","let cloudFS = GoogleDriveCloudFileSystem(authenticator: authenticator)","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")","try await ensemble?.attachPersistentStore()"],"type":"codeListing"},{"level":3,"type":"heading","anchor":"API-Details","text":"API Details"},{"in