{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Framework","role":"collection","title":"EnsemblesGoogleDrive","externalID":"EnsemblesGoogleDrive","symbolKind":"module","modules":[{"name":"EnsemblesGoogleDrive"}]},"topicSections":[{"identifiers":["doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem","doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveAuthenticator"],"anchor":"Cloud-File-System","title":"Cloud File System"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"EnsemblesGoogleDrive provides ","type":"text"},{"isActive":true,"identifier":"doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem","type":"reference"},{"text":", an implementation of the Ensembles ","type":"text"},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" protocol that stores sync data on Google Drive. It communicates directly with the Google Drive REST API v3 using "},{"type":"codeVoice","code":"URLSession"},{"type":"text","text":" — no third-party SDK required."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Google Drive uses file IDs rather than paths internally. The backend transparently bridges between Ensembles’ path-based "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" protocol and Google Drive’s ID-based system, caching folder and file IDs to minimize API calls."}]},{"type":"heading","level":3,"text":"Authentication","anchor":"Authentication"},{"inlineContent":[{"type":"text","text":"The included "},{"isActive":true,"identifier":"doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveAuthenticator","type":"reference"},{"type":"text","text":" handles the full OAuth 2.0 authorization code flow, stores tokens in the Keychain, and automatically refreshes expired tokens."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Google Cloud Console setup:"}],"type":"strong"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Go to "},{"type":"reference","identifier":"https:\/\/console.cloud.google.com\/","isActive":true},{"text":" and create a project (or select an existing one).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Enable the "},{"inlineContent":[{"text":"Google Drive API","type":"text"}],"type":"strong"},{"type":"text","text":" under "},{"inlineContent":[{"text":"APIs & Services → Library","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Go to "},{"type":"emphasis","inlineContent":[{"text":"APIs & Services → Credentials","type":"text"}]},{"type":"text","text":" and create an "},{"type":"strong","inlineContent":[{"text":"OAuth 2.0 Client ID","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Select "},{"type":"strong","inlineContent":[{"type":"text","text":"iOS"}]},{"type":"text","text":" as the application type and enter your app’s bundle identifier."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Note the "},{"type":"strong","inlineContent":[{"type":"text","text":"Client ID"}]},{"type":"text","text":" (looks like "},{"type":"codeVoice","code":"123456789-abc.apps.googleusercontent.com"},{"type":"text","text":")."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Set the redirect URI to: "},{"type":"codeVoice","code":"com.googleusercontent.apps.YOUR-CLIENT-ID:\/oauthredirect"}],"type":"paragraph"}]}],"type":"orderedList"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Code:"}],"type":"strong"}],"type":"paragraph"},{"code":["import EnsemblesGoogleDrive","","let config = GoogleDriveAuthenticator.Configuration(","    clientID: \"YOUR-CLIENT-ID.apps.googleusercontent.com\",","    redirectURI: \"com.googleusercontent.apps.YOUR-CLIENT-ID:\/oauthredirect\"",")","let authenticator = GoogleDriveAuthenticator(configuration: config)","","\/\/ One-time interactive authorization (presents a web sign-in sheet)","try await authenticator.authorize(presenting: window)","","\/\/ Create the cloud file system","let cloudFS = GoogleDriveCloudFileSystem(authenticator: authenticator)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"On subsequent launches, the authenticator restores tokens from the Keychain and refreshes them automatically. Call "},{"type":"codeVoice","code":"authenticator.isAuthorized"},{"type":"text","text":" to check if stored credentials exist."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For apps that manage tokens externally, pass a static access token instead:"}],"type":"paragraph"},{"code":["let cloudFS = GoogleDriveCloudFileSystem(accessToken: \"your-token\")"],"syntax":"swift","type":"codeListing"},{"anchor":"Setup","text":"Setup","level":3,"type":"heading"},{"code":["import Ensembles","import EnsemblesGoogleDrive","","let cloudFS = GoogleDriveCloudFileSystem(authenticator: authenticator)","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")","try await ensemble?.attachPersistentStore()"],"syntax":"swift","type":"codeListing"},{"anchor":"API-Details","text":"API Details","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"The backend uses the Google Drive REST API v3 with the "},{"type":"codeVoice","code":"drive.file"},{"text":" scope, which limits access to files the app creates. Ensembles paths are resolved to Google Drive file IDs via folder traversal, with results cached in memory.","type":"text"}],"type":"paragraph"},{"header":"row","ty