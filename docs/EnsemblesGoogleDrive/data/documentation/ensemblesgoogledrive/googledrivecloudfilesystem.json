t","text":"when they expire. The default scope is "},{"code":"drive.file","type":"codeVoice"},{"type":"text","text":" (per-file access), which"},{"type":"text","text":" "},{"type":"text","text":"limits the app to files it creates."}],"type":"paragraph"},{"anchor":"Threading","text":"Threading","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"This class is "},{"code":"@unchecked Sendable","type":"codeVoice"},{"type":"text","text":". All network calls go through a shared"},{"type":"text","text":" "},{"code":"URLSession","type":"codeVoice"},{"type":"text","text":" instance, which is thread-safe. Mutable state (caches, "},{"code":"loggedIn","type":"codeVoice"},{"type":"text","text":" flag)"},{"type":"text","text":" "},{"type":"text","text":"is accessed only from async methods that are serialized by the ensemble’s operation queue."}],"type":"paragraph"}]}],"sections":[],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GoogleDriveCloudFileSystem","kind":"identifier"}],"role":"symbol","roleHeading":"Class","symbolKind":"class","externalID":"s:20EnsemblesGoogleDrive0bC15CloudFileSystemC","modules":[{"name":"EnsemblesGoogleDrive"}],"title":"GoogleDriveCloudFileSystem","navigatorTitle":[{"text":"GoogleDriveCloudFileSystem","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive"]]},"seeAlsoSections":[{"generated":true,"title":"Cloud File System","anchor":"Cloud-File-System","identifiers":["doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveAuthenticator"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"A cloud file system backed by the Google Drive REST API v3 using "},{"type":"codeVoice","code":"URLSession"},{"type":"text","text":"."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem"},"kind":"symbo