le(atPath:toPath:)"]}],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/EnsemblesGoogleDrive\/9Ensembles15CloudFileSystemP","doc:\/\/EnsemblesGoogleDrive\/s8SendableP","doc:\/\/EnsemblesGoogleDrive\/s16SendableMetatypeP"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"seeAlsoSections":[{"title":"Cloud File System","generated":true,"anchor":"Cloud-File-System","identifiers":["doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveAuthenticator"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"GoogleDriveCloudFileSystem"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This backend communicates directly with Google’s REST API — no third-party SDK"},{"type":"text","text":" "},{"type":"text","text":"is required. Authentication is handled via an OAuth 2.0 access token passed as"},{"type":"text","text":" "},{"type":"text","text":"a "},{"code":"Bearer","type":"codeVoice"},{"type":"text","text":" header on every request."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Google Drive uses file IDs rather than paths to identify files and folders."},{"type":"text","text":" "},{"type":"text","text":"This backend bridges the path-based "},{"code":"CloudFileSystem","type":"codeVoice"},{"type":"text","text":" protocol onto Google Drive’s"},{"type":"text","text":" "},{"type":"text","text":"ID-based API by walking the folder hierarchy to resolve Ensembles paths"},{"type":"text","text":" "},{"type":"text","text":"(e.g. "},{"code":"ensembleId\/events\/file.json","type":"codeVoice"},{"type":"text","text":") to Google Drive folder and file IDs."}]},{"