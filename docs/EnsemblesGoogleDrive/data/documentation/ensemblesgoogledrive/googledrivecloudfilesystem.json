{"topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/init(accessToken:)","doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/init(authenticator:)"]},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/isConnected"]},{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/connect()","doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/contentsOfDirectory(atPath:)","doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/createDirectory(atPath:)","doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/downloadFile(atPath:toLocalFile:)","doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/fetchUserIdentity()","doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/fileExists(atPath:)","doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/removeItem(atPath:)","doc:\/\/EnsemblesGoogleDrive\/documentation\/EnsemblesGoogleDrive\/GoogleDriveCloudFileSystem\/uploadLocalFile(atPath:toPath:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"GoogleDriveCloudFileSystem"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"This backend communicates directly with Google’s REST API — no third-party SDK","type":"text"},{"text":" ","type":"text"},{"text":"is required. Authentication is handled via an OAuth 2.0 access token passed as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"Bearer"},{"type":"text","text":" header on every request."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Google Drive uses file IDs rather than paths to identify files and folders."},{"type":"text","text":" "},{"type":"text","text":"This backend bridges the path-based "},{"code":"CloudFileSystem","type":"codeVoice"},{"type":"text","text":" protocol onto Google Drive’s"},{"type":"text","text":" "},{"type":"text","text":"ID-based API by walking the folder hierarchy to resolve Ensembles paths"},{"type":"text","text":" "},{"type":"text","text":"(e.g. "},{"code":"ensembleId\/events\/file.json","type":"codeVoice"},{"type":"text","text":") to Google Drive folder and file IDs."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Resolved IDs are cached in internal dictionaries to minimize API calls. The cache"},{"type":"text","text":" "},{"type":"text","text":"is invalidated when items are deleted or when not-found errors indicate stale entries."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Two initialization paths are available:"}],"type":"paragraph"},{"code":["\/\/ Simple: static access token (app manages refresh externally)","let cloudFS = GoogleDriveCloudFileSystem(accessToken: \"your-token\")","","\/\/ Authenticator: auto-refreshes expired tokens","let cloudFS = GoogleDriveCloudFileSystem(authenticator: authenticator)"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Setup","text":"Setup","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Go to the "},{"type":"reference","identifier":"https:\/\/console.cloud.google.com\/","isActive":true},{"text":" and crea