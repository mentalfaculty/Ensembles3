,{"code":"ensembleId\/events\/file.json","type":"codeVoice"},{"text":") to Google Drive folder and file IDs.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Resolved IDs are cached in internal dictionaries to minimize API calls. The cache","type":"text"},{"text":" ","type":"text"},{"text":"is invalidated when items are deleted or when not-found errors indicate stale entries.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Two initialization paths are available:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Simple: static access token (app manages refresh externally)","let cloudFS = GoogleDriveCloudFileSystem(accessToken: \"your-token\")","","\/\/ Authenticator: auto-refreshes expired tokens","let cloudFS = GoogleDriveCloudFileSystem(authenticator: authenticator)"],"syntax":"swift"},{"text":"Setup","level":2,"type":"heading","anchor":"Setup"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"Go to the ","type":"text"},{"type":"reference","identifier":"https:\/\/console.cloud.google.com\/","isActive":true},{"text":" and create a project","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Enable the ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Google Drive API"}]},{"text":" under ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"APIs & Services → Library"}]}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Create an ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"OAuth 2.0 Client ID"}]},{"text":" under ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"APIs & Services → Credentials"}]}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"For iOS\/macOS apps, choose “iOS” application type and enter your bundle ID","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Set the redirect URI (typically ","type":"text"},{"type":"codeVoice","code":"com.googleusercontent.apps.YOUR-CLIENT-ID:\/oauthredirect"},{"text":")","type":"text"}]}]}],"type":"unorderedList"}]},{"content":[{"inlineContent":[{"text":"Configure the authenticator and file system:","type":"text"}],"type":"paragraph"}]}]},{"type":"codeListing","code":["let config = GoogleDriveAuthenticator.Configuration(","    clientID: \"YOUR-CLIENT-ID.apps.googleusercontent.com\",","    redirectURI: \"com.googleusercontent.apps.YOUR-CLIENT-ID:\/oauthredirect\"",")","let authenticator = GoogleDriveAuthenticator(configuration: config)","try await authenticator.authorize(presenting: window)","","let cloudFS = GoogleDriveCloudFileSystem(authenticator: authenticator)","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MyStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")"],"syntax":"swift"},{"inlineContent":[{"text":"The authenticator stores tokens in the Keychain and refreshes them automatically","type":"text"},{"text":" ","type":"text"},{"text":"when they expire. The default scope is ","type":"text"},{"code":"drive.file","type":"codeVoice"},{"text":" (per-file access), which","type":"text"},{"text":" ","type":"text"},{"text":"limits the app to files it creates.","type":"text"}],"type":"paragraph"},{"text":"Threading","level":2,"type":"heading","anchor":"Threading"},{"inlineContent":[{"text":"This class is ","type":"text"},{"code":"@unchecked Sendable","type":"codeVoice"},{"text":". All network calls go through a shared","type":"text"},{"text":" ","type":"text"},{"code":"URLSession","type":"codeVoice"},{"text":" instance, which is thread-safe. Mutable state (caches, ","type":"text"},{"code":"loggedIn","type":"codeVoice"},{"text":" flag)","type":"text"},{"text":" ","type":"text"},{"text":"is accessed only from async methods that are serialized by the ensemble’s operation queue.","type":"text"}],"type":"paragraph"}]}],"metadata":{"externa