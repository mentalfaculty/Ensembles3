","text":")"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Configure the authenticator and file system:"}]}]}]},{"type":"codeListing","code":["let config = GoogleDriveAuthenticator.Configuration(","    clientID: \"YOUR-CLIENT-ID.apps.googleusercontent.com\",","    redirectURI: \"com.googleusercontent.apps.YOUR-CLIENT-ID:\/oauthredirect\"",")","let authenticator = GoogleDriveAuthenticator(configuration: config)","try await authenticator.authorize(presenting: window)","","let cloudFS = GoogleDriveCloudFileSystem(authenticator: authenticator)","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MyStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: cloudFS",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The authenticator stores tokens in the Keychain and refreshes them automatically"},{"type":"text","text":" "},{"type":"text","text":"when they expire. The default scope is "},{"code":"drive.file","type":"codeVoice"},{"type":"text","text":" (per-file access), which"},{"type":"text","text":" "},{"type":"text","text":"limits the app to files it creates."}]},{"type":"heading","level":2,"text":"Threading","anchor":"Threading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This class is "},{"code":"@unchecked Sendable","type":"codeVoice"},{"type":"text","text":". All network calls go through a shared"},{"type":"text","text":" "},{"code":"URLSession","type":"codeVoice"},{"type":"text","text":" instance, which is thread-safe. Mutable state (caches, "},{"code":"loggedIn","type":"codeVoice"},{"type":"text","text":" flag)"},{"type":"text","text":" "},{"type":"text","text":"is accessed only from async methods that are serialized by the ensemble’s operation queue."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensemblesgoogledrive\/googledrivecloudfilesystem"]}],"metadata":{"role":"symbol","symbo