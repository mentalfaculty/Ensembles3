{"sections":[],"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem"],"title":"Cloud File System","anchor":"Cloud-File-System"},{"identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/VaultInfo"],"title":"Structures","anchor":"Structures","generated":true},{"identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionError","doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionFormat","doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/FileEncryptor"],"title":"Enumerations","anchor":"Enumerations","generated":true}],"metadata":{"modules":[{"name":"EnsemblesEncrypted"}],"roleHeading":"Framework","role":"collection","title":"EnsemblesEncrypted","externalID":"EnsemblesEncrypted","symbolKind":"module"},"variants":[{"paths":["\/documentation\/ensemblesencrypted"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"inlineContent":[{"text":"EnsemblesEncrypted provides ","type":"text"},{"type":"reference","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem","isActive":true},{"text":", a wrapper that encrypts files before uploading and decrypts after downloading. It can wrap any ","type":"text"},{"type":"codeVoice","code":"CloudFileSystem"},{"text":" implementation — CloudKit, Google Drive, WebDAV, or your own custom backend — to provide end-to-end encryption for sync data.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Encrypted files are stored in a password-derived vault directory with a ","type":"text"},{"type":"codeVoice","code":".cdecrypt"},{"text":" extension. This is backward compatible with the Ensembles 2 Objective-C ","type":"text"},{"type":"codeVoice","code":"CDEEncryptedCloudFileSystem"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Encryption Formats","type":"heading","anchor":"Encryption-Formats","level":3},{"inlineContent":[{"text":"Two encryption formats are available:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".modern"}]},{"type":"text","text":" (default) — AES-256-GCM. Fast, authenticated encryption using Apple’s CryptoKit. Recommended for new apps."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".legacy"}]},{"type":"text","text":" — RNCryptor v3 format. Use this for backward compatibility with Ensembles 2 encrypted data."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The backend auto-detects the encryption format when downloading, so a ","type":"text"},{"type":"codeVoice","code":".modern"},{"text":" client can read ","type":"text"},{"type":"codeVoice","code":".legacy"},{"text":" files and vice versa. The format setting only controls how ","type":"text"},{"inlineContent":[{"type":"text","text":"new"}],"type":"emphasis"},{"text":" files are encrypted.","type":"text"}],"type":"paragraph"},{"text":"Setup","type":"heading","anchor":"Setup","level":3},{"inlineContent":[{"text":"Wrap any cloud file system with encryption:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import Ensembles","import EnsemblesEncrypted","import EnsemblesCloudKit","","\/\/ Wrap CloudKit with encryption","let cloudKitFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","let encryptedFS = EncryptedCloudFileSystem(","    cloudFileSystem: cloudKitFS,","    password: \"user-supplied-password\"",")","","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: encryptedFS!",")","try await ensemble?.attachPersistentStore()"]},{"inlineContent":[{"text":"For more control over the vault, use the ","type":"text"},{"type":"codeVoice","code":"VaultInfo"},{"text":" initializer:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let encryptedFS = EncryptedCloudFileSystem(","    cloudFileSystem: innerFS,","    vaultInfo: vaultInfo,","    encryptionFormat: .modern",")"]},{"text":"When to Use Encryption","type":"heading","anchor":"When-to-Use-Encryption","level":3},{"inlineContent":[{"type":"text","text":"Ensembles sync data is stored as opaque binary files, so even without encryption the raw data is not human-readable. However, it could be deserialized by someone with access to your cloud storage."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For ","type":"text"},{"inlineContent":[{"text":"CloudKit","type":"text"}],"type":"strong"},{"text":", Apple encrypts ","type":"text"},{"type":"codeVoice","code":"CKAsset"},{"text":" data at rest. With Advanced Data Protection (ADP) enabled, assets are end-to-end encrypted. Wrapping CloudKit with ","type":"text"},{"type":"codeVoice","code":"EncryptedCloudFileSystem"},{"text":" adds a layer of protection that doesn’t depend on the user enabling ADP.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For "},{"type":"strong","inlineContent":[{"text":"third-party backends","type":"text"}]},{"type":"text","text":" (Google Drive, OneDrive, WebDAV, etc.), the storage provider can see the raw files. Wrapping with "},{"type":"codeVoice","code":"EncryptedCloudFileSystem"},{"type":"text","text":" ensures data is encrypted before it leaves the device, regardless of what the provider does."}],"type":"paragraph"},{"level":3,"text":"How It Works","anchor":"How-It-Works","type":"heading"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Vault directory"}],"type":"strong"},{"text":" — All encrypted files are stored inside a vault directory in the cloud, derived from the password. Different passwords create different vaults, so the same cloud account can host multiple independent encrypted sync stores.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Upload"}],"type":"strong"},{"text":" — When Ensembles uploads a file, the wrapper encrypts it to a local temporary file, uploads the encrypted version with a ","type":"text"},{"type":"codeVoice","code":".cdecrypt"},{"text":" extension, then removes the temporary file.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Download"}]},{"type":"text","text":" — When Ensembles downloads a file, the wrapper downloads the encrypted "},{"code":".cdecrypt","type":"codeVoice"},{"type":"text","text":" file, auto-detects the format (modern or legacy), decrypts it to a local temporary file, and returns the decrypted content."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Backward compatibility"}],"type":"strong"},{"type":"text","text":" — The "},{"code":".legacy","type":"codeVoice"},{"type":"text","text":" format uses RNCryptor v3, the same encryption format used by Ensembles 2’s "},{"code":"CDEEncryptedCloudFileSystem","type":"codeVoice"},{"type":"text","text":". Apps migrating from E2 to E3 can read existing encrypted cloud data without re-encrypting."}],"type":"paragraph"}]}]},{"type":"heading","anchor":"Wrapping-Other-Backends","level":3,"text":"Wrapping Other Backends"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The wrapper works with any "},{"code":"CloudFileSystem","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Wrap Google Drive","let encryptedGDrive = EncryptedCloudFileSystem(","    cloudFileSystem: GoogleDriveCloudFileSystem(authenticator: gdAuthenticator),","    password: password",")","","\/\/ Wrap WebDAV","let encryptedWebDAV = EncryptedCloudFileSystem(","    cloudFileSystem: WebDAVCloudFileSystem(baseURL: webdavURL, username: user, password: pass),","    password: encryptionPassword",")"]},{"type":"heading","anchor":"Dependencies","level":3,"text":"Dependencies"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This module has "},{"inlineContent":[{"text":"no external dependencies","type":"text"}],"type":"strong"},{"type":"text","text":" beyond Foundation, CryptoKit, and the core "},{"code":"Ensembles","type":"codeVoice"},{"type":"text","text":" framework."}]}],"kind":"content"}],"hierarchy":{"paths":[[]]},"abstract":[{"text":"An encryption wrapper for any Ensembles cloud backend.","type":"text"}],"references":{"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptionError":{"kind":"symbol","url":"\/documentation\/ensemblesencrypted\/encryptionerror","navigatorTitle":[{"text":"EncryptionError","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EncryptionError","kind":"identifier"}],"type":"topic","role":"symbol","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionError","title":"EncryptionError","abstract":[{"text":"Errors that can occur during encryption or decryption.","type":"text"}]},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted":{"role":"collection","url":"\/documentation\/ensemblesencrypted","abstract":[{"type":"text","text":"An encryption wrapper for any Ensembles cloud backend."}],"identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted","title":"EnsemblesEncrypted","type":"topic","kind":"symbol"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptionFormat":{"kind":"symbol","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionFormat","abstract":[{"text":"The encryption format to use when encrypting data.","type":"text"}],"title":"EncryptionFormat","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EncryptionFormat","kind":"identifier"}],"url":"\/documentation\/ensemblesencrypted\/encryptionformat","role":"symbol","type":"topic","navigatorTitle":[{"text":"EncryptionFormat","kind":"identifier"}]},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/VaultInfo":{"kind":"symbol","url":"\/documentation\/ensemblesencrypted\/vaultinfo","navigatorTitle":[{"text":"VaultInfo","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VaultInfo","kind":"identifier"}],"type":"topic","role":"symbol","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/VaultInfo","abstract":[{"type":"text","text":"Represents a vault in an encrypted cloud file system."}],"title":"VaultInfo"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptedCloudFileSystem":{"kind":"symbol","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem","abstract":[{"text":"A cloud file system wrapper that encrypts files before uploading","type":"text"},{"text":" ","type":"text"},{"text":"and decrypts them after downloading.","type":"text"}],"title":"EncryptedCloudFileSystem","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EncryptedCloudFileSystem","kind":"identifier"}],"url":"\/documentation\/ensemblesencrypted\/encryptedcloudfilesystem","role":"symbol","type":"topic","navigatorTitle":[{"text":"EncryptedCloudFileSystem","kind":"identifier"}]},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/FileEncryptor":{"kind":"symbol","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/FileEncryptor","abstract":[{"text":"Unified encryption\/decryption interface with automatic format detection on decrypt.","type":"text"}],"title":"FileEncryptor","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileEncryptor"}],"url":"\/documentation\/ensemblesencrypted\/fileencryptor","role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileEncryptor"}]}}}