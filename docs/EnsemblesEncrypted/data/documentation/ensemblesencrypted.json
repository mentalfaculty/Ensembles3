{"abstract":[{"type":"text","text":"An encryption wrapper for any Ensembles cloud backend."}],"topicSections":[{"anchor":"Cloud-File-System","identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem"],"title":"Cloud File System"},{"anchor":"Structures","identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/VaultInfo"],"title":"Structures","generated":true},{"anchor":"Enumerations","identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionError","doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionFormat","doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/FileEncryptor"],"title":"Enumerations","generated":true}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"EnsemblesEncrypted provides ","type":"text"},{"identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem","isActive":true,"type":"reference"},{"text":", a wrapper that encrypts files before uploading and decrypts after downloading. It can wrap any ","type":"text"},{"code":"CloudFileSystem","type":"codeVoice"},{"text":" implementation — CloudKit, Google Drive, WebDAV, or your own custom backend — to provide end-to-end encryption for sync data.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Encrypted files are stored in a password-derived vault directory with a ","type":"text"},{"code":".cdecrypt","type":"codeVoice"},{"text":" extension. This is backward compatible with the Ensembles 2 Objective-C ","type":"text"},{"code":"CDEEncryptedCloudFileSystem","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"heading","text":"Encryption Formats","anchor":"Encryption-Formats","level":3},{"type":"paragraph","inlineContent":[{"text":"Two encryption formats are available:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":".modern"}],"type":"strong"},{"text":" (default) — AES-256-GCM. Fast, authenticated encryption using Apple’s CryptoKit. Recommended for new apps.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"codeVoice","code":".legacy"}],"type":"strong"},{"text":" — RNCryptor v3 format. Use this for backward compatibility with Ensembles 2 encrypted data.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The backend auto-detects the encryption format when downloading, so a ","type":"text"},{"code":".modern","type":"codeVoice"},{"text":" client can read ","type":"text"},{"code":".legacy","type":"codeVoice"},{"text":" files and vice versa. The format setting only controls how ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"new","type":"text"}]},{"text":" files are encrypted.","type":"text"}]},{"type":"heading","text":"Setup","anchor":"Setup","level":3},{"type":"paragraph","inlineContent":[{"text":"Wrap any cloud file system with encryption:","type":"text"}]},{"syntax":"swift","code":["import Ensembles","import EnsemblesEncrypted","import EnsemblesCloudKit","","\/\/ Wrap CloudKit with encryption","let cloudKitFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","let encryptedFS = EncryptedCloudFileSystem(","    cloudFileSystem: cloudKitFS,","    password: \"user-supplied-password\"",")","","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: encryptedFS!",")","try await ensemble?.attachPersistentStore()"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"For more control over the vault, use the ","type":"text"},{"code":"VaultInfo","type":"codeVoice"},{"text":" initializer:","type":"text"}]},{"syntax":"swift","code":["let encryptedFS = EncryptedCloudFileSystem(","    cloudFileSystem: innerFS,","    vaultInfo: vaultInfo,","    encryptionFormat: .modern",")"],"type":"codeListing"},{"type":"heading","text":"How It Works","anchor":"How-It-Works","level":3},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Vault directory"}],"type":"strong"},{"text":" — All encrypted files are stored inside a vault directory in the cloud, derived from the password. Different passwords create different vaults, so the same cloud account can host multiple independent encrypted sync stores.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"Upload","type":"text"}],"type":"strong"},{"text":" — When Ensembles uploads a file, the wrapper encrypts it to a local temporary file, uploads the encrypted version with a ","type":"text"},{"type":"codeVoice","code":".cdecrypt"},{"text":" extension, then removes the temporary file.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Download","type":"text"}]},{"type":"text","text":" — When Ensembles downloads a file, the wrapper downloads the encrypted "},{"type":"codeVoice","code":".cdecrypt"},{"type":"text","text":" file, auto-detects the format (modern or legacy), decrypts it to a local temporary file, and returns the decrypted content."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Backward compatibility","type":"text"}]},{"type":"text","text":" — The "},{"type":"codeVoice","code":".legacy"},{"type":"text","text":" format uses RNCryptor v3, the same encryption format used by Ensembles 2’s "},{"type":"codeVoice","code":"CDEEncryptedCloudFileSystem"},{"type":"text","text":". Apps migrating from E2 to E3 can read existing encrypted cloud data without re-encrypting."}]}]}],"type":"orderedList"},{"text":"Wrapping Other Backends","type":"heading","anchor":"Wrapping-Other-Backends","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The wrapper works with any "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Wrap Google Drive","let encryptedGDrive = EncryptedCloudFileSystem(","    cloudFileSystem: GoogleDriveCloudFileSystem(authenticator: gdAuthenticator),","    password: password",")","","\/\/ Wrap WebDAV","let encryptedWebDAV = EncryptedCloudFileSystem(","    cloudFileSystem: WebDAVCloudFileSystem(baseURL: webdavURL, username: user, password: pass),","    password: encryptionPassword",")"]},{"text":"Dependencies","type":"heading","anchor":"Dependencies","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"This module has "},{"type":"strong","inlineContent":[{"type":"text","text":"no external dependencies"}]},{"type":"text","text":" beyond Foundation, CryptoKit, and the core "},{"type":"codeVoice","code":"Ensembles"},{"type":"text","text":" framework."}]}]}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"roleHeading":"Framework","modules":[{"name":"EnsemblesEncrypted"}],"title":"EnsemblesEncrypted","role":"collection","symbolKind":"module","externalID":"EnsemblesEncrypted"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensemblesencrypted"]}],"hierarchy":{"paths":[[]]},"identifier":{"url":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted","interfaceLanguage":"swift"},"references":{"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/FileEncryptor":{"title":"FileEncryptor","navigatorTitle":[{"text":"FileEncryptor","kind":"identifier"}],"url":"\/documentation\/ensemblesencrypted\/fileencryptor","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/FileEncryptor","abstract":[{"type":"text","text":"Unified encryption\/decryption interface with automatic format detection on decrypt."}],"role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FileEncryptor","kind":"identifier"}],"type":"topic","kind":"symbol"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptionError":{"abstract":[{"text":"Errors that can occur during encryption or decryption.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionError","navigatorTitle":[{"text":"EncryptionError","kind":"identifier"}],"title":"EncryptionError","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EncryptionError","kind":"identifier"}],"type":"topic","url":"\/documentation\/ensemblesencrypted\/encryptionerror"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptedCloudFileSystem":{"abstract":[{"type":"text","text":"A cloud file system wrapper that encrypts files before uploading"},{"text":" ","type":"text"},{"text":"and decrypts them after downloading.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem","navigatorTitle":[{"kind":"identifier","text":"EncryptedCloudFileSystem"}],"title":"EncryptedCloudFileSystem","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"EncryptedCloudFileSystem"}],"type":"topic","url":"\/documentation\/ensemblesencrypted\/encryptedcloudfilesystem"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted":{"url":"\/documentation\/ensemblesencrypted","abstract":[{"type":"text","text":"An encryption wrapper for any Ensembles cloud backend."}],"title":"EnsemblesEncrypted","type":"topic","role":"collection","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted","kind":"symbol"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptionFormat":{"kind":"symbol","abstract":[{"text":"The encryption format to use when encrypting data.","type":"text"}],"type":"topic","title":"EncryptionFormat","fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"kind":"identifier","text":"EncryptionFormat"}],"navigatorTitle":[{"text":"EncryptionFormat","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionFormat","url":"\/documentation\/ensemblesencrypted\/encryptionformat"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/VaultInfo":{"abstract":[{"type":"text","text":"Represents a vault in an encrypted cloud file system."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VaultInfo"}],"url":"\/documentation\/ensemblesencrypted\/vaultinfo","navigatorTitle":[{"kind":"identifier","text":"VaultInfo"}],"type":"topic","kind":"symbol","title":"VaultInfo","role":"symbol","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/VaultInfo"}}}