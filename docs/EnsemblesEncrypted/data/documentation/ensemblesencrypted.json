{"abstract":[{"text":"An encryption wrapper for any Ensembles cloud backend.","type":"text"}],"metadata":{"title":"EnsemblesEncrypted","externalID":"EnsemblesEncrypted","symbolKind":"module","modules":[{"name":"EnsemblesEncrypted"}],"role":"collection","roleHeading":"Framework"},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[[]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"EnsemblesEncrypted provides "},{"identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem","isActive":true,"type":"reference"},{"type":"text","text":", a wrapper that encrypts files before uploading and decrypts after downloading. It can wrap any "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" implementation — CloudKit, Google Drive, WebDAV, or your own custom backend — to provide end-to-end encryption for sync data."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Encrypted files are stored in a password-derived vault directory with a "},{"type":"codeVoice","code":".cdecrypt"},{"type":"text","text":" extension. This is backward compatible with the Ensembles 2 Objective-C "},{"type":"codeVoice","code":"CDEEncryptedCloudFileSystem"},{"type":"text","text":"."}]},{"level":3,"anchor":"Encryption-Formats","text":"Encryption Formats","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two encryption formats are available:"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"code":".modern","type":"codeVoice"}],"type":"strong"},{"text":" (default) — AES-256-GCM. Fast, authenticated encryption using Apple’s CryptoKit. Recommended for new apps.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":".legacy","type":"codeVoice"}],"type":"strong"},{"type":"text","text":" — RNCryptor v3 format. Use this for backward compatibility with Ensembles 2 encrypted data."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The backend auto-detects the encryption format when downloading, so a ","type":"text"},{"code":".modern","type":"codeVoice"},{"text":" client can read ","type":"text"},{"code":".legacy","type":"codeVoice"},{"text":" files and vice versa. The format setting only controls how ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"new"}]},{"text":" files are encrypted.","type":"text"}]},{"text":"Setup","level":3,"anchor":"Setup","type":"heading"},{"inlineContent":[{"type":"text","text":"Wrap any cloud file system with encryption:"}],"type":"paragraph"},{"type":"codeListing","code":["import Ensembles","import EnsemblesEncrypted","import EnsemblesCloudKit","","\/\/ Wrap CloudKit with encryption","let cloudKitFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","let encryptedFS = EncryptedCloudFileSystem(","    cloudFileSystem: cloudKitFS,","    password: \"user-supplied-password\"",")","","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: encryptedFS!",")","try await ensemble?.attachPersistentStore()"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more control over the vault, use the "},{"code":"VaultInfo","type":"codeVoice"},{"text":" initializer:","type":"text"}]},{"syntax":"swift","code":["let encryptedFS = EncryptedCloudFileSystem(","    cloudFileSystem: innerFS,","    vaultInfo: vaultInfo,","    encryptionFormat: .modern",")"],"type":"codeListing"},{"type":"heading","text":"When to Use Encryption","level":3,"anchor":"When-to-Use-Encryption"},{"inlineContent":[{"type":"text","text":"Ensembles sync data is stored as opaque binary files, so even without encryption the raw data is not human-readable. However, it could be deserialized by someone with access to your cloud storage."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For "},{"type":"strong","inlineContent":[{"type":"text","text":"CloudKit"}]},{"text":", Apple encrypts ","type":"text"},{"type":"codeVoice","code":"CKAsset"},{"text":" data at rest. With Advanced Data Protection (ADP) enabled, assets are end-to-end encrypted. Wrapping CloudKit with ","type":"text"},{"type":"codeVoice","code":"EncryptedCloudFileSystem"},{"text":" adds a layer of protection that doesn’t depend on the user enabling ADP.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For ","type":"text"},{"type":"strong","inlineContent":[{"text":"third-party backends","type":"text"}]},{"type":"text","text":" (Google Drive, OneDrive, WebDAV, etc.), the storage provider can see the raw files. Wrapping with "},{"code":"EncryptedCloudFileSystem","type":"codeVoice"},{"text":" ensures data is encrypted before it leaves the device, regardless of what the provider does.","type":"text"}],"type":"paragraph"},{"text":"How It Works","level":3,"anchor":"How-It-Works","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Vault directory"}]},{"type":"text","text":" — All encrypted files are stored inside a vault directory in the cloud, derived from the password. Different passwords create different vaults, so the same cloud account can host multiple independent encrypted sync stores."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Upload"}]},{"type":"text","text":" — When Ensembles uploads a file, the wrapper encrypts it to a local temporary file, uploads the encrypted version with a "},{"type":"codeVoice","code":".cdecrypt"},{"type":"text","text":" extension, then removes the temporary file."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Download"}],"type":"strong"},{"text":" — When Ensembles downloads a file, the wrapper downloads the encrypted ","type":"text"},{"type":"codeVoice","code":".cdecrypt"},{"type":"text","text":" file, auto-detects the format (modern or legacy), decrypts it to a local temporary file, and returns the decrypted content."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Backward compatibility","type":"text"}],"type":"strong"},{"type":"text","text":" — The "},{"type":"codeVoice","code":".legacy"},{"type":"text","text":" format uses RNCryptor v3, the same encryption format used by Ensembles 2’s "},{"code":"CDEEncryptedCloudFileSystem","type":"codeVoice"},{"type":"text","text":". Apps migrating from E2 to E3 can read existing encrypted cloud data without re-encrypting."}]}]}],"type":"orderedList"},{"text":"Wrapping Other Backends","level":3,"anchor":"Wrapping-Other-Backends","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The wrapper works with any ","type":"text"},{"code":"CloudFileSystem","type":"codeVoice"},{"text":":","type":"text"}]},{"code":["\/\/ Wrap Google Drive","let encryptedGDrive = EncryptedCloudFileSystem(","    cloudFileSystem: GoogleDriveCloudFileSystem(authenticator: gdAuthenticator),","    password: password",")","","\/\/ Wrap WebDAV","let encryptedWebDAV = EncryptedCloudFileSystem(","    cloudFileSystem: WebDAVCloudFileSystem(baseURL: webdavURL, username: user, password: pass),","    password: encryptionPassword",")"],"syntax":"swift","type":"codeListing"},{"level":3,"anchor":"Dependencies","text":"Dependencies","type":"heading"},{"inlineContent":[{"text":"This module has ","type":"text"},{"inlineContent":[{"text":"no external dependencies","type":"text"}],"type":"strong"},{"type":"text","text":" beyond Foundation, CryptoKit, and the core "},{"type":"codeVoice","code":"Ensembles"},{"type":"text","text":" framework."}],"type":"paragraph"}]}],"sections":[],"topicSections":[{"identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem"],"title":"Cloud File System","anchor":"Cloud-File-System"},{"identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/VaultInfo"],"generated":true,"title":"Structures","anchor":"Structures"},{"identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionError","doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionFormat","doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/FileEncryptor"],"generated":true,"title":"Enumerations","anchor":"Enumerations"}],"identifier":{"url":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/ensemblesencrypted"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted":{"abstract":[{"type":"text","text":"An encryption wrapper for any Ensembles cloud backend."}],"identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted","title":"EnsemblesEncrypted","role":"collection","type":"topic","kind":"symbol","url":"\/documentation\/ensemblesencrypted"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/FileEncryptor":{"abstract":[{"type":"text","text":"Unified encryption\/decryption interface with automatic format detection on decrypt."}],"identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/FileEncryptor","navigatorTitle":[{"kind":"identifier","text":"FileEncryptor"}],"type":"topic","role":"symbol","url":"\/documentation\/ensemblesencrypted\/fileencryptor","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileEncryptor"}],"kind":"symbol","title":"FileEncryptor"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptedCloudFileSystem":{"abstract":[{"type":"text","text":"A cloud file system wrapper that encrypts files before uploading"},{"text":" ","type":"text"},{"type":"text","text":"and decrypts them after downloading."}],"navigatorTitle":[{"text":"EncryptedCloudFileSystem","kind":"identifier"}],"identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem","role":"symbol","type":"topic","url":"\/documentation\/ensemblesencrypted\/encryptedcloudfilesystem","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EncryptedCloudFileSystem","kind":"identifier"}],"title":"EncryptedCloudFileSystem"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptionFormat":{"role":"symbol","url":"\/documentation\/ensemblesencrypted\/encryptionformat","type":"topic","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionFormat","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EncryptionFormat","kind":"identifier"}],"title":"EncryptionFormat","abstract":[{"type":"text","text":"The encryption format to use when encrypting data."}],"navigatorTitle":[{"text":"EncryptionFormat","kind":"identifier"}],"kind":"symbol"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptionError":{"identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionError","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EncryptionError","kind":"identifier"}],"kind":"symbol","title":"EncryptionError","abstract":[{"type":"text","text":"Errors that can occur during encryption or decryption."}],"role":"symbol","navigatorTitle":[{"text":"EncryptionError","kind":"identifier"}],"type":"topic","url":"\/documentation\/ensemblesencrypted\/encryptionerror"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/VaultInfo":{"role":"symbol","url":"\/documentation\/ensemblesencrypted\/vaultinfo","type":"topic","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/VaultInfo","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VaultInfo","kind":"identifier"}],"title":"VaultInfo","abstract":[{"type":"text","text":"Represents a vault in an encrypted cloud file system."}],"navigatorTitle":[{"text":"VaultInfo","kind":"identifier"}],"kind":"symbol"}}}