{"sections":[],"hierarchy":{"paths":[[]]},"kind":"symbol","abstract":[{"text":"An encryption wrapper for any Ensembles cloud backend.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem"],"title":"Cloud File System","anchor":"Cloud-File-System"},{"identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/VaultInfo"],"title":"Structures","anchor":"Structures","generated":true},{"identifiers":["doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionError","doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionFormat","doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/FileEncryptor"],"title":"Enumerations","anchor":"Enumerations","generated":true}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"EnsemblesEncrypted provides "},{"type":"reference","isActive":true,"identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem"},{"type":"text","text":", a wrapper that encrypts files before uploading and decrypts after downloading. It can wrap any "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":" implementation — CloudKit, Google Drive, WebDAV, or your own custom backend — to provide end-to-end encryption for sync data."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Encrypted files are stored in a password-derived vault directory with a "},{"type":"codeVoice","code":".cdecrypt"},{"type":"text","text":" extension. This is backward compatible with the Ensembles 2 Objective-C "},{"type":"codeVoice","code":"CDEEncryptedCloudFileSystem"},{"type":"text","text":"."}]},{"anchor":"Encryption-Formats","text":"Encryption Formats","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two encryption formats are available:"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"code":".modern","type":"codeVoice"}],"type":"strong"},{"text":" (default) — AES-256-GCM. Fast, authenticated encryption using Apple’s CryptoKit. Recommended for new apps.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"code":".legacy","type":"codeVoice"}],"type":"strong"},{"text":" — RNCryptor v3 format. Use this for backward compatibility with Ensembles 2 encrypted data.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The backend auto-detects the encryption format when downloading, so a "},{"type":"codeVoice","code":".modern"},{"type":"text","text":" client can read "},{"type":"codeVoice","code":".legacy"},{"type":"text","text":" files and vice versa. The format setting only controls how "},{"inlineContent":[{"type":"text","text":"new"}],"type":"emphasis"},{"type":"text","text":" files are encrypted."}]},{"anchor":"Setup","text":"Setup","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Wrap any cloud file system with encryption:"}]},{"code":["import Ensembles","import EnsemblesEncrypted","import EnsemblesCloudKit","","\/\/ Wrap CloudKit with encryption","let cloudKitFS = CloudKitFileSystem(","    ubiquityContainerIdentifier: \"iCloud.com.yourcompany.yourapp\"",")","let encryptedFS = EncryptedCloudFileSystem(","    cloudFileSystem: cloudKitFS,","    password: \"user-supplied-password\"",")","","let ensemble = CoreDataEnsemble(","    ensembleIdentifier: \"MainStore\",","    persistentStoreURL: storeURL,","    managedObjectModelURL: modelURL,","    cloudFileSystem: encryptedFS!",")","try await ensemble?.attachPersistentStore()"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more control over the vault, use the "},{"type":"codeVoice","code":"VaultInfo"},{"type":"text","text":" initializer:"}]},{"code":["let encryptedFS = EncryptedCloudFileSystem(","    cloudFileSystem: innerFS,","    vaultInfo: vaultInfo,","    encryptionFormat: .modern",")"],"syntax":"swift","type":"codeListing"},{"anchor":"How-It-Works","text":"How It Works","type":"heading","level":3},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Vault directory"}],"type":"strong"},{"text":" — All encrypted files are stored inside a vault directory in the cloud, derived from the password. Different passwords create different vaults, so the same cloud account can host multiple independent encrypted sync stores.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Upload"}],"type":"strong"},{"text":" — When Ensembles uploads a file, the wrapper encrypts it to a local temporary file, uploads the encrypted version with a ","type":"text"},{"type":"codeVoice","code":".cdecrypt"},{"text":" extension, then removes the temporary file.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Download"}],"type":"strong"},{"text":" — When Ensembles downloads a file, the wrapper downloads the encrypted ","type":"text"},{"type":"codeVoice","code":".cdecrypt"},{"text":" file, auto-detects the format (modern or legacy), decrypts it to a local temporary file, and returns the decrypted content.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"Backward compatibility"}],"type":"strong"},{"text":" — The ","type":"text"},{"type":"codeVoice","code":".legacy"},{"text":" format uses RNCryptor v3, the same encryption format used by Ensembles 2’s ","type":"text"},{"type":"codeVoice","code":"CDEEncryptedCloudFileSystem"},{"text":". Apps migrating from E2 to E3 can read existing encrypted cloud data without re-encrypting.","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"Wrapping-Other-Backends","text":"Wrapping Other Backends","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The wrapper works with any "},{"type":"codeVoice","code":"CloudFileSystem"},{"type":"text","text":":"}]},{"code":["\/\/ Wrap Google Drive","let encryptedGDrive = EncryptedCloudFileSystem(","    cloudFileSystem: GoogleDriveCloudFileSystem(authenticator: gdAuthenticator),","    password: password",")","","\/\/ Wrap WebDAV","let encryptedWebDAV = EncryptedCloudFileSystem(","    cloudFileSystem: WebDAVCloudFileSystem(baseURL: webdavURL, username: user, password: pass),","    password: encryptionPassword",")"],"syntax":"swift","type":"codeListing"},{"anchor":"Dependencies","text":"Dependencies","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"This module has "},{"inlineContent":[{"type":"text","text":"no external dependencies"}],"type":"strong"},{"type":"text","text":" beyond Foundation, CryptoKit, and the core "},{"type":"codeVoice","code":"Ensembles"},{"type":"text","text":" framework."}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/ensemblesencrypted"]}],"metadata":{"symbolKind":"module","externalID":"EnsemblesEncrypted","modules":[{"name":"EnsemblesEncrypted"}],"role":"collection","roleHeading":"Framework","title":"EnsemblesEncrypted"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptionFormat":{"title":"EncryptionFormat","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"EncryptionFormat"}],"role":"symbol","abstract":[{"type":"text","text":"The encryption format to use when encrypting data."}],"type":"topic","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionFormat","url":"\/documentation\/ensemblesencrypted\/encryptionformat","navigatorTitle":[{"kind":"identifier","text":"EncryptionFormat"}]},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptedCloudFileSystem":{"kind":"symbol","url":"\/documentation\/ensemblesencrypted\/encryptedcloudfilesystem","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"EncryptedCloudFileSystem"}],"abstract":[{"type":"text","text":"A cloud file system wrapper that encrypts files before uploading"},{"type":"text","text":" "},{"type":"text","text":"and decrypts them after downloading."}],"title":"EncryptedCloudFileSystem","role":"symbol","navigatorTitle":[{"text":"EncryptedCloudFileSystem","kind":"identifier"}],"identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptedCloudFileSystem","type":"topic"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/FileEncryptor":{"title":"FileEncryptor","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileEncryptor"}],"role":"symbol","abstract":[{"type":"text","text":"Unified encryption\/decryption interface with automatic format detection on decrypt."}],"type":"topic","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/FileEncryptor","url":"\/documentation\/ensemblesencrypted\/fileencryptor","navigatorTitle":[{"kind":"identifier","text":"FileEncryptor"}]},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/EncryptionError":{"role":"symbol","navigatorTitle":[{"text":"EncryptionError","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EncryptionError","kind":"identifier"}],"abstract":[{"text":"Errors that can occur during encryption or decryption.","type":"text"}],"kind":"symbol","title":"EncryptionError","type":"topic","url":"\/documentation\/ensemblesencrypted\/encryptionerror","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/EncryptionError"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted/VaultInfo":{"role":"symbol","navigatorTitle":[{"text":"VaultInfo","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VaultInfo","kind":"identifier"}],"abstract":[{"text":"Represents a vault in an encrypted cloud file system.","type":"text"}],"title":"VaultInfo","kind":"symbol","type":"topic","url":"\/documentation\/ensemblesencrypted\/vaultinfo","identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted\/VaultInfo"},"doc://EnsemblesEncrypted/documentation/EnsemblesEncrypted":{"title":"EnsemblesEncrypted","kind":"symbol","role":"collection","type":"topic","abstract":[{"type":"text","text":"An encryption wrapper for any Ensembles cloud backend."}],"identifier":"doc:\/\/EnsemblesEncrypted\/documentation\/EnsemblesEncrypted","url":"\/documentation\/ensemblesencrypted"}}}